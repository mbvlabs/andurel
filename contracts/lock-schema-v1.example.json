{
  "schemaVersion": 1,
  "version": "v1.0.0",
  "tools": {
    "templ": {
      "version": "v0.3.1020",
      "source": "github.com/a-h/templ",
      "download": {
        "urlTemplate": "https://github.com/a-h/templ/releases/download/{{version}}/templ_{{os_capitalized}}_{{arch_x86_64}}.tar.gz",
        "archive": "tar.gz",
        "binaryName": "templ",
        "sha256": {
          "linux/amd64": "1111111111111111111111111111111111111111111111111111111111111111",
          "linux/arm64": "2222222222222222222222222222222222222222222222222222222222222222",
          "darwin/amd64": "3333333333333333333333333333333333333333333333333333333333333333",
          "darwin/arm64": "4444444444444444444444444444444444444444444444444444444444444444"
        }
      },
      "versionCheck": {
        "args": [
          "--version"
        ],
        "regexp": "v?([0-9]+\\.[0-9]+\\.[0-9]+)"
      }
    }
  }
}
