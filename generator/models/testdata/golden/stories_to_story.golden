package models

import (
	"github.com/google/uuid"
	"github.com/jackc/pgx/v5/pgtype"


	"github.com/example/test/models/internal/db"
)

type storyBase struct{}

var Story = storyBase{}

type StoryEntity struct {
	ID uuid.UUID
	CreatedAt pgtype.Timestamptz
	UpdatedAt pgtype.Timestamptz
	Title string
	Content pgtype.Text
}

func rowToStoryEntity(row db.Story) StoryEntity {
	return StoryEntity{
		ID: row.ID,
		CreatedAt: row.CreatedAt,
		UpdatedAt: row.UpdatedAt,
		Title: row.Title,
		Content: row.Content,
	}
}
