package factories

import (
	"context"
	"fmt"
{{- range .StandardImports}}
	"{{.}}"
{{- end}}

	"{{.ModulePath}}/internal/storage"
	"{{.ModulePath}}/models"
{{- range .ExternalImports}}
	"{{.}}"
{{- end}}
)

// {{.ModelName}}Factory wraps models.{{.EntityName}} for testing
type {{.ModelName}}Factory struct {
	models.{{.EntityName}}
}

type {{.ModelName}}Option func(*{{.ModelName}}Factory)

// Build{{.ModelName}} creates an in-memory {{.ModelName}} with default test values.
// Auto-managed fields (ID, timestamps) are left at zero and set by Create{{.ModelName}}.
func Build{{.ModelName}}({{- range .ForeignKeyFields}}{{.ArgumentName}} {{.Type}}, {{end}}opts ...{{.ModelName}}Option) models.{{.EntityName}} {
	f := &{{.ModelName}}Factory{
		{{.EntityName}}: models.{{.EntityName}}{
{{- range .Fields}}
{{- if not .IsAutoManaged}}
{{- if .IsFK}}
			{{.Name}}: {{.ArgumentName}},
{{- else}}
			{{.Name}}: {{.DefaultValue}},
{{- end}}
{{- end}}
{{- end}}
		},
	}

	for _, opt := range opts {
		opt(f)
	}

	return f.{{.EntityName}}
}

{{if .HasCreateFunction}}
// Create{{.ModelName}} creates and persists a {{.ModelName}} to the database.
// It returns the entity populated with all DB-assigned values via RETURNING *.
func Create{{.ModelName}}(ctx context.Context, exec storage.Executor, {{range .ForeignKeyFields}}{{.ArgumentName}} {{.Type}}, {{end}}opts ...{{.ModelName}}Option) (models.{{.EntityName}}, error) {
	built := Build{{.ModelName}}({{range .ForeignKeyFields}}{{.ArgumentName}}, {{end}}opts...)

	entity := models.{{.EntityName}}{
{{- if and (not .IsAutoIncrementID) .IDGoFieldName}}
{{- if or (not .IDType) (eq .IDType "uuid.UUID")}}
		{{.IDGoFieldName}}: uuid.New(),
{{- else}}
		{{.IDGoFieldName}}: built.{{.IDGoFieldName}},
{{- end}}
{{- end}}
{{- if .HasCreatedAt}}
		CreatedAt: time.Now(),
{{- end}}
{{- if .HasUpdatedAt}}
		UpdatedAt: time.Now(),
{{- end}}
{{- range .Fields}}
{{- if not .IsAutoManaged}}
		{{.Name}}: built.{{.Name}},
{{- end}}
{{- end}}
	}

	if err := exec.NewInsert().Model(&entity).Returning("*").Scan(ctx); err != nil {
		return models.{{.EntityName}}{}, err
	}

	return entity, nil
}

// Create{{.ModelName}}s creates multiple {{.ModelName}} records at once
func Create{{.ModelName}}s(ctx context.Context, exec storage.Executor, {{range .ForeignKeyFields}}{{.ArgumentName}} {{.Type}}, {{end}}count int, opts ...{{.ModelName}}Option) ([]models.{{.EntityName}}, error) {
	{{.ModelName | toLower}}s := make([]models.{{.EntityName}}, 0, count)

	for i := 0; i < count; i++ {
		entity, err := Create{{.ModelName}}(ctx, exec, {{range .ForeignKeyFields}}{{.ArgumentName}}, {{end}}opts...)
		if err != nil {
			return nil, fmt.Errorf("failed to create {{.ModelName | toLower}} %d: %w", i+1, err)
		}
		{{.ModelName | toLower}}s = append({{.ModelName | toLower}}s, entity)
	}

	return {{.ModelName | toLower}}s, nil
}
{{end}}

// Option functions
{{- range .Fields}}
{{- if not .IsAutoManaged}}

// {{.OptionName}} sets the {{.Name}} field
func {{.OptionName}}(value {{.Type}}) {{$.ModelName}}Option {
	return func(f *{{$.ModelName}}Factory) {
		f.{{$.EntityName}}.{{.Name}} = value
	}
}
{{- end}}
{{- end}}
