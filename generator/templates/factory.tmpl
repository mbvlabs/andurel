package factories

import (
	"context"
	"fmt"
{{- range .StandardImports}}
	"{{.}}"
{{- end}}

	"{{.ModulePath}}/models"
{{- range .ExternalImports}}
	"{{.}}"
{{- end}}

	"github.com/uptrace/bun"
)

// {{.ModelName}}Factory wraps models.{{.EntityName}} for testing
type {{.ModelName}}Factory struct {
	models.{{.EntityName}}  // Embedded
}

type {{.ModelName}}Option func(*{{.ModelName}}Factory)

// Build{{.ModelName}} creates an in-memory {{.ModelName}} with default test values
func Build{{.ModelName}}({{- range .Fields}}{{- if .IsFK}}{{.ArgumentName}} {{.Type}}, {{end}}{{end}}opts ...{{.ModelName}}Option) models.{{.EntityName}} {
	f := &{{.ModelName}}Factory{
		{{.EntityName}}: models.{{.EntityName}}{
{{- range .Fields}}
{{- if .IsID}}
{{- if or (not $.IDType) (eq $.IDType "uuid.UUID")}}
			{{.Name}}: uuid.New(),
{{- else if or (eq $.IDType "int32") (eq $.IDType "int64")}}
			{{.Name}}: 0, // Will be assigned by database or test setup
{{- else if eq $.IDType "string"}}
			{{.Name}}: faker.UUIDHyphenated(),
{{- end}}
{{- else if .IsTimestamp}}
{{- if eq .Name "CreatedAt"}}
			{{.Name}}: time.Now(),
{{- else if eq .Name "UpdatedAt"}}
			{{.Name}}: time.Now(),
{{- else}}
			{{.Name}}: {{.GoZero}},  // Optional timestamp - zero by default
{{- end}}
{{- else if .IsFK}}
			{{.Name}}: {{.ArgumentName}},  // Foreign key - required parameter
{{- else}}
			{{.Name}}: {{.DefaultValue}},
{{- end}}
{{- end}}
		},
	}

	for _, opt := range opts {
		opt(f)
	}

	return f.{{.EntityName}}
}

{{if .HasCreateFunction}}
// Create{{.ModelName}} creates and persists a {{.ModelName}} to the database
func Create{{.ModelName}}(ctx context.Context, db bun.IDB, {{- range .Fields}}{{- if .IsFK}}{{.ArgumentName}} {{.Type}}, {{end}}{{end}}opts ...{{.ModelName}}Option) (models.{{.EntityName}}, error) {
	// Build with defaults and required FKs
	built := Build{{.ModelName}}({{- range .Fields}}{{- if .IsFK}}{{.ArgumentName}}, {{end}}{{end}}opts...)

	// Prepare creation data
	data := models.Create{{.ModelName}}Data{
{{- range .Fields}}
{{- if not .IsAutoManaged}}
		{{.Name}}: built.{{.Name}},
{{- end}}
{{- end}}
{{- if not $.IsAutoIncrementID}}
{{- if and $.IDType (ne $.IDType "uuid.UUID")}}
		ID: built.ID,
{{- end}}
{{- end}}
	}

	// Use model's Create function via namespace
	entity, err := models.{{.NamespaceVar}}.Create(ctx, db, data)
	if err != nil {
		return models.{{.EntityName}}{}, err
	}

	return entity, nil
}

// Create{{.ModelName}}s creates multiple {{.ModelName}} records at once
func Create{{.ModelName}}s(ctx context.Context, db bun.IDB, {{range .ForeignKeyFields}}{{.ArgumentName}} {{.Type}}, {{end}}count int, opts ...{{.ModelName}}Option) ([]models.{{.EntityName}}, error) {
	{{.ModelName | toLower}}s := make([]models.{{.EntityName}}, 0, count)

	for i := 0; i < count; i++ {
		entity, err := Create{{.ModelName}}(ctx, db, {{range .ForeignKeyFields}}{{.ArgumentName}}, {{end}}opts...)
		if err != nil {
			return nil, fmt.Errorf("failed to create {{.ModelName | toLower}} %d: %w", i+1, err)
		}
		{{.ModelName | toLower}}s = append({{.ModelName | toLower}}s, entity)
	}

	return {{.ModelName | toLower}}s, nil
}
{{end}}

// Option functions
{{- range .Fields}}
{{- if not .IsAutoManaged}}

// {{.OptionName}} sets the {{.Name}} field
func {{.OptionName}}(value {{.Type}}) {{$.ModelName}}Option {
	return func(f *{{$.ModelName}}Factory) {
		f.{{$.EntityName}}.{{.Name}} = value
	}
}
{{- end}}
{{- end}}
