{{$indexRecv := printf "%s%s" .ResourceName "Index" | ToReceiverName}}
{{$showRecv := printf "%s%s" .ResourceName "Show" | ToReceiverName}}
{{$newRecv := printf "%s%s" .ResourceName "New" | ToReceiverName}}
{{$editRecv := printf "%s%s" .ResourceName "Edit" | ToReceiverName}}
package views

import (
	"fmt"
{{ViewDataImports .Fields}}	{{if UsesPackage .Fields "strings"}}"strings"
	{{end}}{{if or (and (HasAction "new") (HasAction "create")) (and (HasAction "edit") (or (HasAction "update") (HasAction "destroy")))}}	"net/http"
	{{end}}
	"{{.ModulePath}}/models"
	{{if or (and (HasAction "show") (HasAction "index")) (and (HasAction "new") (or (HasAction "create") (HasAction "index"))) (and (HasAction "edit") (or (HasAction "update") (HasAction "index") (HasAction "destroy")))}}"{{.ModulePath}}/internal/hypermedia"
	{{end}}
	{{if or (and (HasAction "index") (or (HasAction "new") (HasAction "show") (HasAction "edit"))) (and (HasAction "show") (or (HasAction "edit") (HasAction "index"))) (and (HasAction "new") (or (HasAction "create") (HasAction "index"))) (and (HasAction "edit") (or (HasAction "update") (HasAction "index") (HasAction "destroy")))}}
	"{{.ModulePath}}/router/routes"
	{{end}}
)
{{ViewData .}}
{{if HasAction "index"}}
type {{.NamespacePascal}}{{.ResourceName}}Index struct {
	Items []models.{{.EntityName}}
}

func ({{$indexRecv}} {{.NamespacePascal}}{{.ResourceName}}Index) PageFragment() string {
	return "{{.ResourceName | ToLower}}-index-page-fragment"
}

templ ({{$indexRecv}} {{.NamespacePascal}}{{.ResourceName}}Index) Page() {
	@base() {
		@templ.Fragment({{$indexRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-index-container">
				<section>
					<div>
						<div>
							<h1>{{Plural .ResourceName}}</h1>
						</div>
						{{if HasAction "new"}}
						<a href={ routes.{{.NamespacePascal}}{{.ResourceName}}New.URL() }>New {{.ResourceName}}</a>
						{{end}}
					</div>
					if len({{$indexRecv}}.Items) == 0 {
						<section>
							<div>
								<h2>No {{.PluralName}} found</h2>
							</div>
							{{if HasAction "new"}}
							<div>
								<a href={ routes.{{.NamespacePascal}}{{.ResourceName}}New.URL() }>New {{.ResourceName}}</a>
							</div>
							{{end}}
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										{{range .Fields}}<th>{{.DisplayName}}</th>
										{{end}}<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, {{.ResourceName | ToLower}} := range {{$indexRecv}}.Items {{ViewDataLoop .ResourceName (.ResourceName | ToLower) (HasNullFields .Fields)}}
										<tr>
											{{range .Fields}}<td>{{StringTableDisplay . (ViewDataRowRef ($.ResourceName | ToLower) (HasNullFields $.Fields))}}</td>
											{{end}}<td>
												<div>
													{{if HasAction "show"}}
													<a href={ routes.{{.NamespacePascal}}{{.ResourceName}}Show.URL({{.ResourceName | ToLower}}.ID) }>View</a>
													{{end}}
													{{if HasAction "edit"}}
													<a href={ routes.{{.NamespacePascal}}{{.ResourceName}}Edit.URL({{.ResourceName | ToLower}}.ID) }>Edit</a>
													{{end}}
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}
{{end}}

{{if HasAction "show"}}
type {{.NamespacePascal}}{{.ResourceName}}Show struct {
	Item models.{{.EntityName}}
}

func ({{$showRecv}} {{.NamespacePascal}}{{.ResourceName}}Show) PageFragment() string {
	return "{{.ResourceName | ToLower}}-show-page-fragment"
}

templ ({{$showRecv}} {{.NamespacePascal}}{{.ResourceName}}Show) Page() {
	@base() {
		@templ.Fragment({{$showRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-show-container">
				<section>
					<div>
						<div>
							<h1>{{.ResourceName}} Details</h1>
						</div>
						<div>
							{{if HasAction "edit"}}
							<a href={ routes.{{.NamespacePascal}}{{.ResourceName}}Edit.URL({{$showRecv}}.Item.ID) }>Edit</a>
							{{end}}
							{{if HasAction "index"}}
							<a href={ hypermedia.ResolveBackURL(ctx, routes.{{.NamespacePascal}}{{.ResourceName}}Index.URL()) }>Back to List</a>
							{{end}}
						</div>
					</div>
					<div>
						<div>
							{{$itemRef := printf "%s.%s" $showRecv "Item"}}{{$itemDisplayRef := ViewDataRef .ResourceName $itemRef (HasNullFields .Fields)}}
							{{range .Fields}}<div>
								<p>{{.DisplayName}}</p>
								<p>{{StringDisplay . $itemDisplayRef}}</p>
							</div>
							{{end}}
						</div>
					</div>
				</section>
			</main>
		}
	}
}
{{end}}

{{if HasAction "new"}}
type {{.NamespacePascal}}{{.ResourceName}}New struct{}

func ({{$newRecv}} {{.NamespacePascal}}{{.ResourceName}}New) PageFragment() string {
	return "{{.ResourceName | ToLower}}-new-page-fragment"
}

templ ({{$newRecv}} {{.NamespacePascal}}{{.ResourceName}}New) Page() {
	@base() {
		@templ.Fragment({{$newRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-new-container">
				<section>
					<div>
						<div>
							<h1>New {{.ResourceName}}</h1>
							<p>Enter the details for the new {{.ResourceName | ToLower}}.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								{{if HasAction "create"}}
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.{{.NamespacePascal}}{{.ResourceName}}Create.URL()) }
								{{end}}
							>
								<fieldset data-attr:disabled="$_submitting">
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div>
										<input type="checkbox" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}"/>
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div>
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div>
											<input type="{{.InputType}}" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}"/>
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div>
										{{if HasAction "create"}}
										<button type="submit">Create {{.ResourceName}}</button>
										{{end}}
										{{if HasAction "index"}}
										<a href={ hypermedia.ResolveBackURL(ctx, routes.{{.NamespacePascal}}{{.ResourceName}}Index.URL()) }>Back to List</a>
										{{end}}
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}
{{end}}

{{if HasAction "edit"}}
type {{.NamespacePascal}}{{.ResourceName}}Edit struct {
	Item models.{{.EntityName}}
}

func ({{$editRecv}} {{.NamespacePascal}}{{.ResourceName}}Edit) PageFragment() string {
	return "{{.ResourceName | ToLower}}-edit-page-fragment"
}

templ ({{$editRecv}} {{.NamespacePascal}}{{.ResourceName}}Edit) Page() {
	@base() {
		@templ.Fragment({{$editRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit {{.ResourceName}}</h1>
							<p>Update the details for this {{.ResourceName | ToLower}}.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								{{if HasAction "update"}}
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.{{.NamespacePascal}}{{.ResourceName}}Update.URL({{$editRecv}}.Item.ID)) }
								{{end}}
							>
								<fieldset data-attr:disabled="$_submitting">
									{{$itemRef := printf "%s.%s" $editRecv "Item"}}{{$itemDisplayRef := ViewDataRef .ResourceName $itemRef (HasNullFields .Fields)}}
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div>
										<input type="checkbox" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}" if {{FieldRef . $itemDisplayRef}} { checked } />
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div>
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div>
											<input type="{{.InputType}}" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}" value={ {{StringValue . $itemDisplayRef}} } />
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div>
										{{if HasAction "update"}}
										<button type="submit">Update {{.ResourceName}}</button>
										{{end}}
										{{if HasAction "index"}}
										<a href={ hypermedia.ResolveBackURL(ctx, routes.{{.NamespacePascal}}{{.ResourceName}}Index.URL()) }>Back to List</a>
										{{end}}
									</div>
								</fieldset>
							</form>
						</div>
						{{if HasAction "destroy"}}<div>
							<button
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.{{.NamespacePascal}}{{.ResourceName}}Destroy.URL({{$editRecv}}.Item.ID)) }
							>Destroy {{.ResourceName}}</button>
						</div>
						{{end}}
					</div>
				</section>
			</main>
		}
	}
}
{{end}}
