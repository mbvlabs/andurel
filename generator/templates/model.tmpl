type Paginated{{.PluralName}} struct {
	{{.PluralName}} []{{.EntityName}}
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func ({{.ReceiverName}} {{.NamespaceType}}) Paginate(ctx context.Context, db bun.IDB, page, pageSize int64) (Paginated{{.PluralName}}, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	countQuery := db.NewSelect().
		Model((*{{.EntityName}})(nil)).
		Where("deleted_at IS NULL")
	totalCount, err := countQuery.Count(ctx)
	if err != nil {
		return Paginated{{.PluralName}}{}, err
	}

	var entities []{{.EntityName}}
	err = db.NewSelect().
		Model(&entities).
		Where("deleted_at IS NULL").
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx)
	if err != nil {
		return Paginated{{.PluralName}}{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return Paginated{{.PluralName}}{
		{{.PluralName}}:    entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

