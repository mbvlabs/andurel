	}

	entity := {{.EntityName}}{
{{- if not .IsAutoIncrementID}}
{{- if or (not .IDType) (eq .IDType "uuid.UUID")}}
		ID: uuid.New(),
{{- else}}
		ID: data.ID,
{{- end}}
{{- end}}
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
{{- range .Fields}}
{{- if and (ne .Name "ID") (ne .Name "CreatedAt") (ne .Name "UpdatedAt")}}
		{{.Name}}: data.{{.Name}},
{{- end}}
{{- end}}
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return {{.EntityName}}{}, err
	}
	return entity, nil
}
