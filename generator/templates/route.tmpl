package routes

import (
	"{{.ModulePath}}/internal/routing"
)

const {{.NamespacePascal}}{{.ResourceName}}Prefix = "/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName | kebab}}"

{{- if HasAction "index" }}
var {{.NamespacePascal}}{{.ResourceName}}Index = routing.NewSimpleRoute(
	"",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.index",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "show" }}
var {{.NamespacePascal}}{{.ResourceName}}Show = routing.{{if eq .IDType "int32"}}NewRouteWithSerialID{{else if eq .IDType "int64"}}NewRouteWithBigSerialID{{else if eq .IDType "string"}}NewRouteWithStringID{{else}}NewRouteWithUUIDID{{end}}(
	"/:id",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.show",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "new" }}
var {{.NamespacePascal}}{{.ResourceName}}New = routing.NewSimpleRoute(
	"/new",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.new",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "create" }}
var {{.NamespacePascal}}{{.ResourceName}}Create = routing.NewSimpleRoute(
	"",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.create",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "edit" }}
var {{.NamespacePascal}}{{.ResourceName}}Edit = routing.{{if eq .IDType "int32"}}NewRouteWithSerialID{{else if eq .IDType "int64"}}NewRouteWithBigSerialID{{else if eq .IDType "string"}}NewRouteWithStringID{{else}}NewRouteWithUUIDID{{end}}(
	"/:id/edit",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.edit",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "update" }}
var {{.NamespacePascal}}{{.ResourceName}}Update = routing.{{if eq .IDType "int32"}}NewRouteWithSerialID{{else if eq .IDType "int64"}}NewRouteWithBigSerialID{{else if eq .IDType "string"}}NewRouteWithStringID{{else}}NewRouteWithUUIDID{{end}}(
	"/:id",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.update",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- if HasAction "destroy" }}
var {{.NamespacePascal}}{{.ResourceName}}Destroy = routing.{{if eq .IDType "int32"}}NewRouteWithSerialID{{else if eq .IDType "int64"}}NewRouteWithBigSerialID{{else if eq .IDType "string"}}NewRouteWithStringID{{else}}NewRouteWithUUIDID{{end}}(
	"/:id",
	"{{if .Namespace}}{{.Namespace}}.{{end}}{{.PluralName}}.destroy",
	{{.NamespacePascal}}{{.ResourceName}}Prefix,
)
{{- end }}

{{- range .CustomActions }}
var {{$.NamespacePascal}}{{$.ResourceName}}{{.MethodName}} = routing.NewSimpleRoute(
	"/{{.Path}}",
	"{{if $.Namespace}}{{$.Namespace}}.{{end}}{{$.PluralName}}.{{.RouteName}}",
	{{$.NamespacePascal}}{{$.ResourceName}}Prefix,
)
{{- end }}
