		Method:  http.MethodGet,
		Path:    routes.{{.NamespacePascal}}{{.ResourceName}}Show.Path(),
		Name:    routes.{{.NamespacePascal}}{{.ResourceName}}Show.Name(),
		Handler: {{.ReceiverName}}.Show,
	})
	if err != nil {
