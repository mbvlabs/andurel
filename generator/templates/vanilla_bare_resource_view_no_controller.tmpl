{{$indexRecv := printf "%s%s" .ResourceName "Index" | ToReceiverName}}
{{$showRecv := printf "%s%s" .ResourceName "Show" | ToReceiverName}}
{{$newRecv := printf "%s%s" .ResourceName "New" | ToReceiverName}}
{{$editRecv := printf "%s%s" .ResourceName "Edit" | ToReceiverName}}
package views

import (
	"fmt"
{{ViewDataImports .Fields}}	{{if UsesPackage .Fields "strings"}}"strings"
	{{end}}	"{{.ModulePath}}/internal/hypermedia"
	"{{.ModulePath}}/models"
)
{{ViewData .}}
type {{.NamespacePascal}}{{.ResourceName}}Index struct {
	Items []models.{{.EntityName}}
}

func ({{$indexRecv}} {{.NamespacePascal}}{{.ResourceName}}Index) PageFragment() string {
	return "{{.ResourceName | ToLower}}-index-page-fragment"
}

templ ({{$indexRecv}} {{.NamespacePascal}}{{.ResourceName}}Index) Page() {
	@base() {
		@templ.Fragment({{$indexRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-index-container">
				<section>
					<div>
						<div>
							<h1>{{Plural .ResourceName}}</h1>
						</div>
					</div>
					if len({{$indexRecv}}.Items) == 0 {
						<section>
							<div>
								<h2>No {{.PluralName}} found</h2>
							</div>
							<div>
								<a href="/">New {{.ResourceName}}</a>
							</div>
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										{{range .Fields}}<th>{{.DisplayName}}</th>
										{{end}}<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, {{.ResourceName | ToLower}} := range {{$indexRecv}}.Items {{ViewDataLoop $.NamespacePascal .ResourceName (.ResourceName | ToLower) (HasNullFields .Fields)}}
										<tr>
											{{range .Fields}}<td>{{StringTableDisplay . (ViewDataRowRef $.NamespacePascal $.ResourceName ($.ResourceName | ToLower) (HasNullFields $.Fields))}}</td>
											{{end}}
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}

type {{.NamespacePascal}}{{.ResourceName}}Show struct {
	Item models.{{.EntityName}}
}

func ({{$showRecv}} {{.NamespacePascal}}{{.ResourceName}}Show) PageFragment() string {
	return "{{.ResourceName | ToLower}}-show-page-fragment"
}

templ ({{$showRecv}} {{.NamespacePascal}}{{.ResourceName}}Show) Page() {
	@base() {
		@templ.Fragment({{$showRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-show-container">
				<section>
					<div>
						<div>
							<h1>{{.ResourceName}} Details</h1>
						</div>
						<div>
							<a href="/">Back to List</a>
						</div>
					</div>
					<div>
						<div>
							{{$itemRef := printf "%s.%s" $showRecv "Item"}}{{$itemDisplayRef := ViewDataRef $.NamespacePascal .ResourceName $itemRef (HasNullFields .Fields)}}
							{{range .Fields}}<div>
								<p>{{.DisplayName}}</p>
								<p>{{StringDisplay . $itemDisplayRef}}</p>
							</div>
							{{end}}
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type {{.NamespacePascal}}{{.ResourceName}}New struct{}

func ({{$newRecv}} {{.NamespacePascal}}{{.ResourceName}}New) PageFragment() string {
	return "{{.ResourceName | ToLower}}-new-page-fragment"
}

templ ({{$newRecv}} {{.NamespacePascal}}{{.ResourceName}}New) Page() {
	@base() {
		@templ.Fragment({{$newRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-new-container">
				<section>
					<div>
						<div>
							<h1>New {{.ResourceName}}</h1>
							<p>Enter the details for the new {{.ResourceName | ToLower}}.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ fmt.Sprintf("@post('%s')", "/") }
							>
								<fieldset data-attr:disabled="$_submitting">
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div>
										<input type="checkbox" id="{{.CamelCase}}" data-bind="{{.CamelCase}}" />
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div>
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div>
											<input type="{{.InputType}}" id="{{.CamelCase}}" data-bind="{{.CamelCase}}" />
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div>
										<button type="submit">Create {{.ResourceName}}</button>
										<a href="/">Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type {{.NamespacePascal}}{{.ResourceName}}Edit struct {
	Item models.{{.EntityName}}
}

func ({{$editRecv}} {{.NamespacePascal}}{{.ResourceName}}Edit) PageFragment() string {
	return "{{.ResourceName | ToLower}}-edit-page-fragment"
}

templ ({{$editRecv}} {{.NamespacePascal}}{{.ResourceName}}Edit) Page() {
	@base() {
		@templ.Fragment({{$editRecv}}.PageFragment()) {
			<main id="{{.ResourceName | ToLower}}-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit {{.ResourceName}}</h1>
							<p>Update the details for this {{.ResourceName | ToLower}}.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ fmt.Sprintf("@put('%s')", "/") }
							>
								<fieldset data-attr:disabled="$_submitting">
									{{$itemRef := printf "%s.%s" $editRecv "Item"}}{{$itemDisplayRef := ViewDataRef $.NamespacePascal .ResourceName $itemRef (HasNullFields .Fields)}}
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div>
										<input type="checkbox" id="{{.CamelCase}}" data-bind="{{.CamelCase}}" if {{FieldRef . $itemDisplayRef}} { checked } />
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div>
										<label for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div>
											<input type="{{.InputType}}" id="{{.CamelCase}}" data-bind="{{.CamelCase}}" value={ {{StringValue . $itemDisplayRef}} } />
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div>
										<button type="submit">Update {{.ResourceName}}</button>
										<a href="/">Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
						<div>
							<button
								type="button"
								data-on:click={ fmt.Sprintf("@delete('%s')", "/") }
							>Destroy {{.ResourceName}}</button>
						</div>
					</div>
				</section>
			</main>
		}
	}
}