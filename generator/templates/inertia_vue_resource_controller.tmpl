func ({{.ReceiverName}} {{.PluralResourceName}}) Index(etx *echo.Context) error {
	page := int64(1)
	if p := etx.QueryParam("page"); p != "" {
		if parsed, err := strconv.Atoi(p); err == nil && parsed > 0 {
			page = int64(parsed)
		}
	}

	perPage := int64(25)
	if pp := etx.QueryParam("per_page"); pp != "" {
		if parsed, err := strconv.Atoi(pp); err == nil && parsed > 0 &&
			parsed <= 100 {
			perPage = int64(parsed)
		}
	}

	{{.PluralName | ToCamelCase}}List, err := models.{{.ResourceName}}.Paginate(
		etx.Request().Context(),
		{{.ReceiverName}}.db.Executor(),
		page,
		perPage,
	)
	if err != nil {
		return inertia.Page(etx, "Errors/InternalError", inertia.Props{})
	}

	return inertia.Page(etx, "{{.ResourceName}}/Index", inertia.Props{
		"items": {{.PluralName | ToCamelCase}}List.{{.PluralResourceName}},
	})
}

