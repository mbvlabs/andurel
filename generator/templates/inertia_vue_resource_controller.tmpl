					etx.Request().Context(),
					"could not parse {{.Name}}, setting to nil UUID pointer",
					"error",
					err,
				)
				return nil
			}

			return &parsed
		}(),
		{{- else if eq .GoType "uuid.UUID"}}
		{{.Name}}:    func() uuid.UUID {
			if payload.{{.Name}} == "" {
				return uuid.Nil
			}
			parsed, err := uuid.Parse(payload.{{.Name}})
			if err != nil {
				slog.WarnContext(
					etx.Request().Context(),
