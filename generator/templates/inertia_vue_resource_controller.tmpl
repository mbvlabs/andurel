	{{- else}}
	_ = {{.ResourceName | ToLowerCamelCase}}
	{{- if HasAction "index"}}
	return inertia.Redirect(etx, routes.{{.NamespacePascal}}{{.ResourceName}}Index.URL())
	{{- else}}
	return etx.NoContent(201)
	{{- end}}
	{{- end}}
}

