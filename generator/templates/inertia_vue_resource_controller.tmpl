		{{.Name}}:    func() *time.Time {
			if payload.{{.Name}} == "" {
				return nil
			}
			if t, err := time.Parse("2006-01-02", payload.{{.Name}}); err == nil {
				return &t
			}
			return nil
		}(),
		{{- else if eq .GoType "sql.NullTime"}}
		{{.Name}}:    func() sql.NullTime {
			if payload.{{.Name}} == "" {
				return sql.NullTime{Valid: false}
			}
			if t, err := time.Parse("2006-01-02", payload.{{.Name}}); err == nil {
				return sql.NullTime{Time: t, Valid: true}
			}
			return sql.NullTime{Valid: false}
		}(),
		{{- else if eq .GoType "bun.NullTime"}}
