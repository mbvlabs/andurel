	return inertia.Page(etx, "{{if .Namespace}}{{.NamespacePascal}}/{{end}}{{.ResourceName}}/Show", inertia.Props{
		"item": new{{.ResourceName}}Data({{.ResourceName | ToLowerCamelCase}}),
