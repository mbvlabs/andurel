{{$indexRecv := printf "%s%s" .ResourceName "Index" | ToReceiverName}}
{{$showRecv := printf "%s%s" .ResourceName "Show" | ToReceiverName}}
{{$newRecv := printf "%s%s" .ResourceName "New" | ToReceiverName}}
{{$editRecv := printf "%s%s" .ResourceName "Edit" | ToReceiverName}}
package views

import (
	"fmt"
	{{if UsesPackage .Fields "strings"}}"strings"
	{{end}}	"net/http"
	"{{.ModulePath}}/internal/renderer"
	"{{.ModulePath}}/models"
	"{{.ModulePath}}/router/routes"
	"{{.ModulePath}}/internal/hypermedia"
)

type {{.ResourceName}}Index struct {
	Items []models.{{.EntityName}}
}

func ({{$indexRecv}} {{.ResourceName}}Index) ContainerFragment() string {
	return "{{.ResourceName | ToLower}}-index-container-fragment"
}

templ ({{$indexRecv}} {{.ResourceName}}Index) Page() {
	@base() {
		@templ.Fragment({{$indexRecv}}.ContainerFragment()) {
			<main id="{{.ResourceName | ToLower}}-index-container" class="page-shell">
				<section class="container stack" data-gap="lg">
					<div class="cluster" data-justify="between">
						<div class="stack" data-gap="sm">
							<h1>{{Plural .ResourceName}}</h1>
							<p class="muted">Manage your {{.PluralName}} with the shared vanilla component system.</p>
						</div>
						<a class="btn btn-primary" href={ routes.{{.ResourceName}}New.URL() }>New {{.ResourceName}}</a>
					</div>
					if len({{$indexRecv}}.Items) == 0 {
						<section class="panel empty-state">
							<div class="stack text-center" data-gap="sm">
								<h2 class="empty-state-title">No {{.PluralName}} found</h2>
								<p class="empty-state-description">Create your first {{.ResourceName | ToLower}} to start filling this view.</p>
							</div>
							<div class="empty-state-actions">
								<a class="btn btn-primary" href={ routes.{{.ResourceName}}New.URL() }>New {{.ResourceName}}</a>
							</div>
						</section>
					} else {
						<div class="panel table-wrap">
							<table class="table">
								<thead>
									<tr>
										{{range .Fields}}<th>{{.DisplayName}}</th>
										{{end}}<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, {{.ResourceName | ToLower}} := range {{$indexRecv}}.Items {
										<tr>
											{{range .Fields}}<td>{{StringTableDisplay . ($.ResourceName | ToLower)}}</td>
											{{end}}<td>
												<div class="cluster" data-gap="sm">
													<a class="btn btn-ghost btn-sm" href={ routes.{{.ResourceName}}Show.URL({{.ResourceName | ToLower}}.ID) }>View</a>
													<a class="btn btn-outline btn-sm" href={ routes.{{.ResourceName}}Edit.URL({{.ResourceName | ToLower}}.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}

type {{.ResourceName}}Show struct {
	Item models.{{.EntityName}}
}

func ({{$showRecv}} {{.ResourceName}}Show) ContainerFragment() string {
	return "{{.ResourceName | ToLower}}-show-container-fragment"
}

templ ({{$showRecv}} {{.ResourceName}}Show) Page() {
	@base() {
		@templ.Fragment({{$showRecv}}.ContainerFragment()) {
			<main id="{{.ResourceName | ToLower}}-show-container" class="page-shell">
				<section class="container stack" data-gap="lg">
					<div class="cluster" data-justify="between">
						<div class="stack" data-gap="sm">
							<h1>{{.ResourceName}} Details</h1>
							<p class="muted">Review the current values stored for this {{.ResourceName | ToLower}}.</p>
						</div>
						<div class="cluster" data-gap="sm">
							<a class="btn btn-primary" href={ routes.{{.ResourceName}}Edit.URL({{$showRecv}}.Item.ID) }>Edit</a>
							<a class="btn btn-outline" href={ renderer.ResolveBackURL(ctx, routes.{{.ResourceName}}Index.URL()) }>Back to List</a>
						</div>
					</div>
					<div class="panel">
						<div class="grid-auto-fit" data-grid="compact">
							{{$itemRef := printf "%s.%s" $showRecv "Item"}}
							{{range .Fields}}<div class="field">
								<p class="field-label">{{.DisplayName}}</p>
								<p>{{StringDisplay . $itemRef}}</p>
							</div>
							{{end}}
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type {{.ResourceName}}New struct{}

func ({{$newRecv}} {{.ResourceName}}New) ContainerFragment() string {
	return "{{.ResourceName | ToLower}}-new-container-fragment"
}

templ ({{$newRecv}} {{.ResourceName}}New) Page() {
	@base() {
		@templ.Fragment({{$newRecv}}.ContainerFragment()) {
			<main id="{{.ResourceName | ToLower}}-new-container" class="auth-shell">
				<section class="center">
					<div class="card">
						<div class="card-header">
							<h1 class="card-title">New {{.ResourceName}}</h1>
							<p class="card-description">Enter the details for the new {{.ResourceName | ToLower}}.</p>
						</div>
						<div class="card-content">
							<form
								class="form"
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.{{.ResourceName}}Create.URL()) }
							>
								<fieldset class="fieldset" data-attr:disabled="$_submitting">
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div class="radio-row">
										<input class="checkbox" type="checkbox" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}"/>
										<label class="label" for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div class="field">
										<label class="field-label" for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div class="field-control">
											<input class="input" type="{{.InputType}}" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}"/>
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div class="stack" data-gap="sm">
										<button class="btn btn-primary btn-block" type="submit">Create {{.ResourceName}}</button>
										<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.{{.ResourceName}}Index.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type {{.ResourceName}}Edit struct {
	Item models.{{.EntityName}}
}

func ({{$editRecv}} {{.ResourceName}}Edit) ContainerFragment() string {
	return "{{.ResourceName | ToLower}}-edit-container-fragment"
}

templ ({{$editRecv}} {{.ResourceName}}Edit) Page() {
	@base() {
		@templ.Fragment({{$editRecv}}.ContainerFragment()) {
			<main id="{{.ResourceName | ToLower}}-edit-container" class="auth-shell">
				<section class="center">
					<div class="card">
						<div class="card-header">
							<h1 class="card-title">Edit {{.ResourceName}}</h1>
							<p class="card-description">Update the details for this {{.ResourceName | ToLower}}.</p>
						</div>
						<div class="card-content">
							<form
								class="form"
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.{{.ResourceName}}Update.URL({{$editRecv}}.Item.ID)) }
							>
								<fieldset class="fieldset" data-attr:disabled="$_submitting">
									{{$itemRef := printf "%s.%s" $editRecv "Item"}}
									{{range .Fields}}{{if not .IsSystemField}}{{if eq .InputType "checkbox"}}<div class="radio-row">
										<input class="checkbox" type="checkbox" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}" if {{FieldRef . $itemRef}} { checked }/>
										<label class="label" for="{{.CamelCase}}">{{.DisplayName}}</label>
									</div>
									{{else}}<div class="field">
										<label class="field-label" for="{{.CamelCase}}">{{.DisplayName}}</label>
										<div class="field-control">
											<input class="input" type="{{.InputType}}" id="{{.CamelCase}}" name="{{.CamelCase}}" data-bind="{{.CamelCase}}" value={ {{StringValue . $itemRef}} }/>
										</div>
									</div>
									{{end}}{{end}}{{end}}
									<div class="stack" data-gap="sm">
										<button class="btn btn-primary btn-block" type="submit">Update {{.ResourceName}}</button>
										<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.{{.ResourceName}}Index.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
						<div class="card-footer">
							<button
								class="btn btn-destructive btn-block"
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.{{.ResourceName}}Destroy.URL({{$editRecv}}.Item.ID)) }
							>Destroy {{.ResourceName}}</button>
						</div>
					</div>
				</section>
			</main>
		}
	}
}