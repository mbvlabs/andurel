import { Head, Link, useForm } from '@inertiajs/react'
import type { FormEvent } from 'react'

type Item = Record<string, any>

{{- if eq .ComponentName "Index"}}
type IndexProps = {
  items: Item[]
}

export default function {{.ComponentName}}({ items }: IndexProps) {
  return (
    <>
      <Head title="{{.ResourceName}}s" />

      <div className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div className="flex items-center justify-between">
          <h1 className="text-2xl font-bold text-gray-900">{{.ResourceName}}s</h1>
          <Link href="/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/new" className="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700">New {{.ResourceName}}</Link>
        </div>

        <div className="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <table className="min-w-full divide-y divide-gray-200">
            <thead className="bg-gray-50">
              <tr>
{{- range .Fields}}
                <th className="px-6 py-3 text-left text-xs font-medium uppercase text-gray-500">{{.DisplayName}}</th>
{{- end}}
                <th className="px-6 py-3 text-right text-xs font-medium uppercase text-gray-500">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-200 bg-white">
              {items.map((item) => (
                <tr key={item.{{.IDFieldName}}} className="hover:bg-gray-50">
{{- range .Fields}}
                  <td className="whitespace-nowrap px-6 py-4 text-sm text-gray-900">{item.{{.Name}}}</td>
{{- end}}
                  <td className="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                    <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}`} className="mr-3 text-blue-600 hover:text-blue-900">View</Link>
                    <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}/edit`} className="mr-3 text-indigo-600 hover:text-indigo-900">Edit</Link>
                    <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}`} method="delete" as="button" className="text-red-600 hover:text-red-900">Delete</Link>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </>
  )
}
{{- else if eq .ComponentName "Show"}}
type ShowProps = {
  item: Item
}

export default function {{.ComponentName}}({ item }: ShowProps) {
  return (
    <>
      <Head title="{{.ResourceName}}" />

      <div className="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
        <div className="flex items-center justify-between">
          <h1 className="text-2xl font-bold text-gray-900">{{.ResourceName}} Details</h1>
          <div className="flex gap-3">
            <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}/edit`} className="rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700">Edit</Link>
            <Link href="/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}" className="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Back</Link>
          </div>
        </div>

        <div className="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <dl className="divide-y divide-gray-200">
{{- range .Fields}}
            <div className="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt className="text-sm font-medium text-gray-500">{{.DisplayName}}</dt>
              <dd className="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">{item.{{.Name}}}</dd>
            </div>
{{- end}}
          </dl>
        </div>
      </div>
    </>
  )
}
{{- else if eq .ComponentName "Create"}}
export default function {{.ComponentName}}() {
  const form = useForm({
{{- range .Fields}}
{{- if not .IsSystemField}}
    {{.CamelCase}}: {{if eq .InputType "checkbox"}}false{{else}}''{{end}},
{{- end}}
{{- end}}
  })

  function submit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()
    form.post('/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}')
  }

  return (
    <>
      <Head title="{{.ResourceName}}" />

      <div className="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
        <div className="flex items-center justify-between">
          <h1 className="text-2xl font-bold text-gray-900">New {{.ResourceName}}</h1>
          <Link href="/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}" className="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Back</Link>
        </div>

        <form onSubmit={submit} className="mt-8 space-y-6 overflow-hidden rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
{{- range .Fields}}
{{- if not .IsSystemField}}
          <div>
            <label htmlFor="{{.CamelCase}}" className="block text-sm font-medium text-gray-700">{{.DisplayName}}</label>
{{- if eq .InputType "checkbox"}}
            <input id="{{.CamelCase}}" type="checkbox" checked={form.data.{{.CamelCase}} as boolean} onChange={(event) => form.setData('{{.CamelCase}}', event.target.checked)} className="mt-1 rounded border border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500" />
{{- else}}
            <input id="{{.CamelCase}}" type="{{.InputType}}" value={form.data.{{.CamelCase}} as string} onChange={(event) => form.setData('{{.CamelCase}}', event.target.value)} className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" />
{{- end}}
          </div>
{{- end}}
{{- end}}
          <div className="flex justify-end">
            <button type="submit" disabled={form.processing} className="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50">{form.processing ? 'Creating...' : 'Create {{.ResourceName}}'}</button>
          </div>
        </form>
      </div>
    </>
  )
}
{{- else if eq .ComponentName "Edit"}}
type EditProps = {
  item: Item
}

export default function {{.ComponentName}}({ item }: EditProps) {
  const form = useForm({
{{- range .Fields}}
{{- if not .IsSystemField}}
    {{.CamelCase}}: {{if eq .InputType "checkbox"}}Boolean(item.{{.Name}}){{else}}String(item.{{.Name}} ?? ''){{end}},
{{- end}}
{{- end}}
  })

  function submit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()
    form.put(`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}`)
  }

  return (
    <>
      <Head title="{{.ResourceName}}" />

      <div className="mx-auto max-w-3xl px-4 py-8 sm:px-6 lg:px-8">
        <div className="flex items-center justify-between">
          <h1 className="text-2xl font-bold text-gray-900">Edit {{.ResourceName}}</h1>
          <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}`} className="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</Link>
        </div>

        <form onSubmit={submit} className="mt-8 space-y-6 overflow-hidden rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
{{- range .Fields}}
{{- if not .IsSystemField}}
          <div>
            <label htmlFor="{{.CamelCase}}" className="block text-sm font-medium text-gray-700">{{.DisplayName}}</label>
{{- if eq .InputType "checkbox"}}
            <input id="{{.CamelCase}}" type="checkbox" checked={form.data.{{.CamelCase}} as boolean} onChange={(event) => form.setData('{{.CamelCase}}', event.target.checked)} className="mt-1 rounded border border-gray-300 text-blue-600 shadow-sm focus:ring-blue-500" />
{{- else}}
            <input id="{{.CamelCase}}" type="{{.InputType}}" value={form.data.{{.CamelCase}} as string} onChange={(event) => form.setData('{{.CamelCase}}', event.target.value)} className="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" />
{{- end}}
          </div>
{{- end}}
{{- end}}
          <div className="flex justify-end gap-3">
            <Link href={`/{{if .Namespace}}{{.Namespace}}/{{end}}{{.PluralName}}/${item.{{.IDFieldName}}}`} className="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Cancel</Link>
            <button type="submit" disabled={form.processing} className="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-50">{form.processing ? 'Updating...' : 'Update {{.ResourceName}}'}</button>
          </div>
        </form>
      </div>
    </>
  )
}
{{- end}}
