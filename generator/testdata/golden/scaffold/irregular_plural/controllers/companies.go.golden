package controllers

import (
	"database/sql"
	"errors"
	"fmt"
	"log/slog"
	"net/http"
	"strconv"
	"testapp/internal/hypermedia"
	"testapp/internal/storage"
	"testapp/models"
	"testapp/router"
	"testapp/router/cookies"
	"testapp/router/routes"
	"testapp/views"

	"github.com/google/uuid"
	"github.com/labstack/echo/v5"
)

type Companies struct {
	db storage.Pool
}

func NewCompanies(db storage.Pool) Companies {
	return Companies{db}
}

func (c Companies) RegisterRoutes(r *router.Router) error {
	var errs []error
	var err error
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.CompanyIndex.Path(),
		Name:    routes.CompanyIndex.Name(),
		Handler: c.Index,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.CompanyShow.Path(),
		Name:    routes.CompanyShow.Name(),
		Handler: c.Show,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.CompanyNew.Path(),
		Name:    routes.CompanyNew.Name(),
		Handler: c.New,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodPost,
		Path:    routes.CompanyCreate.Path(),
		Name:    routes.CompanyCreate.Name(),
		Handler: c.Create,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.CompanyEdit.Path(),
		Name:    routes.CompanyEdit.Name(),
		Handler: c.Edit,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodPut,
		Path:    routes.CompanyUpdate.Path(),
		Name:    routes.CompanyUpdate.Name(),
		Handler: c.Update,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodDelete,
		Path:    routes.CompanyDestroy.Path(),
		Name:    routes.CompanyDestroy.Name(),
		Handler: c.Destroy,
	})
	if err != nil {
		errs = append(errs, err)
	}

	return errors.Join(errs...)
}

func (c Companies) Index(etx *echo.Context) error {
	page := int64(1)
	if p := etx.QueryParam("page"); p != "" {
		if parsed, err := strconv.Atoi(p); err == nil && parsed > 0 {
			page = int64(parsed)
		}
	}

	perPage := int64(25)
	if pp := etx.QueryParam("per_page"); pp != "" {
		if parsed, err := strconv.Atoi(pp); err == nil && parsed > 0 &&
			parsed <= 100 {
			perPage = int64(parsed)
		}
	}

	companiesList, err := models.Company.Paginate(
		etx.Request().Context(),
		c.db.Executor(),
		page,
		perPage,
	)
	if err != nil {
		return hypermedia.RenderPage(etx, views.InternalError())
	}

	return hypermedia.RenderPage(etx, views.CompanyIndex{Items: companiesList.Companies}.Page())
}

func (c Companies) Show(etx *echo.Context) error {
	companyID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return hypermedia.RenderPage(etx, views.BadRequest())
	}

	company, err := models.Company.Find(etx.Request().Context(), c.db.Executor(), companyID)
	if err != nil {
		return hypermedia.RenderPage(etx, views.NotFound())
	}

	return hypermedia.RenderPage(etx, views.CompanyShow{Item: company}.Page())
}

func (c Companies) New(etx *echo.Context) error {
	return hypermedia.RenderPage(etx, views.CompanyNew{}.Page())
}

type CreateCompanyFormPayload struct {
	Name     string `json:"name"`
	Industry string `json:"industry"`
}

func (c Companies) Create(etx *echo.Context) error {
	var payload CreateCompanyFormPayload
	if err := etx.Bind(&payload); err != nil {
		slog.ErrorContext(
			etx.Request().Context(),
			"could not parse CreateCompanyFormPayload",
			"error",
			err,
		)

		return hypermedia.RenderPage(etx, views.NotFound())
	}

	data := models.CreateCompanyData{

		Name: payload.Name,

		Industry: sql.NullString{String: payload.Industry, Valid: true},
	}

	company, err := models.Company.Create(
		etx.Request().Context(),
		c.db.Executor(),
		data,
	)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to create company: %v", err)); flashErr != nil {
			return flashErr
		}
		return etx.Redirect(http.StatusSeeOther, routes.CompanyNew.URL())
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "Company created successfully"); flashErr != nil {
		return hypermedia.RenderPage(etx, views.InternalError())
	}
	return etx.Redirect(http.StatusSeeOther, routes.CompanyShow.URL(company.ID))
}

func (c Companies) Edit(etx *echo.Context) error {
	companyID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return hypermedia.RenderPage(etx, views.BadRequest())
	}

	company, err := models.Company.Find(etx.Request().Context(), c.db.Executor(), companyID)
	if err != nil {
		return hypermedia.RenderPage(etx, views.NotFound())
	}

	return hypermedia.RenderPage(etx, views.CompanyEdit{Item: company}.Page())
}

type UpdateCompanyFormPayload struct {
	Name     string `json:"name"`
	Industry string `json:"industry"`
}

func (c Companies) Update(etx *echo.Context) error {
	companyID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return hypermedia.RenderPage(etx, views.BadRequest())
	}

	var payload UpdateCompanyFormPayload
	if err := etx.Bind(&payload); err != nil {
		slog.ErrorContext(
			etx.Request().Context(),
			"could not parse UpdateCompanyFormPayload",
			"error",
			err,
		)

		return hypermedia.RenderPage(etx, views.NotFound())
	}

	data := models.UpdateCompanyData{
		ID: companyID,

		Name: payload.Name,

		Industry: sql.NullString{String: payload.Industry, Valid: true},
	}

	company, err := models.Company.Update(
		etx.Request().Context(),
		c.db.Executor(),
		data,
	)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to update company: %v", err)); flashErr != nil {
			return hypermedia.RenderPage(etx, views.InternalError())
		}
		return etx.Redirect(
			http.StatusSeeOther,
			routes.CompanyEdit.URL(companyID),
		)
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "Company updated successfully"); flashErr != nil {
		return hypermedia.RenderPage(etx, views.InternalError())
	}
	return etx.Redirect(http.StatusSeeOther, routes.CompanyShow.URL(company.ID))
}

func (c Companies) Destroy(etx *echo.Context) error {
	companyID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return hypermedia.RenderPage(etx, views.BadRequest())
	}

	err = models.Company.Destroy(etx.Request().Context(), c.db.Executor(), companyID)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to delete company: %v", err)); flashErr != nil {
			return hypermedia.RenderPage(etx, views.InternalError())
		}
		return etx.Redirect(http.StatusSeeOther, routes.CompanyIndex.URL())
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "Company destroyed successfully"); flashErr != nil {
		return hypermedia.RenderPage(etx, views.InternalError())
	}
	return etx.Redirect(http.StatusSeeOther, routes.CompanyIndex.URL())
}
