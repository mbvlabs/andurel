package main

import (
	"testapp/controllers"
	"testapp/router"
)

func setupControllers(db interface{}, r *router.Router) error {
	companies := controllers.NewCompanies(db)
	if err := r.RegisterCompanyRoutes(companies); err != nil {
		return err
	}

	// andurel:controller-registration-point
	return nil
}
