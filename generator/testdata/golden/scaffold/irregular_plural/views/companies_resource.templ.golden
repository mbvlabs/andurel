



package views

import (
	"fmt"
		"net/http"
	
	"testapp/models"
	"testapp/internal/hypermedia"
	
	
	"testapp/router/routes"
	
)


type CompanyIndex struct {
	Items []models.CompanyEntity
}

func (ci CompanyIndex) PageFragment() string {
	return "company-index-page-fragment"
}

templ (ci CompanyIndex) Page() {
	@base() {
		@templ.Fragment(ci.PageFragment()) {
			<main id="company-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Companies</h1>
						
						<a href={ routes.CompanyNew.URL() } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">New Company</a>
						
					</div>
					if len(ci.Items) == 0 {
						<p class="text-sm text-gray-500">No companies found.</p>
					} else {
						<div class="relative w-full overflow-auto">
							<table class="w-full caption-bottom text-sm">
								<thead class="[&_tr]:border-b [&_tr]:border-gray-300">
									<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Name</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Industry</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Created At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Updated At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Actions</th>
									</tr>
								</thead>
								<tbody class="[&_tr:last-child]:border-0">
									for _, company := range ci.Items {
										<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ company.Name }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ company.Industry }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ company.CreatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ company.UpdatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">
												<div class="flex flex-wrap gap-3 text-sm">
													
													<a class="text-gray-600 hover:text-gray-900" href={ routes.CompanyShow.URL(company.ID) }>View</a>
													
													
													<a class="text-gray-600 hover:text-gray-900" href={ routes.CompanyEdit.URL(company.ID) }>Edit</a>
													
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}



type CompanyShow struct {
	Item models.CompanyEntity
}

func (cs CompanyShow) PageFragment() string {
	return "company-show-page-fragment"
}

templ (cs CompanyShow) Page() {
	@base() {
		@templ.Fragment(cs.PageFragment()) {
			<main id="company-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Company Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							
							<a href={ routes.CompanyEdit.URL(cs.Item.ID) } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">Edit</a>
							
							
							<a class="text-sm text-gray-600 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.CompanyIndex.URL()) }>Back to List</a>
							
						</div>
					</div>
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="p-6 pt-0">
							<div class="grid gap-5 sm:grid-cols-2">
								
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Name</label>
									<p class="text-sm text-gray-900">{ cs.Item.Name }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Industry</label>
									<p class="text-sm text-gray-900">{ cs.Item.Industry }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Created At</label>
									<p class="text-sm text-gray-900">{ cs.Item.CreatedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Updated At</label>
									<p class="text-sm text-gray-900">{ cs.Item.UpdatedAt.String() }</p>
								</div>
								
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type CompanyNew struct{}

func (cn CompanyNew) PageFragment() string {
	return "company-new-page-fragment"
}

templ (cn CompanyNew) Page() {
	@base() {
		@templ.Fragment(cn.PageFragment()) {
			<main id="company-new-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">New Company</h3>
							<p class="text-sm text-gray-500">Enter the details for the new company.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.CompanyCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name" />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="industry">Industry</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="industry" />
										</div>
										
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Create Company</button>
										
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.CompanyIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type CompanyEdit struct {
	Item models.CompanyEntity
}

func (ce CompanyEdit) PageFragment() string {
	return "company-edit-page-fragment"
}

templ (ce CompanyEdit) Page() {
	@base() {
		@templ.Fragment(ce.PageFragment()) {
			<main id="company-edit-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">Edit Company</h3>
							<p class="text-sm text-gray-500">Update the details for this company.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.CompanyUpdate.URL(ce.Item.ID)) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name" value={ ce.Item.Name } />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="industry">Industry</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="industry" value={ ce.Item.Industry } />
										</div>
										
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Update Company</button>
										
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.CompanyIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
							<div role="separator" class="my-6 shrink-0 bg-gray-300 h-px w-full"></div>
							<button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-red-600 text-white shadow-sm hover:bg-red-700 h-9 px-4 py-2 text-sm rounded w-full" data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.CompanyDestroy.URL(ce.Item.ID)) }>Destroy Company</button>
							
						</div>
					</div>
				</div>
			</main>
		}
	}
}

