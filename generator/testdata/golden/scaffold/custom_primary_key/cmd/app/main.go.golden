package main

import (
	"testapp/controllers"
	"testapp/router"
)

func setupControllers(db interface{}, r *router.Router) error {
	warehouses := controllers.NewWarehouses(db)
	if err := r.RegisterWarehouseRoutes(warehouses); err != nil {
		return err
	}

	// andurel:controller-registration-point
	return nil
}
