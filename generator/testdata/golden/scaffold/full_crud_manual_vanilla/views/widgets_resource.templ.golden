



package views

import (
	"fmt"
		"net/http"
	
	"testapp/models"
	"testapp/internal/hypermedia"
	
	
	"testapp/router/routes"
	
)


type WidgetIndex struct {
	Items []models.WidgetEntity
}

func (wi WidgetIndex) PageFragment() string {
	return "widget-index-page-fragment"
}

templ (wi WidgetIndex) Page() {
	@base() {
		@templ.Fragment(wi.PageFragment()) {
			<main id="widget-index-container">
				<section>
					<div>
						<div>
							<h1>Widgets</h1>
						</div>
						
						<a href={ routes.WidgetNew.URL() }>New Widget</a>
						
					</div>
					if len(wi.Items) == 0 {
						<section>
							<div>
								<h2>No widgets found</h2>
							</div>
							
							<div>
								<a href={ routes.WidgetNew.URL() }>New Widget</a>
							</div>
							
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										<th>Name</th>
										<th>Quantity</th>
										<th>Active</th>
										<th>Created At</th>
										<th>Updated At</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, widget := range wi.Items {
										<tr>
											<td>{ widget.Name }</td>
											<td>{ fmt.Sprintf("%d", widget.Quantity) }</td>
											<td>{ fmt.Sprintf("%t", widget.Active) }</td>
											<td>{ widget.CreatedAt.String() }</td>
											<td>{ widget.UpdatedAt.String() }</td>
											<td>
												<div>
													
													<a href={ routes.WidgetShow.URL(widget.ID) }>View</a>
													
													
													<a href={ routes.WidgetEdit.URL(widget.ID) }>Edit</a>
													
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}



type WidgetShow struct {
	Item models.WidgetEntity
}

func (ws WidgetShow) PageFragment() string {
	return "widget-show-page-fragment"
}

templ (ws WidgetShow) Page() {
	@base() {
		@templ.Fragment(ws.PageFragment()) {
			<main id="widget-show-container">
				<section>
					<div>
						<div>
							<h1>Widget Details</h1>
						</div>
						<div>
							
							<a href={ routes.WidgetEdit.URL(ws.Item.ID) }>Edit</a>
							
							
							<a href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
							
						</div>
					</div>
					<div>
						<div>
							
							<div>
								<p>Name</p>
								<p>{ ws.Item.Name }</p>
							</div>
							<div>
								<p>Quantity</p>
								<p>{ fmt.Sprintf("%d", ws.Item.Quantity) }</p>
							</div>
							<div>
								<p>Active</p>
								<p>{ fmt.Sprintf("%t", ws.Item.Active) }</p>
							</div>
							<div>
								<p>Created At</p>
								<p>{ ws.Item.CreatedAt.String() }</p>
							</div>
							<div>
								<p>Updated At</p>
								<p>{ ws.Item.UpdatedAt.String() }</p>
							</div>
							
						</div>
					</div>
				</section>
			</main>
		}
	}
}



type WidgetNew struct{}

func (wn WidgetNew) PageFragment() string {
	return "widget-new-page-fragment"
}

templ (wn WidgetNew) Page() {
	@base() {
		@templ.Fragment(wn.PageFragment()) {
			<main id="widget-new-container">
				<section>
					<div>
						<div>
							<h1>New Widget</h1>
							<p>Enter the details for the new widget.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.WidgetCreate.URL()) }
								
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="name">Name</label>
										<div>
											<input type="text" id="name" name="name" data-bind="name"/>
										</div>
									</div>
									<div>
										<label for="quantity">Quantity</label>
										<div>
											<input type="number" id="quantity" name="quantity" data-bind="quantity"/>
										</div>
									</div>
									<div>
										<input type="checkbox" id="active" name="active" data-bind="active"/>
										<label for="active">Active</label>
									</div>
									
									<div>
										
										<button type="submit">Create Widget</button>
										
										
										<a href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}



type WidgetEdit struct {
	Item models.WidgetEntity
}

func (we WidgetEdit) PageFragment() string {
	return "widget-edit-page-fragment"
}

templ (we WidgetEdit) Page() {
	@base() {
		@templ.Fragment(we.PageFragment()) {
			<main id="widget-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit Widget</h1>
							<p>Update the details for this widget.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.WidgetUpdate.URL(we.Item.ID)) }
								
							>
								<fieldset data-attr:disabled="$_submitting">
									
									<div>
										<label for="name">Name</label>
										<div>
											<input type="text" id="name" name="name" data-bind="name" value={ we.Item.Name } />
										</div>
									</div>
									<div>
										<label for="quantity">Quantity</label>
										<div>
											<input type="number" id="quantity" name="quantity" data-bind="quantity" value={ fmt.Sprintf("%d", we.Item.Quantity) } />
										</div>
									</div>
									<div>
										<input type="checkbox" id="active" name="active" data-bind="active" if we.Item.Active { checked } />
										<label for="active">Active</label>
									</div>
									
									<div>
										
										<button type="submit">Update Widget</button>
										
										
										<a href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
						</div>
						<div>
							<button
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.WidgetDestroy.URL(we.Item.ID)) }
							>Destroy Widget</button>
						</div>
						
					</div>
				</section>
			</main>
		}
	}
}

