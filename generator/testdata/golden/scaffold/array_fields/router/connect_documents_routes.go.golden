package router

import (
	"errors"
	"net/http"

	"testapp/controllers"
	"testapp/router/routes"

	"github.com/labstack/echo"
)

func (r Router) RegisterDocumentRoutes(document controllers.Documents) error {
	errs := []error{}
	var err error
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DocumentIndex.Path(),
		Name:    routes.DocumentIndex.Name(),
		Handler: document.Index,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DocumentShow.Path(),
		Name:    routes.DocumentShow.Name(),
		Handler: document.Show,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DocumentNew.Path(),
		Name:    routes.DocumentNew.Name(),
		Handler: document.New,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodPost,
		Path:    routes.DocumentCreate.Path(),
		Name:    routes.DocumentCreate.Name(),
		Handler: document.Create,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DocumentEdit.Path(),
		Name:    routes.DocumentEdit.Name(),
		Handler: document.Edit,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodPut,
		Path:    routes.DocumentUpdate.Path(),
		Name:    routes.DocumentUpdate.Name(),
		Handler: document.Update,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodDelete,
		Path:    routes.DocumentDestroy.Path(),
		Name:    routes.DocumentDestroy.Name(),
		Handler: document.Destroy,
	})
	if err != nil {
		errs = append(errs, err)
	}

	return errors.Join(errs...)
}
