



package views

import (
	"fmt"
	"time"
		"net/http"
	
	"testapp/models"
	"testapp/internal/hypermedia"
	
	
	"testapp/router/routes"
	
)

type FeedbackEntryData struct {
	StudentName string
	Feedback string
	Rating int32
	SubmittedAt time.Time
	CreatedAt time.Time
	UpdatedAt time.Time
}

func newFeedbackEntryData(entity models.FeedbackEntryEntity) FeedbackEntryData {
	return FeedbackEntryData{
		StudentName: entity.StudentName,
		Feedback: entity.Feedback,
		Rating: func() int32 { if !entity.Rating.Valid { return 0 }; return entity.Rating.Int32 }(),
		SubmittedAt: func() time.Time { if !entity.SubmittedAt.Valid { return time.Time{} }; return entity.SubmittedAt.Time }(),
		CreatedAt: entity.CreatedAt,
		UpdatedAt: entity.UpdatedAt,
	}
}


type FeedbackEntryIndex struct {
	Items []models.FeedbackEntryEntity
}

func (fei FeedbackEntryIndex) PageFragment() string {
	return "feedbackentry-index-page-fragment"
}

templ (fei FeedbackEntryIndex) Page() {
	@base() {
		@templ.Fragment(fei.PageFragment()) {
			<main id="feedbackentry-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">FeedbackEntries</h1>
						
						<a href={ routes.FeedbackEntryNew.URL() } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">New FeedbackEntry</a>
						
					</div>
					if len(fei.Items) == 0 {
						<p class="text-sm text-gray-500">No feedback_entries found.</p>
					} else {
						<div class="relative w-full overflow-auto">
							<table class="w-full caption-bottom text-sm">
								<thead class="[&_tr]:border-b [&_tr]:border-gray-300">
									<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Student Name</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Feedback</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Rating</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Submitted At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Created At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Updated At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Actions</th>
									</tr>
								</thead>
								<tbody class="[&_tr:last-child]:border-0">
									for _, feedbackentry := range fei.Items {
									{{ feedbackentryData := newFeedbackEntryData(feedbackentry) }}
										<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ feedbackentryData.StudentName }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ feedbackentryData.Feedback }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ fmt.Sprintf("%d", feedbackentryData.Rating) }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ feedbackentryData.SubmittedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ feedbackentryData.CreatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ feedbackentryData.UpdatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">
												<div class="flex flex-wrap gap-3 text-sm">
													
													<a class="text-gray-600 hover:text-gray-900" href={ routes.FeedbackEntryShow.URL(feedbackentry.ID) }>View</a>
													
													
													<a class="text-gray-600 hover:text-gray-900" href={ routes.FeedbackEntryEdit.URL(feedbackentry.ID) }>Edit</a>
													
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}



type FeedbackEntryShow struct {
	Item models.FeedbackEntryEntity
}

func (fes FeedbackEntryShow) PageFragment() string {
	return "feedbackentry-show-page-fragment"
}

templ (fes FeedbackEntryShow) Page() {
	@base() {
		@templ.Fragment(fes.PageFragment()) {
			<main id="feedbackentry-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">FeedbackEntry Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							
							<a href={ routes.FeedbackEntryEdit.URL(fes.Item.ID) } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">Edit</a>
							
							
							<a class="text-sm text-gray-600 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.FeedbackEntryIndex.URL()) }>Back to List</a>
							
						</div>
					</div>
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="p-6 pt-0">
							<div class="grid gap-5 sm:grid-cols-2">
								
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Student Name</label>
									<p class="text-sm text-gray-900">{ newFeedbackEntryData(fes.Item).StudentName }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Feedback</label>
									<p class="text-sm text-gray-900">{ newFeedbackEntryData(fes.Item).Feedback }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Rating</label>
									<p class="text-sm text-gray-900">{ fmt.Sprintf("%d", newFeedbackEntryData(fes.Item).Rating) }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Submitted At</label>
									<p class="text-sm text-gray-900">{ newFeedbackEntryData(fes.Item).SubmittedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Created At</label>
									<p class="text-sm text-gray-900">{ newFeedbackEntryData(fes.Item).CreatedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Updated At</label>
									<p class="text-sm text-gray-900">{ newFeedbackEntryData(fes.Item).UpdatedAt.String() }</p>
								</div>
								
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type FeedbackEntryNew struct{}

func (fen FeedbackEntryNew) PageFragment() string {
	return "feedbackentry-new-page-fragment"
}

templ (fen FeedbackEntryNew) Page() {
	@base() {
		@templ.Fragment(fen.PageFragment()) {
			<main id="feedbackentry-new-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">New FeedbackEntry</h3>
							<p class="text-sm text-gray-500">Enter the details for the new feedbackentry.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.FeedbackEntryCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="studentName">Student Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="studentName" />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="feedback">Feedback</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="feedback" />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="rating">Rating</label>
											<input type="number" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="rating" />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="submittedAt">Submitted At</label>
											<div class="relative w-full">
												<div class="relative">
													<input type="date" class="flex h-9 w-full rounded border border-gray-300 bg-gray-50 px-3 py-1 pr-8 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60" data-bind="submittedAt" />
													<div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
														<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
													</div>
												</div>
											</div>
										</div>
										
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Create FeedbackEntry</button>
										
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.FeedbackEntryIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type FeedbackEntryEdit struct {
	Item models.FeedbackEntryEntity
}

func (fee FeedbackEntryEdit) PageFragment() string {
	return "feedbackentry-edit-page-fragment"
}

templ (fee FeedbackEntryEdit) Page() {
	@base() {
		@templ.Fragment(fee.PageFragment()) {
			<main id="feedbackentry-edit-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">Edit FeedbackEntry</h3>
							<p class="text-sm text-gray-500">Update the details for this feedbackentry.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.FeedbackEntryUpdate.URL(fee.Item.ID)) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="studentName">Student Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="studentName" value={ newFeedbackEntryData(fee.Item).StudentName } />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="feedback">Feedback</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="feedback" value={ newFeedbackEntryData(fee.Item).Feedback } />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="rating">Rating</label>
											<input type="number" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="rating" value={ fmt.Sprintf("%d", newFeedbackEntryData(fee.Item).Rating) } />
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="submittedAt">Submitted At</label>
											<div class="relative w-full">
												<div class="relative">
													<input type="date" class="flex h-9 w-full rounded border border-gray-300 bg-gray-50 px-3 py-1 pr-8 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60" data-bind="submittedAt" value={ newFeedbackEntryData(fee.Item).SubmittedAt.String() } />
													<div class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
														<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path></svg>
													</div>
												</div>
											</div>
										</div>
										
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Update FeedbackEntry</button>
										
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.FeedbackEntryIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
							<div role="separator" class="my-6 shrink-0 bg-gray-300 h-px w-full"></div>
							<button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-red-600 text-white shadow-sm hover:bg-red-700 h-9 px-4 py-2 text-sm rounded w-full" data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.FeedbackEntryDestroy.URL(fee.Item.ID)) }>Destroy FeedbackEntry</button>
							
						</div>
					</div>
				</div>
			</main>
		}
	}
}

