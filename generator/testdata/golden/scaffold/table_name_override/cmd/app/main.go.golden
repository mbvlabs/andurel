package main

import (
	"testapp/controllers"
	"testapp/router"
)

func setupControllers(db interface{}, r *router.Router) error {
	studentFeedback := controllers.NewStudentFeedback(db)
	if err := r.RegisterFeedbackEntryRoutes(studentFeedback); err != nil {
		return err
	}

	// andurel:controller-registration-point
	return nil
}
