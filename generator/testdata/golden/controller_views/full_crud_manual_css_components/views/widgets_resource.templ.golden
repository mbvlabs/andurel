



package views

import (
	"fmt"
		"net/http"
	
	"testapp/models"
	"testapp/internal/hypermedia"
	
	
	"testapp/router/routes"
	
)


type WidgetIndex struct {
	Items []models.WidgetEntity
}

func (wi WidgetIndex) PageFragment() string {
	return "widget-index-page-fragment"
}

templ (wi WidgetIndex) Page() {
	@base() {
		@templ.Fragment(wi.PageFragment()) {
			<main id="widget-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold tracking-tight text-base-content">Widgets</h1>
						
						<a href={ routes.WidgetNew.URL() } class="btn btn-primary">New Widget</a>
						
					</div>
					if len(wi.Items) == 0 {
						<p class="text-sm text-base-content/60">No widgets found.</p>
					} else {
						<div class="table-wrap">
							<table class="table">
								<thead>
									<tr>
										<th>Name</th>
										<th>Quantity</th>
										<th>Active</th>
										<th>Created At</th>
										<th>Updated At</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, widget := range wi.Items {
										<tr>
											<td>{ widget.Name }</td>
											<td>{ fmt.Sprintf("%d", widget.Quantity) }</td>
											<td>{ fmt.Sprintf("%t", widget.Active) }</td>
											<td>{ widget.CreatedAt.String() }</td>
											<td>{ widget.UpdatedAt.String() }</td>
											<td>
												<div class="flex flex-wrap gap-3 text-sm">
													
													<a class="inline-link" href={ routes.WidgetShow.URL(widget.ID) }>View</a>
													
													
													<a class="inline-link" href={ routes.WidgetEdit.URL(widget.ID) }>Edit</a>
													
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}



type WidgetShow struct {
	Item models.WidgetEntity
}

func (ws WidgetShow) PageFragment() string {
	return "widget-show-page-fragment"
}

templ (ws WidgetShow) Page() {
	@base() {
		@templ.Fragment(ws.PageFragment()) {
			<main id="widget-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold tracking-tight text-base-content">Widget Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							
							<a href={ routes.WidgetEdit.URL(ws.Item.ID) } class="btn btn-primary">Edit</a>
							
							
							<a class="inline-link text-sm" href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
							
						</div>
					</div>
					<div class="card">
						<div class="card-content">
							<div class="grid gap-5 sm:grid-cols-2">
								
								<div class="field">
									<label class="field-label">Name</label>
									<p class="text-sm text-base-content">{ ws.Item.Name }</p>
								</div>
								<div class="field">
									<label class="field-label">Quantity</label>
									<p class="text-sm text-base-content">{ fmt.Sprintf("%d", ws.Item.Quantity) }</p>
								</div>
								<div class="field">
									<label class="field-label">Active</label>
									<p class="text-sm text-base-content">{ fmt.Sprintf("%t", ws.Item.Active) }</p>
								</div>
								<div class="field">
									<label class="field-label">Created At</label>
									<p class="text-sm text-base-content">{ ws.Item.CreatedAt.String() }</p>
								</div>
								<div class="field">
									<label class="field-label">Updated At</label>
									<p class="text-sm text-base-content">{ ws.Item.UpdatedAt.String() }</p>
								</div>
								
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type WidgetNew struct{}

func (wn WidgetNew) PageFragment() string {
	return "widget-new-page-fragment"
}

templ (wn WidgetNew) Page() {
	@base() {
		@templ.Fragment(wn.PageFragment()) {
			<main id="widget-new-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="card">
						<div class="card-header">
							<h3 class="card-title">New Widget</h3>
							<p class="card-description">Enter the details for the new widget.</p>
						</div>
						<div class="card-content">
							<form class="form" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.WidgetCreate.URL()) }>
								<fieldset class="fieldset" data-attr:disabled="$_submitting">
									<div class="field">
										<label class="field-label" for="name">Name</label>
										<input type="text" class="input" data-bind="name" />
									</div>
									<div class="field">
										<label class="field-label" for="quantity">Quantity</label>
										<input type="number" class="input" data-bind="quantity" />
									</div>
									<div class="radio-row">
										<input type="checkbox" class="checkbox" data-bind="active" />
										<label class="field-label" for="active">Active</label>
									</div>
									
									<div class="card-footer mt-6 flex-col gap-3">
										<button type="submit" class="btn btn-primary btn-block">Create Widget</button>
										
										<a class="btn btn-outline btn-block" href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</div>
			</main>
		}
	}
}



type WidgetEdit struct {
	Item models.WidgetEntity
}

func (we WidgetEdit) PageFragment() string {
	return "widget-edit-page-fragment"
}

templ (we WidgetEdit) Page() {
	@base() {
		@templ.Fragment(we.PageFragment()) {
			<main id="widget-edit-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="card">
						<div class="card-header">
							<h3 class="card-title">Edit Widget</h3>
							<p class="card-description">Update the details for this widget.</p>
						</div>
						<div class="card-content">
							<form class="form" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.WidgetUpdate.URL(we.Item.ID)) }>
								<fieldset class="fieldset" data-attr:disabled="$_submitting">
									
									<div class="field">
										<label class="field-label" for="name">Name</label>
										<input type="text" class="input" data-bind="name" value={ we.Item.Name } />
									</div>
									<div class="field">
										<label class="field-label" for="quantity">Quantity</label>
										<input type="number" class="input" data-bind="quantity" value={ fmt.Sprintf("%d", we.Item.Quantity) } />
									</div>
									<div class="radio-row">
										<input type="checkbox" class="checkbox" data-bind="active" if we.Item.Active { checked } />
										<label class="field-label" for="active">Active</label>
									</div>
									
									<div class="card-footer mt-6 flex-col gap-3">
										<button type="submit" class="btn btn-primary btn-block">Update Widget</button>
										
										<a class="btn btn-outline btn-block" href={ hypermedia.ResolveBackURL(ctx, routes.WidgetIndex.URL()) }>Back to List</a>
										
									</div>
								</fieldset>
							</form>
							<div class="separator my-6"></div>
							<button type="button" class="btn btn-destructive btn-block" data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.WidgetDestroy.URL(we.Item.ID)) }>Destroy Widget</button>
							
						</div>
					</div>
				</div>
			</main>
		}
	}
}

