package router

import (
	"errors"
	"net/http"

	"testapp/controllers"
	"testapp/router/routes"

	"github.com/labstack/echo/v5"
)

func (r Router) RegisterDashboardRoutes(dashboard controllers.Dashboards) error {
	errs := []error{}
	var err error
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DashboardIndex.Path(),
		Name:    routes.DashboardIndex.Name(),
		Handler: dashboard.Index,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.e.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DashboardShow.Path(),
		Name:    routes.DashboardShow.Name(),
		Handler: dashboard.Show,
	})
	if err != nil {
		errs = append(errs, err)
	}

	return errors.Join(errs...)
}
