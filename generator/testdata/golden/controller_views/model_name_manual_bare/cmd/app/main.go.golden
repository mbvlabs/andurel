package main

import (
	"testapp/controllers"
	"testapp/router"
)

func setupControllers(db interface{}, r *router.Router) error {
	dashboards := controllers.NewDashboards(db)
	if err := r.RegisterDashboardRoutes(dashboards); err != nil {
		return err
	}

	// andurel:controller-registration-point
	return nil
}
