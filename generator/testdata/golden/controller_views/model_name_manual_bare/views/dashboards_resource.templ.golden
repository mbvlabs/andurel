



package views

import (
	"fmt"
	
	"testapp/models"
	"testapp/internal/hypermedia"
	
	
	"testapp/router/routes"
	
)


type DashboardIndex struct {
	Items []models.WidgetEntity
}

func (di DashboardIndex) PageFragment() string {
	return "dashboard-index-page-fragment"
}

templ (di DashboardIndex) Page() {
	@base() {
		@templ.Fragment(di.PageFragment()) {
			<main id="dashboard-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Dashboards</h1>
						
					</div>
					if len(di.Items) == 0 {
						<p class="text-sm text-gray-500">No dashboards found.</p>
					} else {
						<div class="relative w-full overflow-auto">
							<table class="w-full caption-bottom text-sm">
								<thead class="[&_tr]:border-b [&_tr]:border-gray-300">
									<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Name</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Quantity</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Active</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Created At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Updated At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Actions</th>
									</tr>
								</thead>
								<tbody class="[&_tr:last-child]:border-0">
									for _, dashboard := range di.Items {
										<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ dashboard.Name }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ fmt.Sprintf("%d", dashboard.Quantity) }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ fmt.Sprintf("%t", dashboard.Active) }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ dashboard.CreatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ dashboard.UpdatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">
												<div class="flex flex-wrap gap-3 text-sm">
													
													<a class="text-gray-600 hover:text-gray-900" href={ routes.DashboardShow.URL(dashboard.ID) }>View</a>
													
													
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}



type DashboardShow struct {
	Item models.WidgetEntity
}

func (ds DashboardShow) PageFragment() string {
	return "dashboard-show-page-fragment"
}

templ (ds DashboardShow) Page() {
	@base() {
		@templ.Fragment(ds.PageFragment()) {
			<main id="dashboard-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Dashboard Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							
							
							<a class="text-sm text-gray-600 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.DashboardIndex.URL()) }>Back to List</a>
							
						</div>
					</div>
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="p-6 pt-0">
							<div class="grid gap-5 sm:grid-cols-2">
								
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Name</label>
									<p class="text-sm text-gray-900">{ ds.Item.Name }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Quantity</label>
									<p class="text-sm text-gray-900">{ fmt.Sprintf("%d", ds.Item.Quantity) }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Active</label>
									<p class="text-sm text-gray-900">{ fmt.Sprintf("%t", ds.Item.Active) }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Created At</label>
									<p class="text-sm text-gray-900">{ ds.Item.CreatedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Updated At</label>
									<p class="text-sm text-gray-900">{ ds.Item.UpdatedAt.String() }</p>
								</div>
								
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}





