package controllers

import (
	"errors"
	"net/http"
	"strconv"
	"testapp/internal/hypermedia"
	"testapp/internal/storage"
	"testapp/models"
	"testapp/router"
	"testapp/router/routes"
	"testapp/views"

	"github.com/google/uuid"
	"github.com/labstack/echo/v5"
)

type Dashboards struct {
	db storage.Pool
}

func NewDashboards(db storage.Pool) Dashboards {
	return Dashboards{db}
}

func (d Dashboards) RegisterRoutes(r *router.Router) error {
	var errs []error
	var err error
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DashboardIndex.Path(),
		Name:    routes.DashboardIndex.Name(),
		Handler: d.Index,
	})
	if err != nil {
		errs = append(errs, err)
	}
	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.DashboardShow.Path(),
		Name:    routes.DashboardShow.Name(),
		Handler: d.Show,
	})
	if err != nil {
		errs = append(errs, err)
	}

	return errors.Join(errs...)
}

func (d Dashboards) Index(etx *echo.Context) error {
	page := int64(1)
	if p := etx.QueryParam("page"); p != "" {
		if parsed, err := strconv.Atoi(p); err == nil && parsed > 0 {
			page = int64(parsed)
		}
	}

	perPage := int64(25)
	if pp := etx.QueryParam("per_page"); pp != "" {
		if parsed, err := strconv.Atoi(pp); err == nil && parsed > 0 &&
			parsed <= 100 {
			perPage = int64(parsed)
		}
	}

	widgetsList, err := models.Widget.Paginate(
		etx.Request().Context(),
		d.db.Executor(),
		page,
		perPage,
	)
	if err != nil {
		return hypermedia.RenderPage(etx, views.InternalError())
	}

	return hypermedia.RenderPage(etx, views.DashboardIndex{Items: widgetsList.Widgets}.Page())
}

func (d Dashboards) Show(etx *echo.Context) error {
	dashboardID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return hypermedia.RenderPage(etx, views.BadRequest())
	}

	dashboard, err := models.Widget.Find(etx.Request().Context(), d.db.Executor(), dashboardID)
	if err != nil {
		return hypermedia.RenderPage(etx, views.NotFound())
	}

	return hypermedia.RenderPage(etx, views.DashboardShow{Item: dashboard}.Page())
}
