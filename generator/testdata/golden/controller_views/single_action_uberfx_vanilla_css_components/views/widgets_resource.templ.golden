



package views

import (
	"fmt"
	
	"testapp/models"
	
	
)




type WidgetShow struct {
	Item models.WidgetEntity
}

func (ws WidgetShow) PageFragment() string {
	return "widget-show-page-fragment"
}

templ (ws WidgetShow) Page() {
	@base() {
		@templ.Fragment(ws.PageFragment()) {
			<main id="widget-show-container" class="page-shell">
				<section class="container stack" data-gap="lg">
					<div class="cluster" data-justify="between">
						<div class="stack" data-gap="sm">
							<h1>Widget Details</h1>
							<p class="muted">Review the current values stored for this widget.</p>
						</div>
						<div class="cluster" data-gap="sm">
							
							
						</div>
					</div>
					<div class="panel">
						<div class="grid-auto-fit" data-grid="compact">
							
							<div class="field">
								<p class="field-label">Name</p>
								<p>{ ws.Item.Name }</p>
							</div>
							<div class="field">
								<p class="field-label">Quantity</p>
								<p>{ fmt.Sprintf("%d", ws.Item.Quantity) }</p>
							</div>
							<div class="field">
								<p class="field-label">Active</p>
								<p>{ fmt.Sprintf("%t", ws.Item.Active) }</p>
							</div>
							<div class="field">
								<p class="field-label">Created At</p>
								<p>{ ws.Item.CreatedAt.String() }</p>
							</div>
							<div class="field">
								<p class="field-label">Updated At</p>
								<p>{ ws.Item.UpdatedAt.String() }</p>
							</div>
							
						</div>
					</div>
				</section>
			</main>
		}
	}
}





