package routes

import "{{.ModuleName}}/internal/framework"

const (
	billingRoutePrefix = "/billing"
	billingNamePrefix  = "billing"
)

var billingGroup = framework.NewRouteGroup(billingNamePrefix, billingRoutePrefix)

var PaymentWebhook = billingGroup.Route("webhook").
	SetPath("/webhook").
	Register()

var PaymentCheckout = billingGroup.Route("checkout").
	SetPath("/checkout").
	Register()

var PaymentPricing = billingGroup.Route("pricing").
	SetPath("/pricing").
	Register()

var PaymentAccount = billingGroup.Route("account").
	SetPath("/account").
	Register()
