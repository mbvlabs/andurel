package services

import (
	"context"
	"database/sql"
	"encoding/json"
	"errors"
	"fmt"
	"time"

	"{{.ModuleName}}/config"
	"{{.ModuleName}}/email"
	"{{.ModuleName}}/internal/storage"
	"{{.ModuleName}}/models"
	"{{.ModuleName}}/queue"
	"{{.ModuleName}}/queue/jobs"
	"{{.ModuleName}}/router/routes"
)

const userResetPassword = "user_password_reset"

var (
	ErrInvalidResetCode = errors.New("invalid reset code")
	ErrExpiredResetCode = errors.New("reset code has expired")
)

type RequestResetPasswordData struct {
	Email string
}

func RequestResetPassword(
	ctx context.Context,
	db storage.Pool,
	insertOnly queue.InsertOnly,
	salt string,
	data RequestResetPasswordData,
) error {
	tx, err := db.BeginTx(ctx, nil)
	if err != nil {
		return err
	}

	user, err := models.User.FindByEmail(ctx, tx, data.Email)
	if err != nil {
		_ = tx.Rollback()
		if errors.Is(err, sql.ErrNoRows) {
			return nil
		}
		return err
	}

	meta, err := json.Marshal(map[string]string{
		"email": user.Email,
	})
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	token, err := models.Token.Create(
		ctx,
		tx,
		salt,
		userResetPassword,
		time.Now().Add(1*time.Hour),
		meta,
	)
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	if err := tx.Commit(); err != nil {
		return err
	}

	resetURL := fmt.Sprintf("%s%s", config.BaseURL, routes.PasswordEdit.URL(token))

	rpEmail := email.ResetPassword{ResetURL: resetURL}

	html, err := rpEmail.ToHTML()
	if err != nil {
		return err
	}

	text, err := rpEmail.ToText()
	if err != nil {
		return err
	}

	_, err = insertOnly.Insert(ctx, jobs.SendTransactionalEmailArgs{
		Data: email.TransactionalData{
			To:       user.Email,
			From:     config.DefaultSenderSignature,
			Subject:  "Reset Your Password",
			HTMLBody: html,
			TextBody: text,
		},
	}, nil)
	return err
}

type ResetPasswordData struct {
	Token           string
	Password        string
	ConfirmPassword string
}

func ResetPassword(
	ctx context.Context,
	db storage.Pool,
	salt string,
	data ResetPasswordData,
) error {
	if data.Password != data.ConfirmPassword {
		return errors.New("passwords do not match")
	}

	if len(data.Password) < 8 {
		return errors.New("password must be at least 8 characters")
	}

	tx, err := db.BeginTx(ctx, nil)
	if err != nil {
		return err
	}

	token, err := models.Token.FindByScopeAndHash(
		ctx,
		tx,
		salt,
		userResetPassword,
		data.Token,
	)
	if err != nil {
		_ = tx.Rollback()
		return ErrInvalidResetCode
	}

	if !token.IsValid(data.Token, salt) {
		_ = tx.Rollback()
		return ErrExpiredResetCode
	}

	var meta map[string]string
	if err := json.Unmarshal(token.MetaData, &meta); err != nil {
		_ = tx.Rollback()
		return err
	}

	emailAddr, ok := meta["email"]
	if !ok {
		_ = tx.Rollback()
		return errors.New("token metadata missing email")
	}

	user, err := models.User.FindByEmail(ctx, tx, emailAddr)
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	hashedPassword, err := models.HashPassword(data.Password, salt)
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	_, err = models.User.Update(ctx, tx, models.UpdateUserData{
		ID:               user.ID,
		Email:            user.Email,
		EmailValidatedAt: user.EmailValidatedAt,
		Password:         []byte(hashedPassword),
		IsAdmin:          user.IsAdmin,
	})
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	if err := models.Token.Destroy(ctx, tx, token.ID); err != nil {
		_ = tx.Rollback()
		return err
	}

	return tx.Commit()
}
