package views

type Home struct{}

func (h Home) PageFragment() string {
	return "home-page-fragment"
}

templ (h Home) Page() {
	@base() {
		@templ.Fragment(h.PageFragment()) {
			<main id="home-container" class="flex-1">
				<div class="space-y-3">
					<h1 class="text-3xl font-bold">Welcome to Andurel</h1>
				</div>
			</main>
		}
	}
}