package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

type RegistrationForm struct{}

func (RegistrationForm) ContainerFragment() string {
	return "registration-container-fragment"
}

templ (rf RegistrationForm) Page() {
	@base() {
		@templ.Fragment(rf.ContainerFragment()) {
			<main id="registration-container">
				<section>
					<div>
						<div>
							<h1>Create an account</h1>
							<p>Enter your details below to create your account.</p>
						</div>
						<div>
							<form data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.RegistrationCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="email">Email</label>
										<div>
											<input type="email" id="email" data-bind="email" required/>
										</div>
									</div>
									<div>
										<label for="password">Password</label>
										<div>
											<input type="password" id="password" data-bind="password" required minlength="8"/>
										</div>
									</div>
									<div>
										<label for="confirmPassword">Confirm Password</label>
										<div>
											<input type="password" id="confirmPassword" data-bind="confirmPassword" required minlength="8"/>
										</div>
									</div>
									<button type="submit">
										<span data-show="!$_submitting">Sign Up</span>
										<span data-show="$_submitting">Loading</span>
									</button>
								</fieldset>
							</form>
						</div>
						<div>
							<p>Already have an account?</p>
							<a href={ routes.SessionNew.URL() }>Login</a>
						</div>
					</div>
				</section>
			</main>
		}
	}
}