// TestSessions_Create_UnverifiedEmail rejects login before email verification.
func TestSessions_Create_UnverifiedEmail(t *testing.T) {
	Load(".env.test")

	testDB, err := testContainer.CreateDB(context.Background(), "test_sessions_unverified")
	if err != nil {
		t.Fatalf("failed to create test DB: %v", err)
	}
	t.Cleanup(func() {
		testDB.Close()
	})

	ctx := context.Background()

	_, err = factories.CreateUser(ctx, testDB.DB.Conn(),
		factories.WithEmail("carol@example.com"),
	)
	assert.NoError(t, err)

	user, err := models.User.FindByEmail(ctx, testDB.DB.Conn(), "carol@example.com")
	assert.NoError(t, err)
	assert.Nil(t, user.EmailValidatedAt, "user email should not be validated")

	e := echo.New()
	sessions := newSessionsController(testDB.DB)

	body := strings.NewReader(`{"email":"carol@example.com","password":"password123"}`)
	req := httptest.NewRequest(http.MethodPost, routes.SessionCreate.URL(), body)
	req.Header.Set(echo.HeaderContentType, echo.MIMEApplicationJSON)
	rec := httptest.NewRecorder()
	c := e.NewContext(req, rec)

	setupSessionStore(c)

	err = sessions.Create(c)
	assert.NoError(t, err)

	assert.Contains(t, rec.Body.String(), `data-bind="email"`)
	assert.Contains(t, rec.Body.String(), "Login to your account")
}

// TestSessions_Destroy destroys the session and redirects back to login.
func TestSessions_Destroy(t *testing.T) {
	Load(".env.test")

	testDB, err := testContainer.CreateDB(context.Background(), "test_sessions_destroy")
	if err != nil {
		t.Fatalf("failed to create test DB: %v", err)
	}
	t.Cleanup(func() {
		testDB.Close()
	})

	e := echo.New()
	sessions := newSessionsController(testDB.DB)

	req := httptest.NewRequest(http.MethodDelete, routes.SessionDestroy.URL(), nil)
	rec := httptest.NewRecorder()
	c := e.NewContext(req, rec)

	setupSessionStore(c)

	err = sessions.Destroy(c)
	assert.NoError(t, err)

	assert.Contains(t, rec.Body.String(), "flashContainer")
	assert.Contains(t, rec.Body.String(), "Successfully logged out")
	assert.Contains(t, rec.Body.String(), `data-bind="email"`)
}
