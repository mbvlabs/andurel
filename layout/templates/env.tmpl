ENVIRONMENT=development

DEFAULT_SENDER_SIGNATURE=info@andurel.com

DB_KIND=postgres
DB_PORT=5432
DB_HOST=127.0.0.1
DB_NAME=andurel
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

PROJECT_NAME={{.ProjectName}}
DOMAIN=localhost:8080
PROTOCOL=http

SESSION_KEY={{.SessionKey}}
SESSION_ENCRYPTION_KEY={{.SessionEncryptionKey}}
SESSION_MAX_AGE=604800

TOKEN_SIGNING_KEY={{.TokenSigningKey}}

CORS_ALLOWED_ORIGINS=
CSRF_STRATEGY=header_only
CSRF_TRUSTED_ORIGINS=

PEPPER={{.Pepper}}
PREVIOUS_PEPPERS=
{{- if .Blueprint.Config.EnvVars}}
{{range .Blueprint.Config.SortedEnvVars}}
{{.Key}}={{.DefaultValue}}
{{- end}}
{{- end}}
