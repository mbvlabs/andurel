	"context"
	"database/sql"
	"encoding/json"
	"errors"
	"time"

	"{{.ModuleName}}/config"
	"{{.ModuleName}}/email"
{{- if ne .DIMode "uberfx"}}
	"{{.ModuleName}}/internal/storage"
{{- end}}
	"{{.ModuleName}}/models"
{{- if ne .DIMode "uberfx"}}
	"{{.ModuleName}}/queue"
{{- end}}
	"{{.ModuleName}}/queue/jobs"
)

const userEmailVerification = "user_email_verification"

type RegisterUserData struct {
	Email           string
	Password        string
	ConfirmPassword string
}

{{if eq .DIMode "uberfx"}}
func (i Identity) RegisterUser(
	ctx context.Context,
	data RegisterUserData,
) error {
	tx, err := i.db.BeginTx(ctx, nil)
{{else}}
func RegisterUser(
	ctx context.Context,
	db storage.Pool,
	insertOnly queue.InsertOnly,
	salt string,
	data RegisterUserData,
) error {
	tx, err := db.BeginTx(ctx, nil)
{{end}}
	if err != nil {
		return err
	}

{{if eq .DIMode "uberfx"}}
	user, err := models.User.Create(ctx, tx, i.pepper, models.CreateUserData{
{{else}}
	user, err := models.User.Create(ctx, tx, salt, models.CreateUserData{
{{end}}
		Email: data.Email,
		PasswordPair: models.PasswordPair{
			Password:        data.Password,
			ConfirmPassword: data.ConfirmPassword,
		},
	})
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	meta, err := json.Marshal(map[string]string{
		"email": user.Email,
	})
	if err != nil {
		_ = tx.Rollback()
		return err
	}

{{if eq .DIMode "uberfx"}}
	code, err := models.Token.CreateCode(
		ctx,
		tx,
		i.pepper,
{{else}}
	code, err := models.Token.CreateCode(
		ctx,
		tx,
		salt,
{{end}}
		userEmailVerification,
		time.Now().Add(24*time.Hour),
		meta,
	)
	if err != nil {
		_ = tx.Rollback()
		return err
	}

	if err := tx.Commit(); err != nil {
		return err
	}

	vEmail := email.VerifyEmail{VerificationCode: code}

	html, err := vEmail.ToHTML()
	if err != nil {
		return err
	}

	text, err := vEmail.ToText()
	if err != nil {
		return err
	}

{{if eq .DIMode "uberfx"}}
	_, err = i.insertOnly.Insert(ctx, jobs.SendTransactionalEmailArgs{
{{else}}
	_, err = insertOnly.Insert(ctx, jobs.SendTransactionalEmailArgs{
{{end}}
		Data: email.TransactionalData{
			To:       user.Email,
			From:     config.DefaultSenderSignature,
			Subject:  "Verify Your Email Address",
			HTMLBody: html,
			TextBody: text,
		},
	}, nil)
	return err
}

var (
	ErrInvalidVerificationCode = errors.New("invalid verification code")
	ErrExpiredVerificationCode = errors.New("verification code has expired")
	ErrUserNotFound            = errors.New("user not found")
)

type VerifyEmailData struct {
	Code string
}

{{if eq .DIMode "uberfx"}}
func (i Identity) VerifyEmail(
	ctx context.Context,
	data VerifyEmailData,
) (models.UserEntity, error) {
	tx, err := i.db.BeginTx(ctx, nil)
{{else}}
func VerifyEmail(
	ctx context.Context,
	db storage.Pool,
	salt string,
	data VerifyEmailData,
) (models.UserEntity, error) {
	tx, err := db.BeginTx(ctx, nil)
{{end}}
	if err != nil {
		return models.UserEntity{}, err
	}

{{if eq .DIMode "uberfx"}}
	token, err := models.Token.FindByScopeAndHash(
		ctx,
		tx,
		i.pepper,
{{else}}
	token, err := models.Token.FindByScopeAndHash(
		ctx,
		tx,
		salt,
{{end}}
		userEmailVerification,
		data.Code,
	)
	if err != nil {
		_ = tx.Rollback()
		return models.UserEntity{}, ErrInvalidVerificationCode
	}

{{if eq .DIMode "uberfx"}}
	if !token.IsValid(data.Code, i.pepper) {
{{else}}
	if !token.IsValid(data.Code, salt) {
{{end}}
		_ = tx.Rollback()
		return models.UserEntity{}, ErrExpiredVerificationCode
	}

	var meta map[string]string
	if err := json.Unmarshal(token.MetaData, &meta); err != nil {
		_ = tx.Rollback()
		return models.UserEntity{}, err
	}

	emailAddr, ok := meta["email"]
	if !ok {
		_ = tx.Rollback()
		return models.UserEntity{}, errors.New("token metadata missing email")
	}

	user, err := models.User.FindByEmail(ctx, tx, emailAddr)
	if err != nil {
		_ = tx.Rollback()
		return models.UserEntity{}, err
	}

	now := time.Now()
	user, err = models.User.Update(ctx, tx, models.UpdateUserData{
		ID:               user.ID,
		Email:            user.Email,
		EmailValidatedAt: sql.NullTime{Time: now, Valid: true},
		Password:         user.Password,
		IsAdmin:          user.IsAdmin,
	})
	if err != nil {
		_ = tx.Rollback()
		return models.UserEntity{}, err
	}

	if err := models.Token.Destroy(ctx, tx, token.ID); err != nil {
		_ = tx.Rollback()
		return models.UserEntity{}, err
	}

	if err := tx.Commit(); err != nil {
		return models.UserEntity{}, err
	}

	return user, nil
}
