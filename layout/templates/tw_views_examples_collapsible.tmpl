<!-- Use for a single expandable details block inside a surface. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:open="false">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Collapsible</h2>
    <p class="text-sm text-base-content/70">Toggles additional detail within a single surface.</p>
  </header>

  <div class="collapsible">
    <button type="button" class="collapsible-trigger" data-on:click="$open = !$open">
      Toggle Details
      <span>⌄</span>
    </button>
    <div class="collapsible-content" data-show="$open">This section expands and collapses with Datastar state.</div>
  </div>
</section>
