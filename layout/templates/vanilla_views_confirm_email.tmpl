package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

templ ConfirmationForm() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Verify Your Email</h1>
						<p class="card-description">Please enter the 6-digit verification code sent to your email.</p>
					</div>
					<div class="card-content">
						<form class="form" data-indicator:submitting data-on:submit={ "!$submitting && " + hypermedia.DataAction(http.MethodPost, routes.ConfirmationCreate.URL()) }>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="code">Verification Code</label>
									<div class="field-control">
										<input
											class="input"
											type="text"
											id="code"
											data-bind="code"
											required
											pattern="[A-Z0-9]{6}"
											maxlength="6"
											placeholder="Enter 6-digit code"
											autocomplete="off"
										/>
									</div>
									<p class="field-hint">Codes are six characters long and may include letters or numbers.</p>
								</div>
								<button class="btn btn-primary btn-block" type="submit">
									<span data-show="!$submitting">Verify Email</span>
									<span data-show="$submitting">Loading</span>
								</button>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}
