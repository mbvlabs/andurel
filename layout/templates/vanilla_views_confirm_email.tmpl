package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

templ ConfirmationForm() {
	@base() {
		<main>
			<section>
				<div>
					<div>
						<h1>Verify Your Email</h1>
						<p>Please enter the 6-digit verification code sent to your email.</p>
					</div>
					<div>
						<form data-indicator:submitting data-on:submit={ "!$submitting && " + hypermedia.DataAction(http.MethodPost, routes.ConfirmationCreate.URL()) }>
							<fieldset data-attr:disabled="$submitting">
								<div>
									<label for="code">Verification Code</label>
									<div>
										<input
											type="text"
											id="code"
											data-bind="code"
											required
											pattern="[A-Z0-9]{6}"
											maxlength="6"
											placeholder="Enter 6-digit code"
											autocomplete="off"
										/>
									</div>
									<p>Codes are six characters long and may include letters or numbers.</p>
								</div>
								<button type="submit">
									<span data-show="!$submitting">Verify Email</span>
									<span data-show="$submitting">Loading</span>
								</button>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}
