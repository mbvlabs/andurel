package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

type ConfirmationForm struct{}

func (ConfirmationForm) ContainerFragment() string {
	return "confirmation-container-fragment"
}

templ (cf ConfirmationForm) Page() {
	@base() {
		@templ.Fragment(cf.ContainerFragment()) {
			<main id="confirmation-container">
				<section>
					<div>
						<div>
							<h1>Verify Your Email</h1>
							<p>Please enter the 6-digit verification code sent to your email.</p>
						</div>
						<div>
							<form data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.ConfirmationCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="code">Verification Code</label>
										<div>
											<input
												type="text"
												id="code"
												data-bind="code"
												required
												pattern="[A-Z0-9]{6}"
												maxlength="6"
												placeholder="Enter 6-digit code"
												autocomplete="off"
											/>
										</div>
										<p>Codes are six characters long and may include letters or numbers.</p>
									</div>
									<button type="submit">
										<span data-show="!$_submitting">Verify Email</span>
										<span data-show="$_submitting">Loading</span>
									</button>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}