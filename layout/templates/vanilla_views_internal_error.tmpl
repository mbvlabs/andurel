package views

templ InternalError() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Internal error</h1>
						<p class="card-description">Something went wrong on our end. Please try again in a moment.</p>
					</div>
				</div>
			</section>
		</main>
	}
}
