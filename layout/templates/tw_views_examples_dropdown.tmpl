<!-- Use for compact action menus attached to a trigger. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:open="false">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Dropdown</h2>
    <p class="text-sm text-base-content/70">Action menu dropdown with separators and labels.</p>
  </header>

  <div class="dropdown">
    <button type="button" class="btn btn-ghost" data-on:click="$open = !$open">Toggle Dropdown</button>
    <div class="dropdown-menu" data-show="$open">
      <p class="dropdown-label">Actions</p>
      <button type="button" class="dropdown-item">Edit</button>
      <button type="button" class="dropdown-item">Duplicate</button>
      <div class="dropdown-separator"></div>
      <button type="button" class="dropdown-item">Delete</button>
    </div>
  </div>
</section>
