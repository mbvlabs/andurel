<!-- Use to visually divide related content without introducing a new surface. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Separator</h2>
    <p class="text-sm text-base-content/70">Horizontal and vertical separators.</p>
  </header>

  <div class="space-y-2">
    <p class="text-sm">Section A</p>
    <div class="separator"></div>
    <p class="text-sm">Section B</p>
  </div>

  <div class="flex items-center gap-3">
    <span class="text-sm">Left</span>
    <div class="separator-vertical"></div>
    <span class="text-sm">Right</span>
  </div>
</section>
