<!-- Use for temporary non-blocking feedback that disappears after a delay. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:showToast="false,visible=true">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Toast</h2>
    <p class="text-sm text-base-content/70">Temporary flash message stack item.</p>
  </header>

  <button type="button" class="btn btn-primary" data-on:click="$showToast = true; $visible = true">Show Toast</button>

  <div class="toast-stack !static" data-show="$showToast">
    <div class="toast toast-success" data-show="$visible" data-init__delay.5000ms="$visible = false; $showToast = false">
      <div class="toast-header">
        <div class="toast-indicator"></div>
        <span class="flex items-center gap-2">
          <p class="toast-time">just now</p>
          <button type="button" class="toast-close" data-on:click="$visible = false; $showToast = false">x</button>
        </span>
      </div>
      <span class="toast-message">Profile settings saved successfully.</span>
    </div>
  </div>
</section>
