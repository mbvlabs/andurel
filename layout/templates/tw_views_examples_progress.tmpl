<!-- Use to show linear completion or upload progress. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Progress</h2>
    <p class="text-sm text-base-content/70">Linear progress states.</p>
  </header>

  <div class="space-y-3">
    <div class="progress"><div class="progress-indicator" style="width: 20%"></div></div>
    <div class="progress"><div class="progress-indicator" style="width: 65%"></div></div>
    <div class="progress"><div class="progress-indicator" style="width: 100%"></div></div>
  </div>
</section>
