/* Layout/object primitives */
:where(.container) {
	inline-size: min(100% - 2 * var(--space-4), min(72rem, calc(100vw - 2 * var(--space-5))));
	margin-inline: auto;
}

:where(.stack) {
	display: grid;
	gap: var(--stack-gap, var(--space-4));
	justify-items: start;
}

:where(.stack) > * {
	margin: 0;
}

:where(.stack)[data-gap="sm"] {
	--stack-gap: var(--space-3);
}

:where(.stack)[data-gap="lg"] {
	--stack-gap: var(--space-6);
}

:where(.cluster) {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: var(--cluster-gap, var(--space-3));
}

:where(.cluster)[data-gap="sm"] {
	--cluster-gap: var(--space-2);
}

:where(.cluster)[data-gap="lg"] {
	--cluster-gap: var(--space-5);
}

:where(.cluster)[data-justify="between"] {
	justify-content: space-between;
}

:where(.cluster)[data-justify="center"] {
	justify-content: center;
}

:where(.center) {
	box-sizing: content-box;
	max-inline-size: 65ch;
	margin-inline: auto;
	padding-inline: var(--space-4);
	text-align: center;
}

:where(.center)[data-center="wide"] {
	max-inline-size: min(72rem, calc(100vw - 2 * var(--space-5)));
}

:where(.grid-auto-fit) {
	--grid-min: 16rem;
	display: grid;
	gap: var(--grid-gap, var(--space-5));
	grid-template-columns: repeat(auto-fit, minmax(min(var(--grid-min), 100%), 1fr));
}

:where(.grid-auto-fit)[data-gap="sm"] {
	--grid-gap: var(--space-3);
}

:where(.grid-auto-fit)[data-gap="lg"] {
	--grid-gap: var(--space-6);
}

:where(.grid-auto-fit)[data-grid="compact"] {
	--grid-min: 12rem;
}

:where(.grid-auto-fit)[data-grid="wide"] {
	--grid-min: 20rem;
}

/* Semantic utility helpers */
:where(.flow) > * + * {
	margin-block-start: var(--space-4);
}

:where(.flow)[data-gap="sm"] > * + * {
	margin-block-start: var(--space-3);
}

:where(.flow)[data-gap="lg"] > * + * {
	margin-block-start: var(--space-5);
}

:where(.muted) {
	color: color-mix(in oklab, var(--color-base-content) 64%, white);
}

:where(.text-center) {
	text-align: center;
}

:where(.full-width) {
	inline-size: 100%;
}

:where(.visually-hidden) {
	position: absolute;
	inline-size: 1px;
	block-size: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}

/* Markup-ready utility classes (tailwind-like contract for vanilla scaffold). */
.flex {
	display: flex;
}

.grid {
	display: grid;
}

.inline-flex {
	display: inline-flex;
}

.flex-1 {
	flex: 1 1 0%;
}

.flex-col {
	flex-direction: column;
}

.flex-wrap {
	flex-wrap: wrap;
}

.items-center {
	align-items: center;
}

.items-start {
	align-items: flex-start;
}

.justify-center {
	justify-content: center;
}

.justify-between {
	justify-content: space-between;
}

.gap-1 {
	gap: var(--space-1);
}

.gap-2 {
	gap: var(--space-2);
}

.gap-3 {
	gap: var(--space-3);
}

.gap-4 {
	gap: var(--space-4);
}

.gap-5 {
	gap: var(--space-5);
}

.gap-6 {
	gap: var(--space-6);
}

.space-y-1 > * + * {
	margin-block-start: var(--space-1);
}

.space-y-2 > * + * {
	margin-block-start: var(--space-2);
}

.space-y-3 > * + * {
	margin-block-start: var(--space-3);
}

.space-y-4 > * + * {
	margin-block-start: var(--space-4);
}

.w-full {
	inline-size: 100%;
}

.max-w-md {
	max-inline-size: 28rem;
}

.max-w-4xl {
	max-inline-size: 56rem;
}

.max-w-5xl {
	max-inline-size: 64rem;
}

.min-h-screen {
	min-block-size: 100vh;
}

.mx-auto {
	margin-inline: auto;
}

.mt-6 {
	margin-block-start: var(--space-6);
}

.my-6 {
	margin-block: var(--space-6);
}

.p-0 {
	padding: 0;
}

.p-6 {
	padding: var(--space-6);
}

.px-4 {
	padding-inline: var(--space-4);
}

.px-6 {
	padding-inline: var(--space-6);
}

.py-2 {
	padding-block: var(--space-2);
}

.py-4 {
	padding-block: var(--space-4);
}

.py-10 {
	padding-block: 2.5rem;
}

.pt-0 {
	padding-block-start: 0;
}

.rounded-field {
	border-radius: var(--radius-field);
}

.rounded-box {
	border-radius: var(--radius-box);
}

.border {
	border: 1px solid color-mix(in oklab, var(--color-base-content) 18%, white);
}

.border-base-300 {
	border-color: var(--color-base-300);
}

.bg-base-100 {
	background: var(--color-base-100);
}

.bg-base-200 {
	background: var(--color-base-200);
}

.bg-base-300 {
	background: var(--color-base-300);
}

.bg-primary {
	background: var(--primary);
}

.bg-error {
	background: var(--error);
}

.text-base-content {
	color: var(--color-base-content);
}

.text-primary-content {
	color: var(--primary-content);
}

.text-error-content {
	color: var(--error-content);
}

.text-sm {
	font-size: var(--step--1);
}

.text-lg {
	font-size: var(--step-1);
}

.text-2xl {
	font-size: var(--step-2);
}

.font-medium {
	font-weight: var(--font-weight-medium);
}

.font-semibold {
	font-weight: var(--font-weight-semibold);
}

.font-bold {
	font-weight: var(--font-weight-bold);
}

.leading-none {
	line-height: 1;
}

.shadow-sm {
	box-shadow: var(--shadow-sm);
}

.transition {
	transition: all var(--duration-base) var(--ease-standard);
}

.hover\:bg-base-200\/70:hover {
	background: color-mix(in oklab, var(--color-base-200) 70%, transparent);
}

.hover\:text-base-content:hover {
	color: var(--color-base-content);
}

/* Utility aliases that mirror scaffold snippets. */
.text-base-content\/60 {
	color: color-mix(in oklab, var(--color-base-content) 60%, transparent);
}

.text-base-content\/70 {
	color: color-mix(in oklab, var(--color-base-content) 70%, transparent);
}

.text-base-content\/80 {
	color: color-mix(in oklab, var(--color-base-content) 80%, transparent);
}
