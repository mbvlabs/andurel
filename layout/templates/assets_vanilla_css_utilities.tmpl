.u-flow > * + * {
	margin-block-start: var(--space-4);
}

.u-muted {
	color: var(--text-muted);
}

.u-center {
	text-align: center;
}

.u-visually-hidden {
	position: absolute;
	inline-size: 1px;
	block-size: 1px;
	padding: 0;
	margin: -1px;
	overflow: hidden;
	clip: rect(0, 0, 0, 0);
	white-space: nowrap;
	border: 0;
}
