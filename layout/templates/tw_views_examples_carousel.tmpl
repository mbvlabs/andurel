<!-- Use for a simple slide deck with manual dot navigation. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:slide=0>
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Carousel</h2>
    <p class="text-sm text-base-content/70">Track and dot navigation for a simple slideshow.</p>
  </header>

  <div class="carousel">
    <div class="carousel-track" data-attr:style="'transform: translateX(-' + ($slide * 100) + '%)'">
      <div class="carousel-item"><div class="rounded-box bg-base-200 p-4">Slide 1</div></div>
      <div class="carousel-item"><div class="rounded-box bg-base-200 p-4">Slide 2</div></div>
      <div class="carousel-item"><div class="rounded-box bg-base-200 p-4">Slide 3</div></div>
    </div>

    <div class="carousel-nav">
      <button type="button" class="carousel-dot" data-attr:data-active="$slide == 0 ? 'true' : null" data-on:click="$slide = 0"></button>
      <button type="button" class="carousel-dot" data-attr:data-active="$slide == 1 ? 'true' : null" data-on:click="$slide = 1"></button>
      <button type="button" class="carousel-dot" data-attr:data-active="$slide == 2 ? 'true' : null" data-on:click="$slide = 2"></button>
    </div>
  </div>
</section>
