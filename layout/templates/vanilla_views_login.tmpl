package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

type LoginForm struct{}

func (LoginForm) ContainerFragment() string {
	return "login-container-fragment"
}

templ (lf LoginForm) Page() {
	@base() {
		@templ.Fragment(lf.ContainerFragment()) {
			<main id="login-container">
				<section>
					<div>
						<div>
							<h1>Login to your account</h1>
							<p>Enter your details below to sign in.</p>
						</div>
						<div>
							<form data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.SessionCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="email">Email</label>
										<div>
											<input type="email" id="email" data-bind="email" required/>
										</div>
									</div>
									<div>
										<label for="password">Password</label>
										<div>
											<input type="password" id="password" data-bind="password" required/>
										</div>
									</div>
									<div>
										<span>Protected session access.</span>
										<a href={ routes.PasswordNew.URL() }>Forgot your password?</a>
									</div>
									<button type="submit">
										<span data-show="!$_submitting">Login</span>
										<span data-show="$_submitting">Loading</span>
									</button>
								</fieldset>
							</form>
						</div>
						<div>
							<p>Don't have an account?</p>
							<a href={ routes.RegistrationNew.URL() }>Sign up</a>
						</div>
					</div>
				</section>
			</main>
		}
	}
}