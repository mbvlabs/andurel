package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/internal/validation"
	"{{.ModuleName}}/router/routes"
)

type LoginForm struct {
	Errors validation.ValidationErrors
}

func (lf LoginForm) FieldError(field string) string {
	return lf.Errors.ToMap()[field]
}

func (lf LoginForm) PageFragment() string {
	return "login-page-fragment"
}

templ (lf LoginForm) Page() {
	@base() {
		@templ.Fragment(lf.PageFragment()) {
			<main id="login-container">
				<section>
					<div>
						<div>
							<h1>Login to your account</h1>
							<p>Enter your details below to sign in.</p>
						</div>
						<div>
							<form data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.SessionCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="email">Email</label>
										<div>
											<input type="email" id="email" data-bind="email" required/>
										</div>
										if lf.FieldError("email") != "" {
											<p id="email-error" style="color: var(--destructive); font-size: var(--step--1); font-weight: 600;" role="alert">{ lf.FieldError("email") }</p>
										}
									</div>
									<div>
										<label for="password">Password</label>
										<div>
											<input type="password" id="password" data-bind="password" required/>
										</div>
										if lf.FieldError("password") != "" {
											<p id="password-error" style="color: var(--destructive); font-size: var(--step--1); font-weight: 600;" role="alert">{ lf.FieldError("password") }</p>
										}
									</div>
									<div>
										<span>Protected session access.</span>
										<a href={ routes.PasswordNew.URL() }>Forgot your password?</a>
									</div>
									<button type="submit">
										<span data-show="!$_submitting">Login</span>
										<span data-show="$_submitting">Loading</span>
									</button>
								</fieldset>
							</form>
						</div>
						<div>
							<p>Don't have an account?</p>
							<a href={ routes.RegistrationNew.URL() }>Sign up</a>
						</div>
					</div>
				</section>
			</main>
		}
	}
}
