// getCookieValue extracts the value of a named cookie from Set-Cookie headers.
func getCookieValue(headers http.Header, name string) string {
	for _, h := range headers.Values("Set-Cookie") {
		if idx := strings.Index(h, "="); idx > 0 && h[:idx] == name {
			rest := h[idx+1:]
			if semi := strings.Index(rest, ";"); semi > 0 {
				return rest[:semi]
			}
			return rest
		}
	}
	return ""
}

// seedUser creates a validated user with password "password123" within its own
// transaction on the given pool.
func seedUser(ctx context.Context, db storage.Pool, email string) error {
	tx, err := db.BeginTx(ctx, nil)
	if err != nil {
		return fmt.Errorf("failed to begin transaction: %w", err)
	}
	defer func() {
		_ = tx.Rollback()
	}()

	_, err = factories.CreateUser(ctx, tx,
		factories.WithEmail(email),
		factories.WithValidatedEmail(),
	)
	if err != nil {
		return fmt.Errorf("failed to create user: %w", err)
	}

	return tx.Commit()
}

var testContainer *database.TestDBContainer

func TestMain(m *testing.M) {
	var err error
	testContainer, err = database.NewTestDBContainer(context.Background())
	if err != nil {
		panic(fmt.Sprintf("failed to start test DB container: %v", err))
	}
	code := m.Run()
	testContainer.Cleanup()
	os.Exit(code)
}
