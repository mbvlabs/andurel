import { Link, useForm } from '@inertiajs/react'
import type { FormEvent } from 'react'

import Layout, { errorTextClass, inputClass, labelClass, linkClass, panelClass, panelCopyClass, panelTitleClass, primaryButtonClass } from '../../Layouts/Layout'
import { routes } from '../../routes'

type ResetPasswordRequestProps = {
  errors?: Record<string, string>
}

export default function ResetPasswordRequest({ errors = {} }: ResetPasswordRequestProps) {
  const form = useForm({ email: '' })

  function submit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()
    form.post(routes.passwordCreate())
  }

  return (
    <Layout>
      <section className={panelClass}>
        <div className="p-6 pb-0">
          <h1 className={panelTitleClass}>Reset Password</h1>
          <p className={panelCopyClass}>Enter your email address and we'll send you a code to reset your password.</p>
        </div>
        <div className="p-6">
          <form onSubmit={submit} className="space-y-5">
            <div className="space-y-1">
              <label className={labelClass} htmlFor="email">Email</label>
              <input id="email" type="email" value={form.data.email} onChange={(event) => form.setData('email', event.target.value)} className={inputClass} required />
              {errors.email && <p className={errorTextClass}>{errors.email}</p>}
            </div>
            <button type="submit" disabled={form.processing} className={primaryButtonClass}>{form.processing ? 'Loading' : 'Send Reset Code'}</button>
          </form>
          <p className="mt-6 text-center text-sm text-[#8f8a7d]">Remember your password? <Link className={linkClass} href={routes.sessionNew()}>Login</Link></p>
        </div>
      </section>
    </Layout>
  )
}
