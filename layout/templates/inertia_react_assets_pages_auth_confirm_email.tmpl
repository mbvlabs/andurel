import { useForm } from '@inertiajs/react'
import type { FormEvent } from 'react'

import Layout, { errorTextClass, inputClass, labelClass, panelClass, panelCopyClass, panelTitleClass, primaryButtonClass } from '../../Layouts/Layout'
import { routes } from '../../routes'

type ConfirmEmailProps = {
  errors?: Record<string, string>
}

export default function ConfirmEmail({ errors = {} }: ConfirmEmailProps) {
  const form = useForm({ code: '' })

  function submit(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()
    form.post(routes.confirmationCreate())
  }

  return (
    <Layout>
      <section className={panelClass}>
        <div className="p-6 pb-0">
          <h1 className={panelTitleClass}>Verify Your Email</h1>
          <p className={panelCopyClass}>Please enter the 6-digit verification code sent to your email.</p>
        </div>
        <div className="p-6">
          <form onSubmit={submit} className="space-y-5">
            <div className="space-y-1">
              <label className={labelClass} htmlFor="code">Verification Code</label>
              <input id="code" type="text" maxLength={6} value={form.data.code} onChange={(event) => form.setData('code', event.target.value)} className={`${inputClass} text-center tracking-[0.3em]`} required />
              {errors.code && <p className={errorTextClass}>{errors.code}</p>}
            </div>
            <button type="submit" disabled={form.processing} className={primaryButtonClass}>{form.processing ? 'Loading' : 'Verify Email'}</button>
          </form>
        </div>
      </section>
    </Layout>
  )
}
