:where(.container, .o-container) {
	inline-size: min(100% - 2 * var(--space-4), var(--container-inline));
	margin-inline: auto;
}

:where(.stack, .o-stack) {
	display: grid;
	gap: var(--stack-gap, var(--space-4));
	justify-items: start;
}

:where(.stack, .o-stack) > * {
	margin: 0;
}

:where(.stack, .o-stack)[data-gap="sm"] {
	--stack-gap: var(--space-3);
}

:where(.stack, .o-stack)[data-gap="lg"] {
	--stack-gap: var(--space-6);
}

:where(.cluster, .o-cluster) {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	gap: var(--cluster-gap, var(--space-3));
}

:where(.cluster, .o-cluster)[data-gap="sm"] {
	--cluster-gap: var(--space-2);
}

:where(.cluster, .o-cluster)[data-gap="lg"] {
	--cluster-gap: var(--space-5);
}

:where(.cluster, .o-cluster)[data-justify="between"] {
	justify-content: space-between;
}

:where(.cluster, .o-cluster)[data-justify="center"] {
	justify-content: center;
}

:where(.center, .o-center) {
	box-sizing: content-box;
	max-inline-size: var(--measure);
	margin-inline: auto;
	padding-inline: var(--space-4);
	text-align: center;
}

:where(.center, .o-center)[data-center="wide"] {
	max-inline-size: var(--container-inline);
}

:where(.grid-auto-fit, .o-grid) {
	--grid-min: 16rem;
	display: grid;
	gap: var(--grid-gap, var(--space-5));
	grid-template-columns: repeat(auto-fit, minmax(min(var(--grid-min), 100%), 1fr));
}

:where(.grid-auto-fit, .o-grid)[data-gap="sm"] {
	--grid-gap: var(--space-3);
}

:where(.grid-auto-fit, .o-grid)[data-gap="lg"] {
	--grid-gap: var(--space-6);
}

:where(.grid-auto-fit, .o-grid)[data-grid="compact"] {
	--grid-min: 12rem;
}

:where(.grid-auto-fit, .o-grid)[data-grid="wide"] {
	--grid-min: 20rem;
}

@media (min-width: 48rem) {
	:where(.o-grid)[data-columns="2"] {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}
}
