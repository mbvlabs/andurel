package views

import (
	"net/http"
	"{{.ModuleName}}/internal/hypermedia"
	"{{.ModuleName}}/router/routes"
)

templ ResetPasswordRequestForm() {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Reset Password</h1>
						<p class="card-description">Enter your email address and we'll send you a code to reset your password.</p>
					</div>
					<div class="card-content">
						<form class="form" data-indicator:submitting data-on:submit={ "!$submitting && " + hypermedia.DataAction(http.MethodPost, routes.PasswordCreate.URL()) }>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="email">Email</label>
									<div class="field-control">
										<input class="input" type="email" id="email" data-bind="email" required/>
									</div>
								</div>
								<button class="btn btn-primary btn-block" type="submit">
									<span data-show="!$submitting">Send Reset Code</span>
									<span data-show="$submitting">Loading</span>
								</button>
							</fieldset>
						</form>
					</div>
					<div class="card-footer">
						<p class="field-hint">Remember your password?</p>
						<a class="btn-link" href={ routes.SessionNew.URL() }>Login</a>
					</div>
				</div>
			</section>
		</main>
	}
}

templ ResetPasswordForm(token string) {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Reset Your Password</h1>
						<p class="card-description">Enter your new password below.</p>
					</div>
					<div class="card-content">
						<form class="form" data-indicator:submitting data-on:submit={ "!$submitting && " + hypermedia.DataAction(http.MethodPut, routes.PasswordUpdate.URL()) }>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<input type="hidden" data-bind="resetPasswordToken" value={ token }/>
								<div class="field">
									<label class="field-label" for="password">New Password</label>
									<div class="field-control">
										<input class="input" type="password" id="password" data-bind="password" required minlength="8"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="confirmPassword">Confirm New Password</label>
									<div class="field-control">
										<input class="input" type="password" id="confirmPassword" data-bind="confirmPassword" required minlength="8"/>
									</div>
								</div>
								<button class="btn btn-primary btn-block" type="submit">
									<span data-show="!$submitting">Reset Password</span>
									<span data-show="$submitting">Loading</span>
								</button>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}
