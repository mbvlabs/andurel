<!-- Use for longer freeform text that spans multiple lines. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Textarea</h2>
    <p class="text-sm text-base-content/70">Textarea with helper and validation text.</p>
  </header>

  <div class="field">
    <label for="example-bio" class="field-label">Bio</label>
    <textarea id="example-bio" class="textarea" placeholder="Tell us about yourself"></textarea>
    <p class="field-hint">Keep it under 160 characters.</p>
  </div>

  <div class="field">
    <label for="example-bio-error" class="field-label">Bio</label>
    <textarea id="example-bio-error" class="textarea-error">This bio is intentionally too long for the field.</textarea>
    <p class="field-error">Bio exceeds the character limit.</p>
  </div>
</section>
