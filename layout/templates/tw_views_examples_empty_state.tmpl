<!-- Use when a screen or section has no data yet and needs a next step. -->
<section class="empty-state">
  <div class="empty-state-icon">+</div>
  <div class="space-y-1">
    <h2 class="empty-state-title">No Deployments Yet</h2>
    <p class="empty-state-description">Create your first deployment target to start rolling out builds.</p>
  </div>
  <div class="empty-state-actions">
    <button type="button" class="btn btn-primary">Create Target</button>
    <button type="button" class="btn btn-outline">Import Existing</button>
  </div>
</section>
