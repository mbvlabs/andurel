	"{{.ModuleName}}/internal/storage"
)

// TestDBContainer manages a single shared PostgreSQL container and provides
// per-test isolated databases within that container. This is significantly
// faster than spinning up a container per test.
type TestDBContainer struct {
	container *postgres.PostgresContainer
	host      string
	port      string
	user      string
	password  string
	ctx       context.Context
}

// NewTestDBContainer starts a single shared PostgreSQL container. Call this
// once in TestMain or package-level init, not per-test.
func NewTestDBContainer(ctx context.Context) (*TestDBContainer, error) {
	pgContainer, err := postgres.Run(ctx,
		"postgres:17-alpine",
		postgres.WithDatabase("testdb"),
		postgres.WithUsername("testuser"),
		postgres.WithPassword("testpass"),
		testcontainers.WithWaitStrategy(
			wait.ForLog("database system is ready to accept connections").
				WithOccurrence(2).
				WithStartupTimeout(60*time.Second)),
	)
	if err != nil {
		return nil, fmt.Errorf("failed to start postgres container: %w", err)
	}

	// Use PortEndpoint to get the properly mapped host:port from Docker
	endpoint, err := pgContainer.PortEndpoint(ctx, "5432/tcp", "")
	if err != nil {
		pgContainer.Terminate(ctx)
		return nil, fmt.Errorf("failed to get port endpoint: %w", err)
	}

	// Parse "host:port" from endpoint — it may be "localhost:12345" or just "12345"
	host := "localhost"
	port := "5432"
	if idx := strings.LastIndex(endpoint, ":"); idx > 0 {
		host = endpoint[:idx]
		port = endpoint[idx+1:]
	}

	return &TestDBContainer{
		container: pgContainer,
		host:      host,
		port:      port,
		user:      "testuser",
		password:  "testpass",
		ctx:       ctx,
	}, nil
}

// CreateDB creates a new isolated database within the shared container, runs
// migrations on it, and returns a fully configured TestDB ready for use.
// Each call creates a separate database so tests remain isolated from each other.
// Databases are automatically cleaned up when the container is terminated.
func (c *TestDBContainer) CreateDB(ctx context.Context, name string) (*TestDB, error) {
	adminDSN := c.adminDSN()
	adminConn, err := c.connectAdmin(adminDSN)
	if err != nil {
		return nil, fmt.Errorf("failed to connect to admin database: %w", err)
	}
	defer adminConn.Close(ctx)

	if _, err := adminConn.Exec(ctx, fmt.Sprintf(`CREATE DATABASE "%s"`, name)); err != nil {
		adminConn.Close(ctx)
		return nil, fmt.Errorf("failed to create database %q: %w", name, err)
	}

	testDSN := c.databaseDSN(name)

	db, err := NewPostgres(ctx, testDSN)
	if err != nil {
		adminConn.Exec(ctx, fmt.Sprintf(`DROP DATABASE IF EXISTS "%s" WITH (FORCE)`, name))
		adminConn.Close(ctx)
		return nil, fmt.Errorf("failed to connect to test database %q: %w", name, err)
	}

	if err := runMigrations(db); err != nil {
		adminConn.Exec(ctx, fmt.Sprintf(`DROP DATABASE IF EXISTS "%s" WITH (FORCE)`, name))
		db.Close()
		return nil, fmt.Errorf("failed to run migrations on %q: %w", name, err)
	}

	return &TestDB{
		DB:        db,
		Container: c.container,
		DSN:       testDSN,
	}, nil
}

// Cleanup terminates the shared PostgreSQL container. Call this in TestMain
// after all tests complete.
func (c *TestDBContainer) Cleanup() error {
	return c.container.Terminate(c.ctx)
}

// ConnectionString returns the full connection string for the base container database.
func (c *TestDBContainer) ConnectionString() string {
	return c.databaseDSN("testdb")
}

func (c *TestDBContainer) databaseDSN(dbName string) string {
	return fmt.Sprintf("postgres://%s:%s@%s:%s/%s?sslmode=disable",
		c.user, c.password, c.host, c.port, dbName)
}

func (c *TestDBContainer) adminDSN() string {
	return c.databaseDSN("testdb")
}

func (c *TestDBContainer) connectAdmin(dsn string) (*pgx.Conn, error) {
	return pgx.Connect(c.ctx, dsn)
}

// TestDB wraps a database connection and the shared container reference.
type TestDB struct {
	DB        storage.Pool
	Container *postgres.PostgresContainer
	DSN       string
}

// Close is kept for backward compatibility but does nothing when using
// TestDBContainer — use container.Cleanup() instead.
func (tdb *TestDB) Close() error {
	if tdb.DB != nil {
		return tdb.DB.Close()
	}
	return nil
}

// WithTx runs fn inside a transaction that is always rolled back, so test
// changes never persist across tests.
func (tdb *TestDB) WithTx(t *testing.T, fn func(tx bun.Tx)) {
	t.Helper()
	ctx := context.Background()

	tx, err := tdb.DB.BeginTx(ctx, nil)
	if err != nil {
		t.Fatalf("failed to begin transaction: %v", err)
	}
	defer func() {
		if rbErr := tx.Rollback(); rbErr != nil && rbErr.Error() != "tx already closed" {
			t.Errorf("failed to rollback transaction: %v", rbErr)
		}
	}()

	fn(tx)
}

func findGoModRoot() (string, error) {
	dir, err := os.Getwd()
	if err != nil {
		return "", fmt.Errorf("could not get working directory: %w", err)
	}

	for {
		goModPath := filepath.Join(dir, "go.mod")
		if _, err := os.Stat(goModPath); err == nil {
			return dir, nil
		}

		parent := filepath.Dir(dir)
		if parent == dir {
			break
		}
		dir = parent
	}

	return "", fmt.Errorf("not in an andurel project: go.mod could not be found")
}

func runMigrations(db *Postgres) error {
	rootDir, err := findGoModRoot()
	if err != nil {
		return err
	}

	goosePath := filepath.Join(rootDir, "bin", "goose")
	if _, err := os.Stat(goosePath); err != nil {
		if os.IsNotExist(err) {
			return fmt.Errorf(
				"goose binary not found at %s\nRun 'andurel tool sync' to download it",
				goosePath,
			)
		}
		return err
	}

	goose.SetBaseFS(Migrations)

	if err := goose.SetDialect("postgres"); err != nil {
		panic(err)
	}

	if err := goose.Up(db.Conn().DB, "migrations"); err != nil {
		panic(err)
	}

	return nil
}
