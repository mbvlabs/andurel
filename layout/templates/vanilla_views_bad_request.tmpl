package views

templ BadRequest() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Bad request</h1>
						<p class="card-description">The request could not be processed because the submitted data or URL was invalid.</p>
					</div>
				</div>
			</section>
		</main>
	}
}
