.toast-stack,
#flashContainer {
	position: fixed;
	inset-inline-end: var(--space-4);
	inset-block-start: var(--space-4);
	display: grid;
	gap: var(--space-3);
	inline-size: min(24rem, calc(100vw - 2 * var(--space-4)));
	z-index: var(--z-toast);
}

#flashContainer > div,
.toast {
	display: grid;
	gap: var(--space-1);
	padding: var(--space-4);
	border: 1px solid color-mix(in oklab, var(--border-subtle) 70%, transparent);
	border-radius: var(--radius-md);
	background: color-mix(in oklab, var(--surface-panel) 92%, transparent);
	box-shadow: var(--shadow-md);
	backdrop-filter: blur(10px);
}

.toast {
	padding: 0;
	overflow: clip;
}

.status,
.alert {
	--feedback-accent: var(--neutral);
	--feedback-surface: color-mix(in oklab, var(--surface-panel) 95%, transparent);
	--feedback-border: color-mix(in oklab, var(--feedback-accent) 32%, var(--border-subtle));
	--feedback-text: var(--text-strong);

	display: grid;
	gap: var(--space-1);
	padding: var(--space-4);
	border: 1px solid var(--feedback-border);
	border-inline-start-width: 0.375rem;
	border-radius: var(--radius-md);
	background: var(--feedback-surface);
	box-shadow: var(--shadow-sm);
	color: var(--feedback-text);
}

.alert {
	inline-size: 100%;
}

.status-neutral,
.alert-neutral {
	--feedback-accent: var(--neutral);
}

.toast-success,
.status-success,
.alert-success {
	--feedback-accent: var(--success);
	--feedback-surface: color-mix(in oklab, var(--success) 10%, var(--surface-panel));
}

.toast-info,
.status-info,
.alert-info {
	--feedback-accent: var(--info);
	--feedback-surface: color-mix(in oklab, var(--info) 10%, var(--surface-panel));
}

.toast-warning,
.status-warning,
.alert-warning {
	--feedback-accent: var(--warning);
	--feedback-surface: color-mix(in oklab, var(--warning) 12%, var(--surface-panel));
}

.toast-error,
.status-error,
.alert-error {
	--feedback-accent: var(--error);
	--feedback-surface: color-mix(in oklab, var(--error) 10%, var(--surface-panel));
}

.status-destructive,
.alert-destructive {
	--feedback-accent: var(--error);
	--feedback-border: color-mix(in oklab, var(--error) 70%, var(--border-subtle));
	--feedback-surface: color-mix(in oklab, var(--error) 18%, var(--surface-panel));
}

.toast-header {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: var(--space-3);
	padding: var(--space-3) var(--space-4);
	border-block-end: 1px solid color-mix(in oklab, var(--border-subtle) 80%, transparent);
}

.toast-header .cluster {
	flex-wrap: nowrap;
}

.toast-indicator {
	inline-size: 0.75rem;
	block-size: 0.75rem;
	border-radius: var(--radius-round);
	background: var(--info);
}

.toast-success .toast-indicator {
	background: var(--success);
}

.toast-info .toast-indicator {
	background: var(--info);
}

.toast-warning .toast-indicator {
	background: var(--warning);
}

.toast-error .toast-indicator {
	background: var(--error);
}

.toast-time {
	color: var(--text-muted);
	font-size: 0.75rem;
}

.status-title,
.alert-title,
.toast-title {
	color: inherit;
	font-size: var(--step--1);
	font-weight: var(--font-weight-semibold);
	letter-spacing: 0.04em;
	text-transform: uppercase;
}

.toast-close {
	--btn-bg: transparent;
	--btn-border: transparent;
	--btn-text: var(--text-muted);
	--btn-shadow: none;
	--btn-hover-bg: color-mix(in oklab, var(--surface-panel-muted) 82%, transparent);
	--btn-hover-border: transparent;
	--btn-hover-shadow: none;
	--btn-hover-text: var(--text-strong);

	min-block-size: 2rem;
	padding-inline: var(--space-2);
}

.toast-message {
	padding: var(--space-4);
	color: var(--text-strong);
}

.toast-body,
.status-subtle,
.alert-description {
	color: var(--text-muted);
}
