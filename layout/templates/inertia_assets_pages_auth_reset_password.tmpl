<script setup lang="ts">
import { useForm } from '@inertiajs/vue3'
import Layout from '../../Layouts/Layout.vue'

const props = defineProps<{
  token: string
  errors?: Record<string, string>
}>()

const form = useForm({
  resetPasswordToken: props.token,
  password: '',
  confirmPassword: '',
})
</script>

<template>
  <Layout>
    <section class="w-full max-w-md rounded-lg border border-cyan-400/25 bg-slate-900 shadow-sm shadow-cyan-950/30">
      <div class="p-8 pb-0">
        <h1 class="text-xl font-semibold text-slate-100">Reset Your Password</h1>
        <p class="mt-1 text-sm text-slate-400">Enter your new password below.</p>
      </div>
      <div class="p-8">
        <form class="space-y-5" @submit.prevent="form.put('/users/password')">
          <p v-if="errors?.resetPasswordToken" class="text-sm font-medium text-red-400">{{ errors.resetPasswordToken }}</p>
          <div class="space-y-1">
            <label class="text-sm font-medium text-slate-200" for="password">New Password</label>
            <input id="password" v-model="form.password" type="password" class="flex h-9 w-full rounded border border-cyan-400/25 bg-slate-950 px-3 py-1 text-sm text-slate-100 shadow-inner shadow-cyan-950/30 focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/40" required>
            <p v-if="errors?.password" class="text-sm font-medium text-red-400">{{ errors.password }}</p>
          </div>
          <div class="space-y-1">
            <label class="text-sm font-medium text-slate-200" for="confirmPassword">Confirm New Password</label>
            <input id="confirmPassword" v-model="form.confirmPassword" type="password" class="flex h-9 w-full rounded border border-cyan-400/25 bg-slate-950 px-3 py-1 text-sm text-slate-100 shadow-inner shadow-cyan-950/30 focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/40" required>
            <p v-if="errors?.confirmPassword" class="text-sm font-medium text-red-400">{{ errors.confirmPassword }}</p>
          </div>
          <button type="submit" :disabled="form.processing" class="inline-flex w-full items-center justify-center rounded bg-cyan-400 px-4 py-2 text-sm font-medium text-slate-950 shadow-sm shadow-cyan-950/30 hover:bg-cyan-300 disabled:opacity-60">{{ form.processing ? 'Loading' : 'Reset Password' }}</button>
        </form>
      </div>
    </section>
  </Layout>
</template>
