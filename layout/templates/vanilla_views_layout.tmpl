package views

import (
	"{{.ModuleName}}/router/cookies"
	"time"
)

templ base(headOpts ...HeadDataOption) {
	<!DOCTYPE html>
	<html lang="en" class="dark">
		@SetupHead(ctx, headOpts...)
		<body>
			{ children... }
			<footer>
				<div>
					&copy; { time.Now().Format("2006") } andurel.
				</div>
			</footer>
		</body>
		<div id="flashContainer">
			for _, flash := range cookies.GetFlashesCtx(ctx) {
				<div id={ "toast-" + flash.ID.String() }>
					<strong>{ string(flash.Type) }</strong>
					<span>{ flash.Message }</span>
					<small>{ flash.CreatedAt.Format(time.Kitchen) }</small>
				</div>
			}
		</div>
	</html>
}
