package views

import (
	"{{.ModuleName}}/router/cookies"
	"time"
)

templ base(headOpts ...HeadDataOption) {
	<!DOCTYPE html>
	<html lang="en" class="dark">
		@SetupHead(ctx, headOpts...)
		<body class="app-shell">
			{ children... }
			<footer class="site-footer">
				<div class="container">
					&copy; { time.Now().Format("2006") } andurel.
				</div>
			</footer>
			<div id="flashContainer" class="toast-stack">
				for _, flash := range cookies.GetFlashesCtx(ctx) {
					<div
						class={ "toast toast-" + string(flash.Type) }
						id={ "toast-" + flash.ID.String() }
						data-flash-type={ string(flash.Type) }
						data-signals:visible="true"
						data-show="$visible"
						data-init__delay.5000ms="$visible = false"
					>
						<div class="toast-header">
							<div class="cluster" data-gap="sm">
								<div class="toast-indicator"></div>
								<p class="toast-time">{ flash.CreatedAt.Format(time.Kitchen) }</p>
							</div>
							<button class="toast-close btn btn-ghost btn-sm" data-on:click="$visible = false" type="button">
								<span class="visually-hidden">Dismiss</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M18 6 6 18"></path>
									<path d="m6 6 12 12"></path>
								</svg>
							</button>
						</div>
						<div class="toast-message">{ flash.Message }</div>
					</div>
				}
			</div>
		</body>
	</html>
}
