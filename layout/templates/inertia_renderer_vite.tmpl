package renderer

import (
	"encoding/json"
	"errors"
	"fmt"
	"html/template"
	"io/fs"

	"{{.ModuleName}}/assets"
	"{{.ModuleName}}/config"
	"{{.ModuleName}}/internal/server"
)

type viteTags struct {
	ViteHead template.HTML
	ViteBody template.HTML
}

type viteManifestEntry struct {
	File    string   `json:"file"`
	CSS     []string `json:"css"`
	Src     string   `json:"src"`
	IsEntry bool     `json:"isEntry"`
}

func initVite() (*viteTags, error) {
	viteHead, viteBody, err := readManifestTags()
	if err != nil {
		if config.Env == server.ProdEnvironment {
			return nil, fmt.Errorf("vite: %w", err)
		}
		return devViteTags(), nil
	}

	return &viteTags{ViteHead: viteHead, ViteBody: viteBody}, nil
}

func devViteTags() *viteTags {
	return &viteTags{
		ViteHead: template.HTML(`<script type="module" src="http://localhost:5173/assets/dist/@vite/client"></script>`),
		ViteBody: template.HTML(`<script type="module" src="http://localhost:5173/assets/dist/resources/js/app.ts"></script>`),
	}
}

func readManifestTags() (template.HTML, template.HTML, error) {
	data, err := assets.Files.ReadFile("dist/vite/manifest.json")
	if err != nil {
		if errors.Is(err, fs.ErrNotExist) {
			return "", "", fmt.Errorf("manifest not found (run vite build)")
		}
		return "", "", fmt.Errorf("read manifest: %w", err)
	}

	var manifest map[string]viteManifestEntry
	if err := json.Unmarshal(data, &manifest); err != nil {
		return "", "", fmt.Errorf("parse manifest: %w", err)
	}

	entry, ok := manifest["resources/js/app.ts"]
	if !ok {
		return "", "", fmt.Errorf("entry point 'resources/js/app.ts' not found in manifest")
	}

	var head template.HTML
	for _, css := range entry.CSS {
		head += template.HTML(`<link rel="stylesheet" href="/assets/dist/` + css + `">`)
	}
	body := template.HTML(`<script type="module" src="/assets/dist/` + entry.File + `"></script>`)

	return head, body, nil
}
