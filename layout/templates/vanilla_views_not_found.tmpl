package views

templ NotFound() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Page not found</h1>
						<p class="card-description">The page you requested does not exist or is no longer available.</p>
					</div>
				</div>
			</section>
		</main>
	}
}
