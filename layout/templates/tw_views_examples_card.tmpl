<!-- Use for bordered content blocks with optional header and footer actions. -->
<article class="card max-w-md">
  <div class="card-header">
    <h2 class="card-title">Card Title</h2>
    <p class="card-description">Short supporting copy for the card.</p>
  </div>
  <div class="card-content">
    <p class="text-sm text-base-content/70">Body content in a bordered surface.</p>
  </div>
  <div class="card-footer gap-2">
    <button type="button" class="btn btn-outline btn-sm">Cancel</button>
    <button type="button" class="btn btn-primary btn-sm">Save</button>
  </div>
</article>
