<!-- Use when you need a bordered multi-item disclosure pattern. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:open="true">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Accordion</h2>
    <p class="text-sm text-base-content/70">Expandable item inside the accordion container.</p>
  </header>

  <div class="accordion">
    <div class="accordion-item">
      <button type="button" class="accordion-trigger" data-on:click="$open = !$open">
        What is Andurel?
        <span>⌄</span>
      </button>
      <div class="accordion-content" data-show="$open">Andurel is a Rails-like fullstack framework for Go.</div>
    </div>
  </div>
</section>
