<!-- Use for indeterminate loading states when no exact progress is available. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Spinner</h2>
    <p class="text-sm text-base-content/70">Loading indicator sizes.</p>
  </header>

  <div class="flex items-center gap-4">
    <span class="spinner spinner-sm"></span>
    <span class="spinner"></span>
    <span class="spinner spinner-lg"></span>
  </div>
</section>
