:where(html) {
	scroll-behavior: smooth;
	color: var(--color-base-content);
	font-family: var(--font-sans);
}

:where(body) {
	min-block-size: 100vh;
	letter-spacing: -0.0125em;
	-webkit-tap-highlight-color: transparent;
	text-rendering: optimizeLegibility;
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
}

:where(main) {
	inline-size: 100%;
}

:where(h1, h2, h3) {
	line-height: 1.05;
	letter-spacing: -0.03em;
	text-wrap: balance;
}

:where(h1) {
	font-size: var(--step-3);
	max-inline-size: 12ch;
}

:where(h2) {
	font-size: var(--step-2);
}

:where(h3) {
	font-size: var(--step-1);
}

:where(p, li, label, input, textarea, select, button) {
	font-size: var(--step-0);
}

:where(p, ul, ol) {
	color: color-mix(in oklab, var(--color-base-content) 64%, white);
	max-inline-size: 65ch;
}

:where(a) {
	color: var(--primary);
	text-decoration-color: color-mix(in oklab, var(--primary) 45%, transparent);
	text-underline-offset: 0.18em;
}

:where(a:hover) {
	color: color-mix(in oklab, var(--color-primary) 88%, black);
}

:where(button, input, textarea, select) {
	accent-color: var(--primary);
}

:where(:focus-visible) {
	outline: 3px solid color-mix(in oklab, var(--color-primary) 36%, white);
	outline-offset: 3px;
}

:where(::placeholder) {
	color: color-mix(in oklab, var(--color-base-content) 45%, transparent);
}

:where([hidden]) {
	display: none !important;
}
