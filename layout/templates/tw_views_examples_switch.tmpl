<!-- Use for immediate on-off settings that apply directly. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6" data-signals:enabled="true">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Switch</h2>
    <p class="text-sm text-base-content/70">Boolean toggle using Datastar state.</p>
  </header>

  <div class="flex items-center gap-3">
    <button type="button" class="switch" data-attr:data-checked="$enabled ? 'true' : null" data-on:click="$enabled = !$enabled" aria-pressed="true">
      <span class="switch-thumb" data-attr:data-checked="$enabled ? 'true' : null"></span>
    </button>
    <span class="text-sm" data-text="$enabled ? 'Notifications enabled' : 'Notifications disabled'">Notifications enabled</span>
  </div>
</section>
