<!-- Use when users need to add and remove multiple short labels in one field. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Tags Input</h2>
    <p class="text-sm text-base-content/70">Tokenized input with removable tags.</p>
  </header>

  <div class="field">
    <label class="field-label">Tags</label>
    <div class="tags-input">
      <span class="tag-pill">Go <button type="button" class="tag-remove">x</button></span>
      <span class="tag-pill">Templ <button type="button" class="tag-remove">x</button></span>
      <input class="input h-7 border-0 bg-transparent p-0 shadow-none focus:ring-0" placeholder="Add tag" />
    </div>
  </div>
</section>
