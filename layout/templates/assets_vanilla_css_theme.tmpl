/* Tailwind-aligned theme variables. */
.light {
	--background-base-100: oklch(100% 0 0);
	--background-base-200: oklch(98% 0 0);
	--background-base-300: oklch(95% 0 0);

	--text-base-content: oklch(21% 0.006 285.885);

	--primary: oklch(45% 0.24 277.023);
	--primary-content: oklch(93% 0.034 272.788);

	--secondary: oklch(65% 0.241 354.308);
	--secondary-content: oklch(94% 0.028 342.258);

	--accent: oklch(77% 0.152 181.912);
	--accent-content: oklch(38% 0.063 188.416);

	--neutral: oklch(14% 0.005 285.823);
	--neutral-content: oklch(92% 0.004 286.32);

	--info: oklch(74% 0.16 232.661);
	--info-content: oklch(29% 0.066 243.157);

	--success: oklch(76% 0.177 163.223);
	--success-content: oklch(37% 0.077 168.94);

	--warning: oklch(82% 0.189 84.429);
	--warning-content: oklch(41% 0.112 45.904);

	--error: oklch(71% 0.194 13.428);
	--error-content: oklch(27% 0.105 12.094);

	color-scheme: light;
}

.dark {
	--background-base-100: oklch(25.33% 0.016 252.42);
	--background-base-200: oklch(23.26% 0.014 253.1);
	--background-base-300: oklch(21.15% 0.012 254.09);

	--text-base-content: oklch(97.807% 0.029 256.847);

	--primary: oklch(58% 0.233 277.117);
	--primary-content: oklch(96% 0.018 272.314);

	--secondary: oklch(65% 0.241 354.308);
	--secondary-content: oklch(94% 0.028 342.258);

	--accent: oklch(77% 0.152 181.912);
	--accent-content: oklch(38% 0.063 188.416);

	--neutral: oklch(14% 0.005 285.823);
	--neutral-content: oklch(92% 0.004 286.32);

	--info: oklch(74% 0.16 232.661);
	--info-content: oklch(29% 0.066 243.157);

	--success: oklch(76% 0.177 163.223);
	--success-content: oklch(37% 0.077 168.94);

	--warning: oklch(82% 0.189 84.429);
	--warning-content: oklch(41% 0.112 45.904);

	--error: oklch(71% 0.194 13.428);
	--error-content: oklch(27% 0.105 12.094);

	color-scheme: dark;
}

/* Default to light theme when no explicit class is present. */
:root:not(.dark):not(.light) {
	--background-base-100: oklch(100% 0 0);
	--background-base-200: oklch(98% 0 0);
	--background-base-300: oklch(95% 0 0);
	--text-base-content: oklch(21% 0.006 285.885);
	--primary: oklch(45% 0.24 277.023);
	--primary-content: oklch(93% 0.034 272.788);
	--secondary: oklch(65% 0.241 354.308);
	--secondary-content: oklch(94% 0.028 342.258);
	--accent: oklch(77% 0.152 181.912);
	--accent-content: oklch(38% 0.063 188.416);
	--neutral: oklch(14% 0.005 285.823);
	--neutral-content: oklch(92% 0.004 286.32);
	--info: oklch(74% 0.16 232.661);
	--info-content: oklch(29% 0.066 243.157);
	--success: oklch(76% 0.177 163.223);
	--success-content: oklch(37% 0.077 168.94);
	--warning: oklch(82% 0.189 84.429);
	--warning-content: oklch(41% 0.112 45.904);
	--error: oklch(71% 0.194 13.428);
	--error-content: oklch(27% 0.105 12.094);
	color-scheme: light;
}

/* Shared theme mapping + scales for vanilla CSS. */
:root,
.light,
.dark {
	--color-base-100: var(--background-base-100);
	--color-base-200: var(--background-base-200);
	--color-base-300: var(--background-base-300);

	--color-base-content: var(--text-base-content);

	--color-primary: var(--primary);
	--color-primary-content: var(--primary-content);
	--color-secondary: var(--secondary);
	--color-secondary-content: var(--secondary-content);
	--color-accent: var(--accent);
	--color-accent-content: var(--accent-content);
	--color-neutral: var(--neutral);
	--color-neutral-content: var(--neutral-content);
	--color-info: var(--info);
	--color-info-content: var(--info-content);
	--color-success: var(--success);
	--color-success-content: var(--success-content);
	--color-warning: var(--warning);
	--color-warning-content: var(--warning-content);
	--color-error: var(--error);
	--color-error-content: var(--error-content);

	--font-sans: "Inter", "Segoe UI", sans-serif;
	--font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
	--font-weight-regular: 400;
	--font-weight-medium: 500;
	--font-weight-semibold: 600;
	--font-weight-bold: 700;

	--step--1: 0.875rem;
	--step-0: 1rem;
	--step-1: clamp(1.2rem, 1.05rem + 0.75vw, 1.7rem);
	--step-2: clamp(1.6rem, 1.3rem + 1.5vw, 2.4rem);
	--step-3: clamp(2rem, 1.5rem + 2.4vw, 3.4rem);

	--space-1: 0.25rem;
	--space-2: 0.5rem;
	--space-3: 0.75rem;
	--space-4: 1rem;
	--space-5: 1.5rem;
	--space-6: 2rem;
	--space-7: 3rem;
	--space-8: 4rem;

	/* Border radius — aligned with Tailwind @theme. */
	--radius-selector: 1rem;
	--radius-field: 0.25rem;
	--radius-box: 0.5rem;
	--radius-round: 999px;

	/* Base sizes. */
	--size-selector: 0.25rem;
	--size-field: 0.25rem;

	/* Border size. */
	--border: 1px;

	/* Effects. */
	--depth: 1;
	--noise: 0;

	--shadow-sm: 0 1px 2px hsl(220 30% 12% / 0.08);
	--shadow-md: 0 10px 26px hsl(220 35% 20% / 0.12);
	--shadow-lg: 0 20px 52px hsl(220 35% 18% / 0.18);

	--duration-fast: 120ms;
	--duration-base: 180ms;
	--duration-slow: 280ms;
	--ease-standard: cubic-bezier(0.2, 0, 0.13, 1);

	--z-base: 0;
	--z-dropdown: 10;
	--z-sticky: 20;
	--z-overlay: 30;
	--z-toast: 40;
	--z-modal: 50;
}
