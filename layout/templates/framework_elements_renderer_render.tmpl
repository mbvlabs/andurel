// Package renderer provides utilities for rendering templ components and inertia pages.
package renderer

import (
	"context"
	"errors"
	"net/http"
	"strings"

	"github.com/a-h/templ"
	"github.com/labstack/echo/v5"
{{- if eq .ViewLayer "inertia-vue"}}
	"fmt"

	"{{.ModuleName}}/config"
	inertia "github.com/romsar/gonertia/v3"
{{- end}}
)

type CookieKey string

const BackURLKey CookieKey = "back_url_context"

{{- if eq .ViewLayer "inertia-vue"}}

// Package-level Inertia instance, initialized once at startup.
var gInertia *inertia.Inertia

// InitInertia initializes the global Inertia instance with the root HTML template
// that serves as the mounting point for the Vue application. Must be called once
// during application startup before any Inertia middleware or render calls.
func InitInertia(rootHTML string, opts ...inertia.Option) error {
	tags, err := initVite()
	if err != nil {
		return fmt.Errorf("renderer: vite init: %w", err)
	}

	templateData := map[string]any{
		"viteHead": tags.ViteHead,
		"viteBody": tags.ViteBody,
		"appName":  config.ProjectName,
	}

	allOpts := append([]inertia.Option{
		inertia.WithTemplateData(templateData),
	}, opts...)

	i, err := inertia.NewFromFile(rootHTML, allOpts...)
	if err != nil {
		return err
	}
	gInertia = i
	return nil
}

// Inertia renders an Inertia page response.
// For initial (non-Inertia) requests: returns a full HTML document with the page
// object embedded in the data-page attribute of the root element.
// For Inertia XHR requests (identified by the X-Inertia header): returns a JSON
// response containing the component name and props.
func Inertia(etx *echo.Context, component string, props inertia.Props) error {
	if gInertia == nil {
		return errors.New("renderer: Inertia not initialized, call InitInertia")
	}
	return gInertia.Render(etx.Response(), etx.Request(), component, props)
}

// InertiaRedirect sends an Inertia-aware redirect.
// For Inertia requests: automatically promotes PUT/PATCH/DELETE to 303.
// For standard requests: performs a normal HTTP redirect with the given status.
func InertiaRedirect(etx *echo.Context, url string, status ...int) error {
	if gInertia == nil {
		return errors.New("renderer: Inertia not initialized, call InitInertia")
	}
	gInertia.Redirect(etx.Response(), etx.Request(), url, status...)
	return nil
}

// InertiaMiddleware returns an Echo middleware that wraps the gonertia middleware.
// It handles:
//   - Asset version mismatch detection (409 + X-Inertia-Location response)
//   - 302 to 303 promotion for PUT/PATCH/DELETE requests
//   - Vary: X-Inertia header on all responses
//   - Shared prop injection and session persistence
func InertiaMiddleware() echo.MiddlewareFunc {
	return echo.WrapMiddleware(func(next http.Handler) http.Handler {
		return gInertia.Middleware(next)
	})
}
{{- end}}

func Render(ctx *echo.Context, t templ.Component, cookieKeys []CookieKey) error {
	buf := templ.GetBuffer()
	defer templ.ReleaseBuffer(buf)

	extendedCtx := ctx.Request().Context()

	for _, cookie := range cookieKeys {
		cookieCtx := ctx.Get(string(cookie))
		bufCtx := context.WithValue(
			extendedCtx,
			cookie,
			cookieCtx,
		)

		extendedCtx = bufCtx
	}

	if err := t.Render(extendedCtx, buf); err != nil {
		return err
	}

	return ctx.HTML(http.StatusOK, buf.String())
}

func ResolveBackURL(ctx context.Context, fallback string) string {
	backURL, _ := ctx.Value(BackURLKey).(string)
	backURL = strings.TrimSpace(backURL)
	if !isSafeBackURL(backURL) {
		return fallback
	}

	return backURL
}

func isSafeBackURL(backURL string) bool {
	if backURL == "" {
		return false
	}

	return strings.HasPrefix(backURL, "/") &&
		!strings.HasPrefix(backURL, "//")
}
