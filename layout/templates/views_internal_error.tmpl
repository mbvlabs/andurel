package views

templ InternalError() {
	@base() {
		<section class="flex flex-1 items-center justify-center px-6 py-16">
			<div class="w-full max-w-md rounded-lg border border-cyan-400/25 bg-slate-900 p-6 text-center shadow-sm shadow-cyan-950/30">
				<p class="text-sm font-medium uppercase tracking-wide text-cyan-300">500</p>
				<h1 class="mt-2 text-2xl font-semibold text-white">Something went wrong.</h1>
				<p class="mt-3 text-sm leading-6 text-slate-400">The application hit an unexpected error.</p>
			</div>
		</section>
	}
}
