var testDB *database.TestDB

// TestMain initializes a shared TestDB for all auth integration tests.
// Each individual test uses WithTx for transactional rollback isolation.
func TestMain(m *testing.M) {
	var err error
	testDB, err = database.NewTestDB()
	if err != nil {
		panic(err)
	}
	defer testDB.Close()

	m.Run()
}

// noOpInsertOnly satisfies queue.InsertOnly by doing nothing on InsertTx.
// RegisterUser calls InsertTx after committing the user transaction,
// so this allows registration tests without a running River worker.
type noOpInsertOnly struct{}

func (n *noOpInsertOnly) Insert(ctx context.Context, args rivertype.JobArgs, opts *rivertype.InsertOpts) (*rivertype.JobInsertResult, error) {
	return &rivertype.JobInsertResult{}, nil
}

func (n *noOpInsertOnly) InsertTx(ctx context.Context, tx pgx.Tx, args rivertype.JobArgs, opts *rivertype.InsertOpts) (*rivertype.JobInsertResult, error) {
	return &rivertype.JobInsertResult{}, nil
}

func (n *noOpInsertOnly) InsertMany(ctx context.Context, params []rivertype.InsertManyParams) ([]*rivertype.JobInsertResult, error) {
	return nil, nil
}

func (n *noOpInsertOnly) InsertManyTx(ctx context.Context, tx pgx.Tx, params []rivertype.InsertManyParams) ([]*rivertype.JobInsertResult, error) {
	return nil, nil
}

func (n *noOpInsertOnly) InsertManyFast(ctx context.Context, params []rivertype.InsertManyParams) (int, error) {
	return 0, nil
}

func (n *noOpInsertOnly) InsertManyFastTx(ctx context.Context, tx pgx.Tx, params []rivertype.InsertManyParams) (int, error) {
	return 0, nil
}

// newSessionsController creates a Sessions controller with the shared test DB.
func newSessionsController() controllers.Sessions {
	return controllers.NewSessions(testDB.DB, config.Config{
		Auth: config.Auth{Pepper: factories.TestPepper},
	})
}

// newRegistrationsController creates a Registrations controller with the shared test DB
// and a no-op insert-only queue.
func newRegistrationsController() controllers.Registrations {
	return controllers.NewRegistrations(
		testDB.DB,
		&noOpInsertOnly{},
		config.Config{
			Auth: config.Auth{Pepper: factories.TestPepper},
		},
	)
}

// TestSessions_New renders the login form successfully.
func TestSessions_New(t *testing.T) {
	e := echo.New()
	sessions := newSessionsController()

	req := httptest.NewRequest(http.MethodGet, "/sign_in", nil)
	rec := httptest.NewRecorder()
	c := e.NewContext(req, rec)

	err := sessions.New(c)
	if err != nil {
		t.Fatalf("New returned unexpected error: %v", err)
	}

	if c.Response().Status != http.StatusOK {
		t.Errorf("expected status %d, got %d", http.StatusOK, c.Response().Status)
	}
}

// TestSessions_Create_LoginSuccess authenticates a user and creates a session.
func TestSessions_Create_LoginSuccess(t *testing.T) {
	testDB.WithTx(t, func(tx {{if eq .DatabaseType "postgresql"}}pgx.Tx{{else}}*sql.Tx{{end}}) {
		factories.CreateUser(tx,
			factories.WithEmail("alice@example.com"),
			factories.WithValidatedEmail(),
		)

		e := echo.New()
		sessions := newSessionsController()

		body := strings.NewReader(`{"email":"alice@example.com","password":"password123"}`)
		req := httptest.NewRequest(http.MethodPost, "/sign_in", body)
		req.Header.Set(echo.HeaderContentType, echo.MIMEApplicationJSON)
		rec := httptest.NewRecorder()
		c := e.NewContext(req, rec)

		err := sessions.Create(c)
		if err != nil {
			t.Fatalf("Create returned unexpected error: %v", err)
		}

		if c.Response().Status != http.StatusOK {
			t.Errorf("expected status %d (hypermedia redirect), got %d", http.StatusOK, c.Response().Status)
		}
	})
}

