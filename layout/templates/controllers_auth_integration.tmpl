var testDB *database.TestDB

// TestMain initializes a shared TestDB for all auth integration tests.
// Each individual test uses WithTx for transactional rollback isolation.
func TestMain(m *testing.M) {
	var err error
	testDB, err = database.NewTestDB()
	if err != nil {
		panic(err)
	}
	defer testDB.Close()

	m.Run()
}

// newSessionsController creates a Sessions controller with the shared test DB.
func newSessionsController() controllers.Sessions {
	return controllers.NewSessions(testDB.DB, config.NewTestConfig(factories.TestPepper))
}

// newRegistrationsController creates a Registrations controller with the shared test DB
// and an insert-only queue backed by the test database (no workers needed).
func newRegistrationsController() controllers.Registrations {
	wrks := river.NewWorkers()
	insertOnly, err := queue.NewInsertOnly(testDB.DB, wrks)
	if err != nil {
		panic(err)
	}
	return controllers.NewRegistrations(
		testDB.DB,
		insertOnly,
		config.NewTestConfig(factories.TestPepper),
	)
}

// TestSessions_New renders the login form successfully.
func TestSessions_New(t *testing.T) {
	e := echo.New()
	sessions := newSessionsController()

	req := httptest.NewRequest(http.MethodGet, routes.SessionNew.URL(), nil)
	rec := httptest.NewRecorder()
	c := e.NewContext(req, rec)

	err := sessions.New(c)
	if err != nil {
		t.Fatalf("New returned unexpected error: %v", err)
	}

	if c.Response().Status != http.StatusOK {
		t.Errorf("expected status %d, got %d", http.StatusOK, c.Response().Status)
	}
}

// TestSessions_Create_LoginSuccess authenticates a user and creates a session.
func TestSessions_Create_LoginSuccess(t *testing.T) {
	testDB.WithTx(t, func(tx {{if eq .DatabaseType "postgresql"}}pgx.Tx{{else}}*sql.Tx{{end}}) {
		factories.CreateUser(tx,
			factories.WithEmail("alice@example.com"),
			factories.WithValidatedEmail(),
		)

		e := echo.New()
		sessions := newSessionsController()

		body := strings.NewReader(`{"email":"alice@example.com","password":"password123"}`)
		req := httptest.NewRequest(http.MethodPost, routes.SessionCreate.URL(), body)
		req.Header.Set(echo.HeaderContentType, echo.MIMEApplicationJSON)
		rec := httptest.NewRecorder()
		c := e.NewContext(req, rec)

		err := sessions.Create(c)
		if err != nil {
			t.Fatalf("Create returned unexpected error: %v", err)
		}

		if c.Response().Status != http.StatusOK {
			t.Errorf("expected status %d (hypermedia redirect), got %d", http.StatusOK, c.Response().Status)
		}
	})
}

