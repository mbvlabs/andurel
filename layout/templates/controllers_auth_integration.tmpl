// TestRegistrations_Create_Success registers a new user and verifies DB state.
func TestRegistrations_Create_Success(t *testing.T) {
	testDB.WithTx(t, func(tx {{if eq .DatabaseType "postgresql"}}pgx.Tx{{else}}*sql.Tx{{end}}) {
		e := echo.New()
		registrations := newRegistrationsController()

		body := strings.NewReader(`{"email":"dave@example.com","password":"mySecurePass99!","confirmPassword":"mySecurePass99!"}`)
		req := httptest.NewRequest(http.MethodPost, routes.RegistrationCreate.URL(), body)
		req.Header.Set(echo.HeaderContentType, echo.MIMEApplicationJSON)
		rec := httptest.NewRecorder()
		c := e.NewContext(req, rec)

		err := registrations.Create(c)
		if err != nil {
			t.Fatalf("Create returned unexpected error: %v", err)
		}

		if c.Response().Status != http.StatusOK {
			t.Errorf("expected status %d (hypermedia redirect), got %d", http.StatusOK, c.Response().Status)
		}

		// Verify user was created in the database
		var users []models.UserEntity
		tx.NewSelect().Model(&users).Scan(context.Background())

		if len(users) != 1 {
			t.Fatalf("expected 1 user in DB, got %d", len(users))
		}

		if users[0].Email != "dave@example.com" {
			t.Errorf("expected email dave@example.com, got %s", users[0].Email)
		}

		if users[0].HasValidatedEmail() {
			t.Error("newly registered users should not have validated email")
		}

		// Verify password is hashed (not plaintext)
		pwStr := string(users[0].Password)
		if pwStr == "mySecurePass99!" {
			t.Fatal("password should be hashed, not stored as plaintext")
		}
	})
}

