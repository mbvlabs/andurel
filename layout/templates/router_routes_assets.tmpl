package routes

import (
	"fmt"
	"time"

	"{{.ModuleName}}/internal/framework"
)

const (
	AssetsRoutePrefix = "/assets"
	assetsNamePrefix  = "assets"
)

var startTime = time.Now().Unix()

var Robots = framework.NewRouteBuilder("robots").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + "/robots.txt").
	Register()

var Sitemap = framework.NewRouteBuilder("sitemap").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + "/sitemap.xml").
	Register()

{{- if eq .CSSFramework "vanilla"}}
var StyleImport = framework.NewRouteBuilder("css.file").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + "/css/:file").
	Register()
{{- end}}

var Stylesheet = framework.NewRouteBuilder("css.stylesheet").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + fmt.Sprintf("/css/%v/style.css", startTime)).
	Register()

var Scripts = framework.NewRouteBuilder("js.scripts").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + fmt.Sprintf("/js/%v/scripts.js", startTime)).
	Register()

var Script = framework.NewRouteBuilder("js.script").
	SetNamePrefix(assetsNamePrefix).
	SetPath(AssetsRoutePrefix + fmt.Sprintf("/js/%v/:file", startTime)).
	RegisterWithFile()
