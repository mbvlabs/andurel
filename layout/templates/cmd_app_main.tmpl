	"context"
	"encoding/hex"
	"fmt"
	"log/slog"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{.ModuleName}}/config"
	"{{.ModuleName}}/controllers"
	"{{.ModuleName}}/database"
{{- if eq .Inertia "vue"}}
	"{{.ModuleName}}/internal/inertia"
{{- end}}
	"{{.ModuleName}}/internal/server"
	"{{.ModuleName}}/internal/storage"
	"{{.ModuleName}}/queue"
	"{{.ModuleName}}/router"
	"{{.ModuleName}}/telemetry"
	"{{.ModuleName}}/queue/workers"
	"riverqueue.com/riverui"
{{- range .Blueprint.Controllers.SortedDependencies}}
{{- if .ImportPath}}
	"{{.ImportPath}}"
{{- end}}
{{- end}}
{{- range .Blueprint.Main.Imports.Items}}
	"{{.}}"
{{- end}}

{{- if not .Inertia}}
	"github.com/a-h/templ"
{{- end}}
)

var appVersion string

// setupControllers initializes and registers all controllers with the router.
// The comment: 'andurel:controller-registration-point' is used as a marker for automated code generation tools.
// If you remove it or change it, the generator tool may not function correctly. 
// If you decide to move it, ensure it remains in a logical place within a function that passes the correct dependencies to the controllers.
func setupControllers(
{{- range $i, $dep := .Blueprint.Controllers.SortedDependencies}}
	{{$dep.Name}} {{$dep.Type}},
{{- end}}
	insertOnly queue.InsertOnly,
	r *router.Router,
	riverHandler *riverui.Handler,
) error {
{{- if not .Inertia}}
	pagesCache, err := controllers.NewCacheBuilder[templ.Component]().Build()
	if err != nil {
		return err
	}

{{- end}}
	assetsCache, err := controllers.NewCacheBuilder[string]().WithSize(2).Build()
	if err != nil {
		return err
	}

{{- range .Blueprint.Controllers.SortedConstructors}}
	{{.VarName}} := {{.Expression}}
{{- end}}

	if err := r.RegisterAPIRoutes(api); err != nil {
		return err
	}

	if err := r.RegisterAssetsRoutes(assets); err != nil {
		return err
	}

	if err := r.RegisterConfirmationsRoutes(confirmations); err != nil {
		return err
	}

	if err := r.RegisterPagesRoutes(pages); err != nil {
		return err
	}

	if err := r.RegisterResetPasswordsRoutes(resetPasswords); err != nil {
		return err
	}

	if err := r.RegisterSessionsRoutes(sessions); err != nil {
		return err
	}

	if err := r.RegisterRegistrationsRoutes(registrations); err != nil {
		return err
	}

	// andurel:controller-registration-point

	r.RegisterCustomRoutes(
		riverHandler,
		pages.NotFound,
	)

	return nil
}

func setupRouter(
	cfg config.Config,
	tel *telemetry.Telemetry,
) (*router.Router, error) {
	authKey, err := hex.DecodeString(cfg.App.SessionKey)
	if err != nil {
		return nil, err
	}
	encKey, err := hex.DecodeString(cfg.App.SessionEncryptionKey)
	if err != nil {
		return nil, err
	}

	globalMiddleware, err := router.SetupGlobalMiddleware(cfg, tel, authKey, encKey, "_csrf")
	if err != nil {
		return nil, err
	}

	r, err := router.New(
		true,
		globalMiddleware,
	)
	if err != nil {
		return nil, err
	}

	return r, nil
}

func buildTelemetry(cfg config.Config) (*telemetry.Telemetry, error) {
	return telemetry.New(cfg)
}

func run(ctx context.Context) error {
	ctx, cancel := signal.NotifyContext(ctx, os.Interrupt, syscall.SIGTERM)
	defer cancel()

	cfg := config.NewConfig()

{{- if eq .Inertia "vue"}}
	if err := inertia.Init("views/root.go.html", config.InertiaEnableSSR); err != nil {
		return fmt.Errorf("failed to initialize inertia: %w", err)
	}

{{- end}}
	tel, err := buildTelemetry(cfg)
	if err != nil {
		return fmt.Errorf("failed to initialize telemetry: %w", err)
	}
	defer func() {
		shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
		defer cancel()
		if err := tel.Shutdown(shutdownCtx); err != nil {
			slog.Error("telemetry shutdown error", "error", err)
		}
	}()

	if err := tel.HealthCheck(ctx); err != nil {
		slog.Warn("telemetry health check failed", "error", err)
	}


	db, err := database.NewPostgres(ctx, cfg)
	if err != nil {
		return err
	}

{{- range .Blueprint.Controllers.SortedDependencies}}
{{- if .InitExpr}}
	{{.Name}} := {{.InitExpr}}
{{- end}}
{{- end}}

{{- range .Blueprint.Main.SortedInitializations}}
	{{.VarName}} := {{.Expression}}
{{- end}}

	wrks, err := workers.RegisterWorkers(emailClient, emailClient)
	if err != nil {
		return err
	}

	insertOnly, err := queue.NewInsertOnly(
		db,
		wrks,
	)
	if err != nil {
		return err
	}

	processor, err := queue.NewProcessor(
		db,
		wrks,
	)
	if err != nil {
		return err
	}

	go func() {
		if err := processor.Start(ctx); err != nil {
			slog.Error("queue processor error", "error", err)
			cancel()
		}
	}()

{{- range .Blueprint.Main.SortedPreRunHooks}}
	// Pre-run hook: {{.Name}}
	{{.Code}}
{{- end}}

	endpoints := riverui.NewEndpoints(processor.Client, nil)
	opts := &riverui.HandlerOpts{
		Endpoints: endpoints,
		Logger:    slog.Default(),
		Prefix:    "/riverui", // mount the UI and its APIs under /riverui or another path
	}
	riverHandler, err := riverui.NewHandler(opts)
	if err != nil {
		return err
	}

	riverHandler.Start(ctx)

	r, err := setupRouter(cfg, tel)
	if err != nil {
		return err
	}

	err = setupControllers(
{{- range .Blueprint.Controllers.SortedDependencies}}
		{{.Name}},
{{- end}}
		insertOnly,
		r,
		riverHandler,
	)
	if err != nil {
		return err
	}

{{- range .Blueprint.Main.SortedBackgroundWorkers}}
	// Start background worker: {{.Name}}
	go {{.FunctionCall}}
{{- end}}

	server := server.New(
		ctx,
		cfg.App.Host,
		cfg.App.Port,
		config.Env,
		r.Handler,
		[]server.Shutdowner{processor},
	)

	slog.InfoContext(ctx, "starting server", "host", cfg.App.Host, "port", cfg.App.Port)
	return server.Start(ctx, config.Env)
}

func main() {
	ctx := context.Background()
	if err := run(ctx); err != nil {
		fmt.Fprintf(os.Stderr, "%s\n", err)
		os.Exit(1)
	}
}
