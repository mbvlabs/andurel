<!-- Use for short verification codes or one-time passwords. -->
<section class="space-y-4 rounded-box border border-base-300 bg-base-100 p-6">
  <header class="space-y-1">
    <h2 class="text-xl font-semibold">Input OTP</h2>
    <p class="text-sm text-base-content/70">One-time code field.</p>
  </header>

  <div class="field">
    <label for="example-otp" class="field-label">Verification code</label>
    <input id="example-otp" type="text" maxlength="6" class="input-otp" value="841205" />
  </div>
</section>
