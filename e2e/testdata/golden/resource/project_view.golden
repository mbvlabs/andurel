



package views

import (
	"net/http"
	"testapp/internal/hypermedia"
	"testapp/internal/renderer"
	"testapp/models"
	"testapp/router/routes"
)

type ProjectIndex struct {
	Items []models.ProjectEntity
}

func (pi ProjectIndex) PageFragment() string {
	return "project-index-page-fragment"
}

templ (pi ProjectIndex) Page() {
	@base() {
		@templ.Fragment(pi.PageFragment()) {
			<main id="project-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Projects</h1>
						<a href={ routes.ProjectNew.URL() } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">New Project</a>
					</div>
					if len(pi.Items) == 0 {
						<p class="text-sm text-gray-500">No projects found.</p>
					} else {
						<div class="relative w-full overflow-auto">
							<table class="w-full caption-bottom text-sm">
								<thead class="[&_tr]:border-b [&_tr]:border-gray-300">
									<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Name</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Description</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Created At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Updated At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Actions</th>
									</tr>
								</thead>
								<tbody class="[&_tr:last-child]:border-0">
									for _, project := range pi.Items {
										<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ project.Name }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ project.Description }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ project.CreatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ project.UpdatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">
												<div class="flex flex-wrap gap-3 text-sm">
													<a class="text-gray-600 hover:text-gray-900" href={ routes.ProjectShow.URL(project.ID) }>View</a>
													<a class="text-gray-600 hover:text-gray-900" href={ routes.ProjectEdit.URL(project.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}

type ProjectShow struct {
	Item models.ProjectEntity
}

func (ps ProjectShow) PageFragment() string {
	return "project-show-page-fragment"
}

templ (ps ProjectShow) Page() {
	@base() {
		@templ.Fragment(ps.PageFragment()) {
			<main id="project-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Project Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							<a href={ routes.ProjectEdit.URL(ps.Item.ID) } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">Edit</a>
							<a class="text-sm text-gray-600 hover:text-gray-900" href={ renderer.ResolveBackURL(ctx, routes.ProjectIndex.URL()) }>Back to List</a>
						</div>
					</div>
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="p-6 pt-0">
							<div class="grid gap-5 sm:grid-cols-2">
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Name</label>
									<p class="text-sm text-gray-900">{ ps.Item.Name }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Description</label>
									<p class="text-sm text-gray-900">{ ps.Item.Description }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Created At</label>
									<p class="text-sm text-gray-900">{ ps.Item.CreatedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Updated At</label>
									<p class="text-sm text-gray-900">{ ps.Item.UpdatedAt.String() }</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}

type ProjectNew struct{}

func (pn ProjectNew) PageFragment() string {
	return "project-new-page-fragment"
}

templ (pn ProjectNew) Page() {
	@base() {
		@templ.Fragment(pn.PageFragment()) {
			<main id="project-new-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">New Project</h3>
							<p class="text-sm text-gray-500">Enter the details for the new project.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.ProjectCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name"/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="description">Description</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="description"/>
										</div>
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Create Project</button>
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ renderer.ResolveBackURL(ctx, routes.ProjectIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</div>
			</main>
		}
	}
}

type ProjectEdit struct {
	Item models.ProjectEntity
}

func (pe ProjectEdit) PageFragment() string {
	return "project-edit-page-fragment"
}

templ (pe ProjectEdit) Page() {
	@base() {
		@templ.Fragment(pe.PageFragment()) {
			<main id="project-edit-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">Edit Project</h3>
							<p class="text-sm text-gray-500">Update the details for this project.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.ProjectUpdate.URL(pe.Item.ID)) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name" value={ pe.Item.Name }/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="description">Description</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="description" value={ pe.Item.Description }/>
										</div>
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Update Project</button>
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ renderer.ResolveBackURL(ctx, routes.ProjectIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
							<div role="separator" class="my-6 shrink-0 bg-gray-300 h-px w-full"></div>
							<button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-red-600 text-white shadow-sm hover:bg-red-700 h-9 px-4 py-2 text-sm rounded w-full" data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.ProjectDestroy.URL(pe.Item.ID)) }>Destroy Project</button>
						</div>
					</div>
				</div>
			</main>
		}
	}
}
