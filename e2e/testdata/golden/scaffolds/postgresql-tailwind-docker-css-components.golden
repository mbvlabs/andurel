/* Shared base for text-like form controls. */
@utility input-base {
	@apply flex w-full rounded-sm border bg-background px-3 py-1 text-sm text-foreground shadow-inner transition placeholder:text-muted-foreground focus:outline-none focus:ring-2 disabled:cursor-not-allowed disabled:opacity-60;
}

/* Default border and focus treatment for valid controls. */
@utility control-default {
	@apply border border-input focus:border-primary focus:ring-ring;
}

/* Error border and focus treatment for invalid controls. */
@utility control-error {
	@apply border border-error focus:border-error focus:ring-error/50;
}

/* Shared label typography and disabled-peer handling. */
@utility label-base {
	@apply text-sm font-medium leading-none text-muted-foreground peer-disabled:cursor-not-allowed peer-disabled:opacity-60;
}

/* Reusable hoverable row or action item surface. */
@utility interactive-item {
	@apply rounded-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring;
}

/* Standard bordered panel surface used by cards and containers. */
@utility panel-base {
	@apply rounded-lg border border-outline bg-card text-card-foreground;
}

/* Shared close-button treatment for dismissible overlays. */
@utility overlay-close {
	@apply cursor-pointer rounded-sm p-0.5 opacity-70 transition-opacity hover:opacity-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring;
}

/* Shared floating popup panel anchored below a trigger. */
@utility popup-base {
	@apply absolute left-0 top-full z-40 mt-2 rounded-lg border border-outline bg-popover text-popover-foreground shadow-lg;
}

/* Success feedback text and border styling. */
@utility status-success {
	@apply border-success/40 text-success;
}

/* Warning feedback text and border styling. */
@utility status-warning {
	@apply border-warning/40 text-warning;
}

/* Error feedback text and border styling. */
@utility status-error {
	@apply border-error/40 text-error;
}

/* Stronger destructive feedback surface for dangerous actions. */
@utility status-destructive {
	@apply border-error bg-error text-error-foreground;
}

/* Shared checkbox and radio sizing, focus, and disabled state. */
@utility checkable-base {
	@apply h-4 w-4 border border-input text-primary focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-60;
}

/* Shared switch-like control focus and disabled behavior. */
@utility toggle-base {
	@apply transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-60;
}
