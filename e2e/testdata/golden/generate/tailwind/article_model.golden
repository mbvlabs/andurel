package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// ArticleEntity represents a Article record in the database.
type ArticleEntity struct {
	bun.BaseModel `bun:"table:articles"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	Title         string     `bun:"title"`
	Content       *string    `bun:"content"`
	Published     *bool      `bun:"published"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (a article) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (ArticleEntity, error) {
	var entity ArticleEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return ArticleEntity{}, err
	}
	return entity, nil
}

type CreateArticleData struct {
	Title     string
	Content   *string
	Published *bool
}

func (a article) Create(ctx context.Context, db storage.Executor, data CreateArticleData) (ArticleEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ArticleEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ArticleEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Content:   data.Content,
		Published: data.Published,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return ArticleEntity{}, err
	}
	return entity, nil
}

type UpdateArticleData struct {
	ID        uuid.UUID
	Title     string
	Content   *string
	Published *bool
	UpdatedAt *time.Time
}

func (a article) Update(ctx context.Context, db storage.Executor, data UpdateArticleData) (ArticleEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ArticleEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ArticleEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Content:   data.Content,
		Published: data.Published,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return ArticleEntity{}, err
	}
	return entity, nil
}

func (a article) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*ArticleEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (a article) All(ctx context.Context, db storage.Executor) ([]ArticleEntity, error) {
	var entities []ArticleEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedArticles struct {
	Articles   []ArticleEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (a article) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedArticles, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&ArticleEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedArticles{}, err
	}

	var entities []ArticleEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedArticles{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedArticles{
		Articles:   entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (a article) Upsert(ctx context.Context, db storage.Executor, data CreateArticleData) (ArticleEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ArticleEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ArticleEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Content:   data.Content,
		Published: data.Published,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return ArticleEntity{}, err
	}
	return entity, nil
}
