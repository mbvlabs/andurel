package factories

import (
	"context"
	"database/sql"
	"fmt"
	"time"

	"testapp/internal/storage"
	"testapp/models"

	"github.com/go-faker/faker/v4"
	"github.com/google/uuid"
)

// BookFactory wraps models.BookEntity for testing
type BookFactory struct {
	models.BookEntity
}

type BookOption func(*BookFactory)

// BuildBook creates an in-memory Book with default test values.
// Auto-managed fields (ID, timestamps) are left at zero and set by CreateBook.
func BuildBook(opts ...BookOption) models.BookEntity {
	f := &BookFactory{
		BookEntity: models.BookEntity{
			Title:  faker.Word(),
			Author: faker.Word(),
			Price:  sql.NullFloat64{Float64: float64(randomInt(1, 1000, 100)), Valid: true},
			Pages:  sql.NullInt32{Int32: randomInt(1, 1000, 100), Valid: true},
		},
	}

	for _, opt := range opts {
		opt(f)
	}

	return f.BookEntity
}

// CreateBook creates and persists a Book to the database.
// It returns the entity populated with all DB-assigned values via RETURNING *.
func CreateBook(ctx context.Context, exec storage.Executor, opts ...BookOption) (models.BookEntity, error) {
	built := BuildBook(opts...)

	entity := models.BookEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     built.Title,
		Author:    built.Author,
		Price:     built.Price,
		Pages:     built.Pages,
	}

	if err := exec.NewInsert().Model(&entity).Returning("*").Scan(ctx); err != nil {
		return models.BookEntity{}, err
	}

	return entity, nil
}

// CreateBooks creates multiple Book records at once
func CreateBooks(ctx context.Context, exec storage.Executor, count int, opts ...BookOption) ([]models.BookEntity, error) {
	books := make([]models.BookEntity, 0, count)

	for i := 0; i < count; i++ {
		entity, err := CreateBook(ctx, exec, opts...)
		if err != nil {
			return nil, fmt.Errorf("failed to create book %d: %w", i+1, err)
		}
		books = append(books, entity)
	}

	return books, nil
}

// Option functions

// WithBooksTitle sets the Title field
func WithBooksTitle(value string) BookOption {
	return func(f *BookFactory) {
		f.BookEntity.Title = value
	}
}

// WithBooksAuthor sets the Author field
func WithBooksAuthor(value string) BookOption {
	return func(f *BookFactory) {
		f.BookEntity.Author = value
	}
}

// WithBooksPrice sets the Price field
func WithBooksPrice(value sql.NullFloat64) BookOption {
	return func(f *BookFactory) {
		f.BookEntity.Price = value
	}
}

// WithBooksPages sets the Pages field
func WithBooksPages(value sql.NullInt32) BookOption {
	return func(f *BookFactory) {
		f.BookEntity.Pages = value
	}
}
