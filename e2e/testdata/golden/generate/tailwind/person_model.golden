package models

import (
	"context"
	"database/sql"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

type PersonEntity struct {
	bun.BaseModel `bun:"table:people_data,alias:people_data"`
	ID            uuid.UUID      `bun:"id,pk,type:uuid"`
	FirstName     string         `bun:"first_name"`
	LastName      string         `bun:"last_name"`
	Email         sql.NullString `bun:"email"`
	CreatedAt     sql.NullTime   `bun:"created_at"`
	UpdatedAt     sql.NullTime   `bun:"updated_at"`
}

func (p person) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (PersonEntity, error) {
	var entity PersonEntity
	if err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx); err != nil {
		return PersonEntity{}, err
	}

	return entity, nil
}

type CreatePersonData struct {
	FirstName string
	LastName  string
	Email     sql.NullString
}

func (p person) Create(ctx context.Context, db storage.Executor, data CreatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	if _, err := db.NewInsert().Model(&entity).Exec(ctx); err != nil {
		return Person{}, err
	}

	return entity, nil
}

type UpdatePersonData struct {
	ID        uuid.UUID
	FirstName string
	LastName  string
	Email     sql.NullString
	UpdatedAt sql.NullTime
}

func (p person) Update(ctx context.Context, db storage.Executor, data UpdatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	if err := db.NewUpdate().
		Model(&entity).
		Column("first_name").
		Column("last_name").
		Column("email").
		Column("updated_at").
		WherePK().
		Returning("*").
		Scan(ctx); err != nil {
		return PersonEntity{}, err
	}

	return entity, nil
}

func (p person) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*PersonEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)

	return err
}

func (p person) All(ctx context.Context, db storage.Executor) ([]PersonEntity, error) {
	var entities []PersonEntity
	if err := db.NewSelect().
		Model(&entities).
		Scan(ctx); err != nil {
		return nil, err
	}

	return entities, nil
}

type PaginatedPerson struct {
	Person     []PersonEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (p person) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedPerson, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	totalCount, err := db.NewSelect().
		Model(&PersonEntity{}).Count(ctx)
	if err != nil {
		return PaginatedPerson{}, err
	}

	var entities []PersonEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedPerson{}, err
	}

	totalPages := (int64(totalCount) + pageSize - 1) / pageSize

	return PaginatedPerson{
		Person:     entities,
		TotalCount: int64(totalCount),
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (p person) Upsert(ctx context.Context, db storage.Executor, data CreatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	if err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Set("first_name = excluded.first_name").
		Set("last_name = excluded.last_name").
		Set("email = excluded.email").
		Returning("*").
		Scan(ctx); err != nil {
		return PersonEntity{}, err
	}

	return entity, nil
}
