package models

import (
	"context"
	"database/sql"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

type StudentFeedbackEntity struct {
	bun.BaseModel `bun:"table:student_feedback,alias:student_feedback"`
	ID            uuid.UUID     `bun:"id,pk,type:uuid"`
	StudentID     string        `bun:"student_id"`
	Feedback      string        `bun:"feedback"`
	Rating        sql.NullInt32 `bun:"rating"`
	CreatedAt     sql.NullTime  `bun:"created_at"`
	UpdatedAt     sql.NullTime  `bun:"updated_at"`
}

func (sf studentFeedback) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (StudentFeedbackEntity, error) {
	var entity StudentFeedbackEntity
	if err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx); err != nil {
		return StudentFeedbackEntity{}, err
	}

	return entity, nil
}

type CreateStudentFeedbackData struct {
	StudentID string
	Feedback  string
	Rating    sql.NullInt32
}

func (sf studentFeedback) Create(ctx context.Context, db storage.Executor, data CreateStudentFeedbackData) (StudentFeedbackEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return StudentFeedbackEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := StudentFeedbackEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		StudentID: data.StudentID,
		Feedback:  data.Feedback,
		Rating:    data.Rating,
	}

	if _, err := db.NewInsert().Model(&entity).Exec(ctx); err != nil {
		return StudentFeedbackEntity{}, err
	}

	return entity, nil
}

type UpdateStudentFeedbackData struct {
	ID        uuid.UUID
	StudentID string
	Feedback  string
	Rating    sql.NullInt32
	UpdatedAt sql.NullTime
}

func (sf studentFeedback) Update(ctx context.Context, db storage.Executor, data UpdateStudentFeedbackData) (StudentFeedbackEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return StudentFeedbackEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := StudentFeedbackEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		StudentID: data.StudentID,
		Feedback:  data.Feedback,
		Rating:    data.Rating,
	}

	if err := db.NewUpdate().
		Model(&entity).
		Column("student_id").
		Column("feedback").
		Column("rating").
		Column("updated_at").
		WherePK().
		Returning("*").
		Scan(ctx); err != nil {
		return StudentFeedbackEntity{}, err
	}

	return entity, nil
}

func (sf studentFeedback) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*StudentFeedbackEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)

	return err
}

func (sf studentFeedback) All(ctx context.Context, db storage.Executor) ([]StudentFeedbackEntity, error) {
	var entities []StudentFeedbackEntity
	if err := db.NewSelect().
		Model(&entities).
		Scan(ctx); err != nil {
		return nil, err
	}

	return entities, nil
}

type PaginatedStudentFeedback struct {
	StudentFeedback []StudentFeedbackEntity
	TotalCount      int64
	Page            int64
	PageSize        int64
	TotalPages      int64
}

func (sf studentFeedback) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedStudentFeedback, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	totalCount, err := db.NewSelect().
		Model(&StudentFeedbackEntity{}).Count(ctx)
	if err != nil {
		return PaginatedStudentFeedback{}, err
	}

	var entities []StudentFeedbackEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedStudentFeedback{}, err
	}

	totalPages := (int64(totalCount) + pageSize - 1) / pageSize

	return PaginatedStudentFeedback{
		StudentFeedback: entities,
		TotalCount:      int64(totalCount),
		Page:            page,
		PageSize:        pageSize,
		TotalPages:      totalPages,
	}, nil
}

func (sf studentFeedback) Upsert(ctx context.Context, db storage.Executor, data CreateStudentFeedbackData) (StudentFeedbackEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return StudentFeedbackEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := StudentFeedbackEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		StudentID: data.StudentID,
		Feedback:  data.Feedback,
		Rating:    data.Rating,
	}

	if err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Set("student_id = excluded.student_id").
		Set("feedback = excluded.feedback").
		Set("rating = excluded.rating").
		Returning("*").
		Scan(ctx); err != nil {
		return StudentFeedbackEntity{}, err
	}

	return entity, nil
}
