package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// BookEntity represents a Book record in the database.
type BookEntity struct {
	bun.BaseModel `bun:"table:books"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	Title         string     `bun:"title"`
	Author        string     `bun:"author"`
	Price         *float64   `bun:"price"`
	Pages         *int32     `bun:"pages"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (b book) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (BookEntity, error) {
	var entity BookEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return BookEntity{}, err
	}
	return entity, nil
}

type CreateBookData struct {
	Title  string
	Author string
	Price  *float64
	Pages  *int32
}

func (b book) Create(ctx context.Context, db storage.Executor, data CreateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return BookEntity{}, err
	}
	return entity, nil
}

type UpdateBookData struct {
	ID        uuid.UUID
	Title     string
	Author    string
	Price     *float64
	Pages     *int32
	UpdatedAt *time.Time
}

func (b book) Update(ctx context.Context, db storage.Executor, data UpdateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return BookEntity{}, err
	}
	return entity, nil
}

func (b book) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*BookEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (b book) All(ctx context.Context, db storage.Executor) ([]BookEntity, error) {
	var entities []BookEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedBooks struct {
	Books      []BookEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (b book) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedBooks, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&BookEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedBooks{}, err
	}

	var entities []BookEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedBooks{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedBooks{
		Books:      entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (b book) Upsert(ctx context.Context, db storage.Executor, data CreateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return BookEntity{}, err
	}
	return entity, nil
}
