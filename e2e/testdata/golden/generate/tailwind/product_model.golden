package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// ProductEntity represents a Product record in the database.
type ProductEntity struct {
	bun.BaseModel `bun:"table:products"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	Name          string     `bun:"name"`
	Price         *float64   `bun:"price"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (p product) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (ProductEntity, error) {
	var entity ProductEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return ProductEntity{}, err
	}
	return entity, nil
}

type CreateProductData struct {
	Name  string
	Price *float64
}

func (p product) Create(ctx context.Context, db storage.Executor, data CreateProductData) (ProductEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ProductEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ProductEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Name:      data.Name,
		Price:     data.Price,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return ProductEntity{}, err
	}
	return entity, nil
}

type UpdateProductData struct {
	ID        uuid.UUID
	Name      string
	Price     *float64
	UpdatedAt *time.Time
}

func (p product) Update(ctx context.Context, db storage.Executor, data UpdateProductData) (ProductEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ProductEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ProductEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		Name:      data.Name,
		Price:     data.Price,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return ProductEntity{}, err
	}
	return entity, nil
}

func (p product) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*ProductEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (p product) All(ctx context.Context, db storage.Executor) ([]ProductEntity, error) {
	var entities []ProductEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedProducts struct {
	Products   []ProductEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (p product) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedProducts, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&ProductEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedProducts{}, err
	}

	var entities []ProductEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedProducts{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedProducts{
		Products:   entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (p product) Upsert(ctx context.Context, db storage.Executor, data CreateProductData) (ProductEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ProductEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ProductEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Name:      data.Name,
		Price:     data.Price,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return ProductEntity{}, err
	}
	return entity, nil
}
