package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// ItemEntity represents a Item record in the database.
type ItemEntity struct {
	bun.BaseModel `bun:"table:items"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	WarehouseID   *uuid.UUID `bun:"warehouse_id,type:uuid"`
	Name          string     `bun:"name"`
	Quantity      *int32     `bun:"quantity"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (i item) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (ItemEntity, error) {
	var entity ItemEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return ItemEntity{}, err
	}
	return entity, nil
}

type CreateItemData struct {
	WarehouseID *uuid.UUID
	Name        string
	Quantity    *int32
}

func (i item) Create(ctx context.Context, db storage.Executor, data CreateItemData) (ItemEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ItemEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ItemEntity{
		ID:          uuid.New(),
		CreatedAt:   time.Now(),
		UpdatedAt:   time.Now(),
		WarehouseID: data.WarehouseID,
		Name:        data.Name,
		Quantity:    data.Quantity,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return ItemEntity{}, err
	}
	return entity, nil
}

type UpdateItemData struct {
	ID          uuid.UUID
	WarehouseID *uuid.UUID
	Name        string
	Quantity    *int32
	UpdatedAt   *time.Time
}

func (i item) Update(ctx context.Context, db storage.Executor, data UpdateItemData) (ItemEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ItemEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ItemEntity{
		ID:          data.ID,
		UpdatedAt:   time.Now(),
		WarehouseID: data.WarehouseID,
		Name:        data.Name,
		Quantity:    data.Quantity,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return ItemEntity{}, err
	}
	return entity, nil
}

func (i item) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*ItemEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (i item) All(ctx context.Context, db storage.Executor) ([]ItemEntity, error) {
	var entities []ItemEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedItems struct {
	Items      []ItemEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (i item) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedItems, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&ItemEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedItems{}, err
	}

	var entities []ItemEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedItems{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedItems{
		Items:      entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (i item) Upsert(ctx context.Context, db storage.Executor, data CreateItemData) (ItemEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return ItemEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := ItemEntity{
		ID:          uuid.New(),
		CreatedAt:   time.Now(),
		UpdatedAt:   time.Now(),
		WarehouseID: data.WarehouseID,
		Name:        data.Name,
		Quantity:    data.Quantity,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return ItemEntity{}, err
	}
	return entity, nil
}
