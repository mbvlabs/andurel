



package views

import (
	"fmt"
	"net/http"

	"testapp/internal/hypermedia"
	"testapp/models"

	"testapp/router/routes"
)

type ItemIndex struct {
	Items []models.ItemEntity
}

func (ii ItemIndex) PageFragment() string {
	return "item-index-page-fragment"
}

templ (ii ItemIndex) Page() {
	@base() {
		@templ.Fragment(ii.PageFragment()) {
			<main id="item-index-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Items</h1>
						<a href={ routes.ItemNew.URL() } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">New Item</a>
					</div>
					if len(ii.Items) == 0 {
						<p class="text-sm text-gray-500">No items found.</p>
					} else {
						<div class="relative w-full overflow-auto">
							<table class="w-full caption-bottom text-sm">
								<thead class="[&_tr]:border-b [&_tr]:border-gray-300">
									<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Warehouse Id</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Name</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Quantity</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Created At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Updated At</th>
										<th class="h-10 px-4 text-left align-middle font-medium text-gray-500 [&:has([role=checkbox])]:pr-0">Actions</th>
									</tr>
								</thead>
								<tbody class="[&_tr:last-child]:border-0">
									for _, item := range ii.Items {
										<tr class="border-b border-gray-300 transition-colors hover:bg-gray-100">
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ item.WarehouseID.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ item.Name }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ fmt.Sprintf("%d", item.Quantity) }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ item.CreatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">{ item.UpdatedAt.String() }</td>
											<td class="p-4 align-middle [&:has([role=checkbox])]:pr-0">
												<div class="flex flex-wrap gap-3 text-sm">
													<a class="text-gray-600 hover:text-gray-900" href={ routes.ItemShow.URL(item.ID) }>View</a>
													<a class="text-gray-600 hover:text-gray-900" href={ routes.ItemEdit.URL(item.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</div>
			</main>
		}
	}
}

type ItemShow struct {
	Item models.ItemEntity
}

func (is ItemShow) PageFragment() string {
	return "item-show-page-fragment"
}

templ (is ItemShow) Page() {
	@base() {
		@templ.Fragment(is.PageFragment()) {
			<main id="item-show-container" class="flex-1 px-6 py-10">
				<div class="mx-auto flex w-full max-w-4xl flex-col gap-6">
					<div class="flex flex-wrap items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-gray-900">Item Details</h1>
						<div class="flex flex-wrap items-center gap-3">
							<a href={ routes.ItemEdit.URL(is.Item.ID) } class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded">Edit</a>
							<a class="text-sm text-gray-600 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.ItemIndex.URL()) }>Back to List</a>
						</div>
					</div>
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="p-6 pt-0">
							<div class="grid gap-5 sm:grid-cols-2">
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Warehouse Id</label>
									<p class="text-sm text-gray-900">{ is.Item.WarehouseID.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Name</label>
									<p class="text-sm text-gray-900">{ is.Item.Name }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Quantity</label>
									<p class="text-sm text-gray-900">{ fmt.Sprintf("%d", is.Item.Quantity) }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Created At</label>
									<p class="text-sm text-gray-900">{ is.Item.CreatedAt.String() }</p>
								</div>
								<div class="space-y-1">
									<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60">Updated At</label>
									<p class="text-sm text-gray-900">{ is.Item.UpdatedAt.String() }</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</main>
		}
	}
}

type ItemNew struct{}

func (in ItemNew) PageFragment() string {
	return "item-new-page-fragment"
}

templ (in ItemNew) Page() {
	@base() {
		@templ.Fragment(in.PageFragment()) {
			<main id="item-new-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">New Item</h3>
							<p class="text-sm text-gray-500">Enter the details for the new item.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.ItemCreate.URL()) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="warehouseId">Warehouse Id</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="warehouseId"/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name"/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="quantity">Quantity</label>
											<input type="number" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="quantity"/>
										</div>
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Create Item</button>
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.ItemIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</div>
			</main>
		}
	}
}

type ItemEdit struct {
	Item models.ItemEntity
}

func (ie ItemEdit) PageFragment() string {
	return "item-edit-page-fragment"
}

templ (ie ItemEdit) Page() {
	@base() {
		@templ.Fragment(ie.PageFragment()) {
			<main id="item-edit-container" class="flex-1 flex items-center justify-center px-6 py-10">
				<div class="mx-auto flex w-full max-w-md flex-col gap-6">
					<div class="rounded-lg border border-gray-300 bg-white shadow-sm">
						<div class="flex flex-col space-y-1.5 p-6">
							<h3 class="text-lg font-semibold leading-none text-gray-900">Edit Item</h3>
							<p class="text-sm text-gray-500">Update the details for this item.</p>
						</div>
						<div class="p-6 pt-0">
							<form class="space-y-5" data-indicator:_submitting data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.ItemUpdate.URL(ie.Item.ID)) }>
								<fieldset data-attr:disabled="$_submitting">
									<div class="space-y-4">
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="warehouseId">Warehouse Id</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="warehouseId" value={ ie.Item.WarehouseID.String() }/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="name">Name</label>
											<input type="text" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="name" value={ ie.Item.Name }/>
										</div>
										<div class="space-y-1">
											<label class="text-sm font-medium leading-none text-gray-700 peer-disabled:cursor-not-allowed peer-disabled:opacity-60" for="quantity">Quantity</label>
											<input type="number" class="flex h-9 w-full rounded border bg-gray-50 px-3 py-1 text-sm text-gray-900 shadow-inner transition placeholder:text-gray-400 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 disabled:cursor-not-allowed disabled:opacity-60 border-gray-300" data-bind="quantity" value={ fmt.Sprintf("%d", ie.Item.Quantity) }/>
										</div>
									</div>
									<div class="mt-6 space-y-3">
										<button type="submit" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-blue-600 text-white shadow-sm hover:bg-blue-700 h-9 px-4 py-2 text-sm rounded w-full">Update Item</button>
										<a class="inline-flex h-9 w-full items-center justify-center rounded border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600 transition hover:bg-gray-100 hover:text-gray-900" href={ hypermedia.ResolveBackURL(ctx, routes.ItemIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
							<div role="separator" class="my-6 shrink-0 bg-gray-300 h-px w-full"></div>
							<button type="button" class="inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/50 disabled:opacity-60 disabled:cursor-not-allowed bg-red-600 text-white shadow-sm hover:bg-red-700 h-9 px-4 py-2 text-sm rounded w-full" data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.ItemDestroy.URL(ie.Item.ID)) }>Destroy Item</button>
						</div>
					</div>
				</div>
			</main>
		}
	}
}
