package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// PostEntity represents a Post record in the database.
type PostEntity struct {
	bun.BaseModel `bun:"table:posts"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	Title         string     `bun:"title"`
	Tags          []string   `bun:"tags"`
	Scores        []int32    `bun:"scores"`
	Settings      []byte     `bun:"settings,type:jsonb"`
	Metadata      []byte     `bun:"metadata"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (p post) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (PostEntity, error) {
	var entity PostEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return PostEntity{}, err
	}
	return entity, nil
}

type CreatePostData struct {
	Title    string
	Tags     []string
	Scores   []int32
	Settings []byte
	Metadata []byte
}

func (p post) Create(ctx context.Context, db storage.Executor, data CreatePostData) (PostEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PostEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PostEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Tags:      data.Tags,
		Scores:    data.Scores,
		Settings:  data.Settings,
		Metadata:  data.Metadata,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return PostEntity{}, err
	}
	return entity, nil
}

type UpdatePostData struct {
	ID        uuid.UUID
	Title     string
	Tags      []string
	Scores    []int32
	Settings  []byte
	Metadata  []byte
	UpdatedAt *time.Time
}

func (p post) Update(ctx context.Context, db storage.Executor, data UpdatePostData) (PostEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PostEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PostEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Tags:      data.Tags,
		Scores:    data.Scores,
		Settings:  data.Settings,
		Metadata:  data.Metadata,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return PostEntity{}, err
	}
	return entity, nil
}

func (p post) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*PostEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (p post) All(ctx context.Context, db storage.Executor) ([]PostEntity, error) {
	var entities []PostEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedPosts struct {
	Posts      []PostEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (p post) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedPosts, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&PostEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedPosts{}, err
	}

	var entities []PostEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedPosts{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedPosts{
		Posts:      entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (p post) Upsert(ctx context.Context, db storage.Executor, data CreatePostData) (PostEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PostEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PostEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Tags:      data.Tags,
		Scores:    data.Scores,
		Settings:  data.Settings,
		Metadata:  data.Metadata,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return PostEntity{}, err
	}
	return entity, nil
}
