package controllers

import (
	"testapp/internal/renderer"
	"testapp/router/cookies"

	"github.com/a-h/templ"
	"github.com/labstack/echo/v5"
)

type Items struct {
	db interface{ Conn() any }
}

func NewItems() Items {
	return Items{}
}

func render(etx echo.Context, t templ.Component) error {
	return renderer.Render(
		etx,
		t,
		[]renderer.CookieKey{
			cookies.AppKey,
			cookies.FlashKey,
		},
	)
}

func (i Items) Index(etx echo.Context) error {
	return render(etx, ItemIndex())
}

func (i Items) Show(etx echo.Context) error {
	return render(etx, ItemShow())
}

func (i Items) New(etx echo.Context) error {
	return render(etx, ItemNew())
}

func (i Items) Create(etx echo.Context) error {
	return render(etx, ItemCreate())
}

func (i Items) Edit(etx echo.Context) error {
	return render(etx, ItemEdit())
}

func (i Items) Update(etx echo.Context) error {
	return render(etx, ItemUpdate())
}

func (i Items) Destroy(etx echo.Context) error {
	return render(etx, ItemDestroy())
}
