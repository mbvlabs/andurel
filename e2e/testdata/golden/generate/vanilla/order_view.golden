package views

import (
	"fmt"
	"net/http"
	"testapp/internal/hypermedia"
	"testapp/internal/renderer"
	"testapp/models"
	"testapp/router/routes"
)

templ OrderIndex(orders []models.Order) {
	@base() {
		<main class="flex-1 px-6 py-10">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Orders</h1>
						<p class="muted">Manage your orders with the shared vanilla component system.</p>
					</div>
					<a class="btn btn-primary" href={ routes.OrderNew.URL() }>New Order</a>
				</div>
				if len(orders) == 0 {
					<section class="panel empty-state">
						<div class="stack text-center" data-gap="sm">
							<h2 class="empty-state-title">No orders found</h2>
							<p class="empty-state-description">Create your first order to start filling this view.</p>
						</div>
						<div class="empty-state-actions">
							<a class="btn btn-primary" href={ routes.OrderNew.URL() }>New Order</a>
						</div>
					</section>
				} else {
					<div class="panel table-wrap">
						<table class="table">
							<thead>
								<tr>
									<th>Account Id</th>
									<th>Customer Name</th>
									<th>Total</th>
									<th>Signature</th>
									<th>Created At</th>
									<th>Updated At</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								for _, order := range orders {
									<tr>
										<td>{ order.AccountID.String() }</td>
										<td>{ order.CustomerName }</td>
										<td>{ fmt.Sprintf("%f", order.Total) }</td>
										<td>{ string(order.Signature) }</td>
										<td>{ order.CreatedAt.String() }</td>
										<td>{ order.UpdatedAt.String() }</td>
										<td>
											<div class="cluster" data-gap="sm">
												<a class="btn btn-ghost btn-sm" href={ routes.OrderShow.URL(order.ID) }>View</a>
												<a class="btn btn-outline btn-sm" href={ routes.OrderEdit.URL(order.ID) }>Edit</a>
											</div>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</section>
		</main>
	}
}

templ OrderShow(order models.Order) {
	@base() {
		<main class="flex-1 px-6 py-10">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Order Details</h1>
						<p class="muted">Review the current values stored for this order.</p>
					</div>
					<div class="cluster" data-gap="sm">
						<a class="btn btn-primary" href={ routes.OrderEdit.URL(order.ID) }>Edit</a>
						<a class="btn btn-outline" href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
					</div>
				</div>
				<div class="panel">
					<div class="grid-auto-fit" data-grid="compact">
						<div class="field">
							<p class="field-label">Account Id</p>
							<p>{ order.AccountID.String() }</p>
						</div>
						<div class="field">
							<p class="field-label">Customer Name</p>
							<p>{ order.CustomerName }</p>
						</div>
						<div class="field">
							<p class="field-label">Total</p>
							<p>{ fmt.Sprintf("%f", order.Total) }</p>
						</div>
						<div class="field">
							<p class="field-label">Signature</p>
							<p>{ string(order.Signature) }</p>
						</div>
						<div class="field">
							<p class="field-label">Created At</p>
							<p>{ order.CreatedAt.String() }</p>
						</div>
						<div class="field">
							<p class="field-label">Updated At</p>
							<p>{ order.UpdatedAt.String() }</p>
						</div>
					</div>
				</div>
			</section>
		</main>
	}
}

templ OrderNew() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">New Order</h1>
						<p class="card-description">Enter the details for the new order.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting &&" + hypermedia.DataAction(http.MethodPost, routes.OrderCreate.URL()) }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="accountId">Account Id</label>
									<div class="field-control">
										<input class="input" type="text" id="accountId" name="accountId" data-bind="accountId"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="customerName">Customer Name</label>
									<div class="field-control">
										<input class="input" type="text" id="customerName" name="customerName" data-bind="customerName"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="total">Total</label>
									<div class="field-control">
										<input class="input" type="number" id="total" name="total" data-bind="total"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="signature">Signature</label>
									<div class="field-control">
										<input class="input" type="text" id="signature" name="signature" data-bind="signature"/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Create Order</button>
									<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}

templ OrderEdit(order models.Order) {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Edit Order</h1>
						<p class="card-description">Update the details for this order.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting &&" + hypermedia.DataAction(http.MethodPut, routes.OrderUpdate.URL(order.ID)) }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="accountId">Account Id</label>
									<div class="field-control">
										<input class="input" type="text" id="accountId" name="accountId" data-bind="accountId" value={ order.AccountID.String() }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="customerName">Customer Name</label>
									<div class="field-control">
										<input class="input" type="text" id="customerName" name="customerName" data-bind="customerName" value={ order.CustomerName }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="total">Total</label>
									<div class="field-control">
										<input class="input" type="number" id="total" name="total" data-bind="total" value={ fmt.Sprintf("%f", order.Total) }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="signature">Signature</label>
									<div class="field-control">
										<input class="input" type="text" id="signature" name="signature" data-bind="signature" value={ string(order.Signature) }/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Update Order</button>
									<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
					<div class="card-footer">
						<button
							class="btn btn-destructive btn-block"
							type="button"
							data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.OrderDestroy.URL(order.ID)) }
						>Destroy Order</button>
					</div>
				</div>
			</section>
		</main>
	}
}
