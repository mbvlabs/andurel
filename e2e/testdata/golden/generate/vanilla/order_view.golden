



package views

import (
	"fmt"
	"net/http"
	"testapp/internal/hypermedia"
	"testapp/internal/renderer"
	"testapp/models"
	"testapp/router/routes"
)

type OrderIndex struct {
	Items []models.OrderEntity
}

func (oi OrderIndex) PageFragment() string {
	return "order-index-page-fragment"
}

templ (oi OrderIndex) Page() {
	@base() {
		@templ.Fragment(oi.PageFragment()) {
			<main id="order-index-container">
				<section>
					<div>
						<div>
							<h1>Orders</h1>
						</div>
						<a href={ routes.OrderNew.URL() }>New Order</a>
					</div>
					if len(oi.Items) == 0 {
						<section>
							<div>
								<h2>No orders found</h2>
							</div>
							<div>
								<a href={ routes.OrderNew.URL() }>New Order</a>
							</div>
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										<th>Account Id</th>
										<th>Customer Name</th>
										<th>Total</th>
										<th>Signature</th>
										<th>Created At</th>
										<th>Updated At</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, order := range oi.Items {
										<tr>
											<td>{ order.AccountID.String() }</td>
											<td>{ order.CustomerName }</td>
											<td>{ fmt.Sprintf("%f", order.Total) }</td>
											<td>{ string(order.Signature) }</td>
											<td>{ order.CreatedAt.String() }</td>
											<td>{ order.UpdatedAt.String() }</td>
											<td>
												<div>
													<a href={ routes.OrderShow.URL(order.ID) }>View</a>
													<a href={ routes.OrderEdit.URL(order.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}

type OrderShow struct {
	Item models.OrderEntity
}

func (os OrderShow) PageFragment() string {
	return "order-show-page-fragment"
}

templ (os OrderShow) Page() {
	@base() {
		@templ.Fragment(os.PageFragment()) {
			<main id="order-show-container">
				<section>
					<div>
						<div>
							<h1>Order Details</h1>
						</div>
						<div>
							<a href={ routes.OrderEdit.URL(os.Item.ID) }>Edit</a>
							<a href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
						</div>
					</div>
					<div>
						<div>
							<div>
								<p>Account Id</p>
								<p>{ os.Item.AccountID.String() }</p>
							</div>
							<div>
								<p>Customer Name</p>
								<p>{ os.Item.CustomerName }</p>
							</div>
							<div>
								<p>Total</p>
								<p>{ fmt.Sprintf("%f", os.Item.Total) }</p>
							</div>
							<div>
								<p>Signature</p>
								<p>{ string(os.Item.Signature) }</p>
							</div>
							<div>
								<p>Created At</p>
								<p>{ os.Item.CreatedAt.String() }</p>
							</div>
							<div>
								<p>Updated At</p>
								<p>{ os.Item.UpdatedAt.String() }</p>
							</div>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type OrderNew struct{}

func (on OrderNew) PageFragment() string {
	return "order-new-page-fragment"
}

templ (on OrderNew) Page() {
	@base() {
		@templ.Fragment(on.PageFragment()) {
			<main id="order-new-container">
				<section>
					<div>
						<div>
							<h1>New Order</h1>
							<p>Enter the details for the new order.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.OrderCreate.URL()) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="accountId">Account Id</label>
										<div>
											<input type="text" id="accountId" name="accountId" data-bind="accountId"/>
										</div>
									</div>
									<div>
										<label for="customerName">Customer Name</label>
										<div>
											<input type="text" id="customerName" name="customerName" data-bind="customerName"/>
										</div>
									</div>
									<div>
										<label for="total">Total</label>
										<div>
											<input type="number" id="total" name="total" data-bind="total"/>
										</div>
									</div>
									<div>
										<label for="signature">Signature</label>
										<div>
											<input type="text" id="signature" name="signature" data-bind="signature"/>
										</div>
									</div>
									<div>
										<button type="submit">Create Order</button>
										<a href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type OrderEdit struct {
	Item models.OrderEntity
}

func (oe OrderEdit) PageFragment() string {
	return "order-edit-page-fragment"
}

templ (oe OrderEdit) Page() {
	@base() {
		@templ.Fragment(oe.PageFragment()) {
			<main id="order-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit Order</h1>
							<p>Update the details for this order.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.OrderUpdate.URL(oe.Item.ID)) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="accountId">Account Id</label>
										<div>
											<input type="text" id="accountId" name="accountId" data-bind="accountId" value={ oe.Item.AccountID.String() }/>
										</div>
									</div>
									<div>
										<label for="customerName">Customer Name</label>
										<div>
											<input type="text" id="customerName" name="customerName" data-bind="customerName" value={ oe.Item.CustomerName }/>
										</div>
									</div>
									<div>
										<label for="total">Total</label>
										<div>
											<input type="number" id="total" name="total" data-bind="total" value={ fmt.Sprintf("%f", oe.Item.Total) }/>
										</div>
									</div>
									<div>
										<label for="signature">Signature</label>
										<div>
											<input type="text" id="signature" name="signature" data-bind="signature" value={ string(oe.Item.Signature) }/>
										</div>
									</div>
									<div>
										<button type="submit">Update Order</button>
										<a href={ renderer.ResolveBackURL(ctx, routes.OrderIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
						<div>
							<button
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.OrderDestroy.URL(oe.Item.ID)) }
							>Destroy Order</button>
						</div>
					</div>
				</section>
			</main>
		}
	}
}
