package models

import (
	"context"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

// PersonEntity represents a Person record in the database.
type PersonEntity struct {
	bun.BaseModel `bun:"table:people_data"`
	ID            uuid.UUID  `bun:"id,pk,type:uuid"`
	FirstName     string     `bun:"first_name"`
	LastName      string     `bun:"last_name"`
	Email         *string    `bun:"email"`
	CreatedAt     *time.Time `bun:"created_at"`
	UpdatedAt     *time.Time `bun:"updated_at"`
}

func (p person) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (PersonEntity, error) {
	var entity PersonEntity
	err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx)
	if err != nil {
		return PersonEntity{}, err
	}
	return entity, nil
}

type CreatePersonData struct {
	FirstName string
	LastName  string
	Email     *string
}

func (p person) Create(ctx context.Context, db storage.Executor, data CreatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	_, err := db.NewInsert().Model(&entity).Exec(ctx)
	if err != nil {
		return PersonEntity{}, err
	}
	return entity, nil
}

type UpdatePersonData struct {
	ID        uuid.UUID
	FirstName string
	LastName  string
	Email     *string
	UpdatedAt *time.Time
}

func (p person) Update(ctx context.Context, db storage.Executor, data UpdatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	_, err := db.NewUpdate().
		Model(&entity).
		Where("id = ?", data.ID).
		Exec(ctx)
	if err != nil {
		return PersonEntity{}, err
	}
	return entity, nil
}

func (p person) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*PersonEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)
	return err
}

func (p person) All(ctx context.Context, db storage.Executor) ([]PersonEntity, error) {
	var entities []PersonEntity
	err := db.NewSelect().
		Model(&entities).
		Scan(ctx)
	if err != nil {
		return nil, err
	}
	return entities, nil
}

type PaginatedPerson struct {
	Person     []PersonEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (p person) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedPerson, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	var totalCount int64
	if err := db.NewSelect().
		Model(&PersonEntity{}).Scan(ctx, &totalCount); err != nil {
		return PaginatedPerson{}, err
	}

	var entities []PersonEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedPerson{}, err
	}

	totalPages := (totalCount + pageSize - 1) / pageSize

	return PaginatedPerson{
		Person:     entities,
		TotalCount: totalCount,
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (p person) Upsert(ctx context.Context, db storage.Executor, data CreatePersonData) (PersonEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return PersonEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := PersonEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		FirstName: data.FirstName,
		LastName:  data.LastName,
		Email:     data.Email,
	}

	_, err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Exec(ctx)
	if err != nil {
		return PersonEntity{}, err
	}
	return entity, nil
}
