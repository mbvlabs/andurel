package models

import (
	"context"
	"database/sql"
	"errors"
	"testapp/internal/storage"
	"time"

	"github.com/google/uuid"
	"github.com/uptrace/bun"
)

type BookEntity struct {
	bun.BaseModel `bun:"table:books,alias:books"`
	ID            uuid.UUID       `bun:"id,pk,type:uuid"`
	Title         string          `bun:"title"`
	Author        string          `bun:"author"`
	Price         sql.NullFloat64 `bun:"price"`
	Pages         sql.NullInt32   `bun:"pages"`
	CreatedAt     sql.NullTime    `bun:"created_at"`
	UpdatedAt     sql.NullTime    `bun:"updated_at"`
}

func (b book) Find(ctx context.Context, db storage.Executor, id uuid.UUID) (BookEntity, error) {
	var entity BookEntity
	if err := db.NewSelect().
		Model(&entity).
		Where("id = ?", id).
		Scan(ctx); err != nil {
		return BookEntity{}, err
	}

	return entity, nil
}

type CreateBookData struct {
	Title  string
	Author string
	Price  sql.NullFloat64
	Pages  sql.NullInt32
}

func (b book) Create(ctx context.Context, db storage.Executor, data CreateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	if err := db.NewInsert().Model(&entity).Scan(ctx); err != nil {
		return BookEntity{}, err
	}

	return entity, nil
}

type UpdateBookData struct {
	ID        uuid.UUID
	Title     string
	Author    string
	Price     sql.NullFloat64
	Pages     sql.NullInt32
	UpdatedAt sql.NullTime
}

func (b book) Update(ctx context.Context, db storage.Executor, data UpdateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        data.ID,
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	if err := db.NewUpdate().
		Model(&entity).
		Column("title").
		Column("author").
		Column("price").
		Column("pages").
		Column("updated_at").
		WherePK().
		Returning("*").
		Scan(ctx); err != nil {
		return BookEntity{}, err
	}

	return entity, nil
}

func (b book) Destroy(ctx context.Context, db storage.Executor, id uuid.UUID) error {
	_, err := db.NewDelete().
		Model((*BookEntity)(nil)).
		Where("id = ?", id).
		Exec(ctx)

	return err
}

func (b book) All(ctx context.Context, db storage.Executor) ([]BookEntity, error) {
	var entities []BookEntity
	if err := db.NewSelect().
		Model(&entities).
		Scan(ctx); err != nil {
		return nil, err
	}

	return entities, nil
}

type PaginatedBooks struct {
	Books      []BookEntity
	TotalCount int64
	Page       int64
	PageSize   int64
	TotalPages int64
}

func (b book) Paginate(ctx context.Context, db storage.Executor, page, pageSize int64) (PaginatedBooks, error) {
	if page < 1 {
		page = 1
	}
	if pageSize < 1 {
		pageSize = 10
	}
	if pageSize > 100 {
		pageSize = 100
	}

	offset := (page - 1) * pageSize

	totalCount, err := db.NewSelect().
		Model(&BookEntity{}).Count(ctx)
	if err != nil {
		return PaginatedBooks{}, err
	}

	var entities []BookEntity
	if err := db.NewSelect().
		Model(&entities).
		Limit(int(pageSize)).
		Offset(int(offset)).
		Scan(ctx); err != nil {
		return PaginatedBooks{}, err
	}

	totalPages := (int64(totalCount) + pageSize - 1) / pageSize

	return PaginatedBooks{
		Books:      entities,
		TotalCount: int64(totalCount),
		Page:       page,
		PageSize:   pageSize,
		TotalPages: totalPages,
	}, nil
}

func (b book) Upsert(ctx context.Context, db storage.Executor, data CreateBookData) (BookEntity, error) {
	if err := Validate.Struct(data); err != nil {
		return BookEntity{}, errors.Join(ErrDomainValidation, err)
	}

	entity := BookEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		Title:     data.Title,
		Author:    data.Author,
		Price:     data.Price,
		Pages:     data.Pages,
	}

	if err := db.NewInsert().
		Model(&entity).
		On("CONFLICT (id) DO UPDATE").
		Set("title = excluded.title").
		Set("author = excluded.author").
		Set("price = excluded.price").
		Set("pages = excluded.pages").
		Returning("*").
		Scan(ctx); err != nil {
		return BookEntity{}, err
	}

	return entity, nil
}
