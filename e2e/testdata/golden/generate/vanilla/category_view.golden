package views

import (
	"fmt"
	"testapp/models"
)

templ CategoryIndex(categories []models.Category) {
	@base() {
		<main class="flex-1 px-6 py-10">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Categories</h1>
						<p class="muted">Manage your categories with the shared vanilla component system.</p>
					</div>
					<a class="btn btn-primary" href="/">New Category</a>
				</div>
				if len(categories) == 0 {
					<section class="panel empty-state">
						<div class="stack text-center" data-gap="sm">
							<h2 class="empty-state-title">No categories found</h2>
							<p class="empty-state-description">Create your first category to start filling this view.</p>
						</div>
						<div class="empty-state-actions">
							<a class="btn btn-primary" href="/">New Category</a>
						</div>
					</section>
				} else {
					<div class="panel table-wrap">
						<table class="table">
							<thead>
								<tr>
									<th>Name</th>
									<th>Description</th>
									<th>Created At</th>
									<th>Updated At</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								for _, category := range categories {
									<tr>
										<td>{ category.Name }</td>
										<td>{ category.Description }</td>
										<td>{ category.CreatedAt.String() }</td>
										<td>{ category.UpdatedAt.String() }</td>
										<td>
											<div class="cluster" data-gap="sm">
												<a class="btn btn-ghost btn-sm" href="/">View</a>
												<a class="btn btn-outline btn-sm" href="/">Edit</a>
											</div>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</section>
		</main>
	}
}

templ CategoryShow(category models.Category) {
	@base() {
		<main class="flex-1 px-6 py-10">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Category Details</h1>
						<p class="muted">Review the current values stored for this category.</p>
					</div>
					<div class="cluster" data-gap="sm">
						<a class="btn btn-primary" href="/">Edit</a>
						<a class="btn btn-outline" href="/">Back to List</a>
					</div>
				</div>
				<div class="panel">
					<div class="grid-auto-fit" data-grid="compact">
						<div class="field">
							<p class="field-label">Name</p>
							<p>{ category.Name }</p>
						</div>
						<div class="field">
							<p class="field-label">Description</p>
							<p>{ category.Description }</p>
						</div>
						<div class="field">
							<p class="field-label">Created At</p>
							<p>{ category.CreatedAt.String() }</p>
						</div>
						<div class="field">
							<p class="field-label">Updated At</p>
							<p>{ category.UpdatedAt.String() }</p>
						</div>
					</div>
				</div>
			</section>
		</main>
	}
}

templ CategoryNew() {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">New Category</h1>
						<p class="card-description">Enter the details for the new category.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting && " + fmt.Sprintf("@post('%s')", "/") }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="name">Name</label>
									<div class="field-control">
										<input class="input" id="name" type="text" data-bind="name"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="description">Description</label>
									<div class="field-control">
										<input class="input" id="description" type="text" data-bind="description"/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Create Category</button>
									<a class="btn btn-outline btn-block" href="/">Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}

templ CategoryEdit(category models.Category) {
	@base() {
		<main class="flex flex-1 items-center justify-center px-6 py-10">
			<section class="w-full max-w-md">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Edit Category</h1>
						<p class="card-description">Update the details for this category.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting && " + fmt.Sprintf("@put('%s')", "/") }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="name">Name</label>
									<div class="field-control">
										<input class="input" id="name" type="text" data-bind="name" value={ category.Name }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="description">Description</label>
									<div class="field-control">
										<input class="input" id="description" type="text" data-bind="description" value={ category.Description }/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Update Category</button>
									<a class="btn btn-outline btn-block" href="/">Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
					<div class="card-footer">
						<button
							class="btn btn-destructive btn-block"
							type="button"
							data-on:click={ fmt.Sprintf("@delete('%s')", "/") }
						>Destroy Category</button>
					</div>
				</div>
			</section>
		</main>
	}
}
