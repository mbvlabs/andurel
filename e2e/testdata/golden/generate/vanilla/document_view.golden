package views

import (
	"fmt"
	"strings"
	"testapp/models"
)

templ DocumentIndex(documents []models.Document) {
	@base() {
		<main class="page-shell">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Documents</h1>
						<p class="muted">Manage your documents with the shared vanilla component system.</p>
					</div>
					<a class="btn btn-primary" href="/">New Document</a>
				</div>
				if len(documents) == 0 {
					<section class="panel empty-state">
						<div class="stack text-center" data-gap="sm">
							<h2 class="empty-state-title">No documents found</h2>
							<p class="empty-state-description">Create your first document to start filling this view.</p>
						</div>
						<div class="empty-state-actions">
							<a class="btn btn-primary" href="/">New Document</a>
						</div>
					</section>
				} else {
					<div class="panel table-wrap">
						<table class="table">
							<thead>
								<tr>
									<th>Title</th>
									<th>Tags</th>
									<th>Page Numbers</th>
									<th>View Count</th>
									<th>Is Published</th>
									<th>Created At</th>
									<th>Updated At</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								for _, document := range documents {
									<tr>
										<td>{ document.Title }</td>
										<td>{ strings.Join(document.Tags, ", ") }</td>
										<td>{ fmt.Sprintf("%v", document.PageNumbers) }</td>
										<td>{ fmt.Sprintf("%d", document.ViewCount) }</td>
										<td>{ fmt.Sprintf("%v", document.IsPublished) }</td>
										<td>{ fmt.Sprintf("%v", document.CreatedAt) }</td>
										<td>{ fmt.Sprintf("%v", document.UpdatedAt) }</td>
										<td>
											<div class="cluster" data-gap="sm">
												<a class="btn btn-ghost btn-sm" href="/">View</a>
												<a class="btn btn-outline btn-sm" href="/">Edit</a>
											</div>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</section>
		</main>
	}
}

templ DocumentShow(document models.Document) {
	@base() {
		<main class="page-shell">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>Document Details</h1>
						<p class="muted">Review the current values stored for this document.</p>
					</div>
					<div class="cluster" data-gap="sm">
						<a class="btn btn-primary" href="/">Edit</a>
						<a class="btn btn-outline" href="/">Back to List</a>
					</div>
				</div>
				<div class="panel">
					<div class="grid-auto-fit" data-grid="compact">
						<div class="field">
							<p class="field-label">Title</p>
							<p>{ document.Title }</p>
						</div>
						<div class="field">
							<p class="field-label">Tags</p>
							<p>{ strings.Join(document.Tags, ", ") }</p>
						</div>
						<div class="field">
							<p class="field-label">Page Numbers</p>
							<p>{ fmt.Sprintf("%v", document.PageNumbers) }</p>
						</div>
						<div class="field">
							<p class="field-label">View Count</p>
							<p>{ fmt.Sprintf("%d", document.ViewCount) }</p>
						</div>
						<div class="field">
							<p class="field-label">Is Published</p>
							<p>{ fmt.Sprintf("%v", document.IsPublished) }</p>
						</div>
						<div class="field">
							<p class="field-label">Created At</p>
							<p>{ fmt.Sprintf("%v", document.CreatedAt) }</p>
						</div>
						<div class="field">
							<p class="field-label">Updated At</p>
							<p>{ fmt.Sprintf("%v", document.UpdatedAt) }</p>
						</div>
					</div>
				</div>
			</section>
		</main>
	}
}

templ DocumentNew() {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">New Document</h1>
						<p class="card-description">Enter the details for the new document.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting && " + fmt.Sprintf("@post('%s')", "/") }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="title">Title</label>
									<div class="field-control">
										<input class="input" id="title" type="text" data-bind="title"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="tags">Tags</label>
									<div class="field-control">
										<input class="input" id="tags" type="text" data-bind="tags"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="pageNumbers">Page Numbers</label>
									<div class="field-control">
										<input class="input" id="pageNumbers" type="text" data-bind="pageNumbers"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="viewCount">View Count</label>
									<div class="field-control">
										<input class="input" id="viewCount" type="number" data-bind="viewCount"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="isPublished">Is Published</label>
									<div class="field-control">
										<input class="input" id="isPublished" type="text" data-bind="isPublished"/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Create Document</button>
									<a class="btn btn-outline btn-block" href="/">Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}

templ DocumentEdit(document models.Document) {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Edit Document</h1>
						<p class="card-description">Update the details for this document.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting && " + fmt.Sprintf("@put('%s')", "/") }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="title">Title</label>
									<div class="field-control">
										<input class="input" id="title" type="text" data-bind="title" value={ document.Title }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="tags">Tags</label>
									<div class="field-control">
										<input class="input" id="tags" type="text" data-bind="tags" value={ strings.Join(document.Tags, ", ") }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="pageNumbers">Page Numbers</label>
									<div class="field-control">
										<input class="input" id="pageNumbers" type="text" data-bind="pageNumbers" value={ fmt.Sprintf("%v", document.PageNumbers) }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="viewCount">View Count</label>
									<div class="field-control">
										<input class="input" id="viewCount" type="number" data-bind="viewCount" value={ fmt.Sprintf("%d", document.ViewCount) }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="isPublished">Is Published</label>
									<div class="field-control">
										<input class="input" id="isPublished" type="text" data-bind="isPublished" value={ fmt.Sprintf("%v", document.IsPublished) }/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Update Document</button>
									<a class="btn btn-outline btn-block" href="/">Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
					<div class="card-footer">
						<button
							class="btn btn-destructive btn-block"
							type="button"
							data-on:click={ fmt.Sprintf("@delete('%s')", "/") }
						>Destroy Document</button>
					</div>
				</div>
			</section>
		</main>
	}
}
