



package views

import (
	"fmt"
	"net/http"
	"strings"

	"testapp/internal/hypermedia"
	"testapp/models"

	"testapp/router/routes"
)

type DocumentIndex struct {
	Items []models.DocumentEntity
}

func (di DocumentIndex) PageFragment() string {
	return "document-index-page-fragment"
}

templ (di DocumentIndex) Page() {
	@base() {
		@templ.Fragment(di.PageFragment()) {
			<main id="document-index-container">
				<section>
					<div>
						<div>
							<h1>Documents</h1>
						</div>
						<a href={ routes.DocumentNew.URL() }>New Document</a>
					</div>
					if len(di.Items) == 0 {
						<section>
							<div>
								<h2>No documents found</h2>
							</div>
							<div>
								<a href={ routes.DocumentNew.URL() }>New Document</a>
							</div>
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										<th>Title</th>
										<th>Tags</th>
										<th>Page Numbers</th>
										<th>View Count</th>
										<th>Is Published</th>
										<th>Created At</th>
										<th>Updated At</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, document := range di.Items {
										<tr>
											<td>{ document.Title }</td>
											<td>{ strings.Join(document.Tags, ", ") }</td>
											<td>{ fmt.Sprintf("%v", document.PageNumbers) }</td>
											<td>{ fmt.Sprintf("%d", document.ViewCount) }</td>
											<td>{ fmt.Sprintf("%t", document.IsPublished) }</td>
											<td>{ document.CreatedAt.String() }</td>
											<td>{ document.UpdatedAt.String() }</td>
											<td>
												<div>
													<a href={ routes.DocumentShow.URL(document.ID) }>View</a>
													<a href={ routes.DocumentEdit.URL(document.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}

type DocumentShow struct {
	Item models.DocumentEntity
}

func (ds DocumentShow) PageFragment() string {
	return "document-show-page-fragment"
}

templ (ds DocumentShow) Page() {
	@base() {
		@templ.Fragment(ds.PageFragment()) {
			<main id="document-show-container">
				<section>
					<div>
						<div>
							<h1>Document Details</h1>
						</div>
						<div>
							<a href={ routes.DocumentEdit.URL(ds.Item.ID) }>Edit</a>
							<a href={ hypermedia.ResolveBackURL(ctx, routes.DocumentIndex.URL()) }>Back to List</a>
						</div>
					</div>
					<div>
						<div>
							<div>
								<p>Title</p>
								<p>{ ds.Item.Title }</p>
							</div>
							<div>
								<p>Tags</p>
								<p>{ strings.Join(ds.Item.Tags, ", ") }</p>
							</div>
							<div>
								<p>Page Numbers</p>
								<p>{ fmt.Sprintf("%v", ds.Item.PageNumbers) }</p>
							</div>
							<div>
								<p>View Count</p>
								<p>{ fmt.Sprintf("%d", ds.Item.ViewCount) }</p>
							</div>
							<div>
								<p>Is Published</p>
								<p>{ fmt.Sprintf("%t", ds.Item.IsPublished) }</p>
							</div>
							<div>
								<p>Created At</p>
								<p>{ ds.Item.CreatedAt.String() }</p>
							</div>
							<div>
								<p>Updated At</p>
								<p>{ ds.Item.UpdatedAt.String() }</p>
							</div>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type DocumentNew struct{}

func (dn DocumentNew) PageFragment() string {
	return "document-new-page-fragment"
}

templ (dn DocumentNew) Page() {
	@base() {
		@templ.Fragment(dn.PageFragment()) {
			<main id="document-new-container">
				<section>
					<div>
						<div>
							<h1>New Document</h1>
							<p>Enter the details for the new document.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.DocumentCreate.URL()) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="title">Title</label>
										<div>
											<input type="text" id="title" name="title" data-bind="title"/>
										</div>
									</div>
									<div>
										<label for="tags">Tags</label>
										<div>
											<input type="text" id="tags" name="tags" data-bind="tags"/>
										</div>
									</div>
									<div>
										<label for="pageNumbers">Page Numbers</label>
										<div>
											<input type="text" id="pageNumbers" name="pageNumbers" data-bind="pageNumbers"/>
										</div>
									</div>
									<div>
										<label for="viewCount">View Count</label>
										<div>
											<input type="number" id="viewCount" name="viewCount" data-bind="viewCount"/>
										</div>
									</div>
									<div>
										<input type="checkbox" id="isPublished" name="isPublished" data-bind="isPublished"/>
										<label for="isPublished">Is Published</label>
									</div>
									<div>
										<button type="submit">Create Document</button>
										<a href={ hypermedia.ResolveBackURL(ctx, routes.DocumentIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type DocumentEdit struct {
	Item models.DocumentEntity
}

func (de DocumentEdit) PageFragment() string {
	return "document-edit-page-fragment"
}

templ (de DocumentEdit) Page() {
	@base() {
		@templ.Fragment(de.PageFragment()) {
			<main id="document-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit Document</h1>
							<p>Update the details for this document.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.DocumentUpdate.URL(de.Item.ID)) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="title">Title</label>
										<div>
											<input type="text" id="title" name="title" data-bind="title" value={ de.Item.Title }/>
										</div>
									</div>
									<div>
										<label for="tags">Tags</label>
										<div>
											<input type="text" id="tags" name="tags" data-bind="tags" value={ strings.Join(de.Item.Tags, ", ") }/>
										</div>
									</div>
									<div>
										<label for="pageNumbers">Page Numbers</label>
										<div>
											<input type="text" id="pageNumbers" name="pageNumbers" data-bind="pageNumbers" value={ fmt.Sprintf("%v", de.Item.PageNumbers) }/>
										</div>
									</div>
									<div>
										<label for="viewCount">View Count</label>
										<div>
											<input type="number" id="viewCount" name="viewCount" data-bind="viewCount" value={ fmt.Sprintf("%d", de.Item.ViewCount) }/>
										</div>
									</div>
									<div>
										<input type="checkbox" id="isPublished" name="isPublished" data-bind="isPublished" if de.Item.IsPublished {
	checked
}/>
										<label for="isPublished">Is Published</label>
									</div>
									<div>
										<button type="submit">Update Document</button>
										<a href={ hypermedia.ResolveBackURL(ctx, routes.DocumentIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
						<div>
							<button
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.DocumentDestroy.URL(de.Item.ID)) }
							>Destroy Document</button>
						</div>
					</div>
				</section>
			</main>
		}
	}
}
