package views

import (
	"fmt"
	"net/http"
	"testapp/internal/hypermedia"
	"testapp/internal/renderer"
	"testapp/models"
	"testapp/router/routes"
)

templ StudentFeedbackIndex(student_feedbacks []models.StudentfeedbackEntity) {
	@base() {
		<main class="page-shell">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>StudentFeedbacks</h1>
						<p class="muted">Manage your student_feedbacks with the shared vanilla component system.</p>
					</div>
					<a class="btn btn-primary" href={ routes.StudentFeedbackNew.URL() }>New StudentFeedback</a>
				</div>
				if len(student_feedbacks) == 0 {
					<section class="panel empty-state">
						<div class="stack text-center" data-gap="sm">
							<h2 class="empty-state-title">No student_feedbacks found</h2>
							<p class="empty-state-description">Create your first studentfeedback to start filling this view.</p>
						</div>
						<div class="empty-state-actions">
							<a class="btn btn-primary" href={ routes.StudentFeedbackNew.URL() }>New StudentFeedback</a>
						</div>
					</section>
				} else {
					<div class="panel table-wrap">
						<table class="table">
							<thead>
								<tr>
									<th>Student Id</th>
									<th>Feedback</th>
									<th>Rating</th>
									<th>Created At</th>
									<th>Updated At</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								for _, studentfeedback := range student_feedbacks {
									<tr>
										<td>{ studentfeedback.StudentID }</td>
										<td>{ studentfeedback.Feedback }</td>
										<td>{ fmt.Sprintf("%v", studentfeedback.Rating) }</td>
										<td>{ fmt.Sprintf("%v", studentfeedback.CreatedAt) }</td>
										<td>{ fmt.Sprintf("%v", studentfeedback.UpdatedAt) }</td>
										<td>
											<div class="cluster" data-gap="sm">
												<a class="btn btn-ghost btn-sm" href={ routes.StudentFeedbackShow.URL(studentfeedback.ID) }>View</a>
												<a class="btn btn-outline btn-sm" href={ routes.StudentFeedbackEdit.URL(studentfeedback.ID) }>Edit</a>
											</div>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</section>
		</main>
	}
}

templ StudentFeedbackShow(studentfeedback models.StudentfeedbackEntity) {
	@base() {
		<main class="page-shell">
			<section class="container stack" data-gap="lg">
				<div class="cluster" data-justify="between">
					<div class="stack" data-gap="sm">
						<h1>StudentFeedback Details</h1>
						<p class="muted">Review the current values stored for this studentfeedback.</p>
					</div>
					<div class="cluster" data-gap="sm">
						<a class="btn btn-primary" href={ routes.StudentFeedbackEdit.URL(studentfeedback.ID) }>Edit</a>
						<a class="btn btn-outline" href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
					</div>
				</div>
				<div class="panel">
					<div class="grid-auto-fit" data-grid="compact">
						<div class="field">
							<p class="field-label">Student Id</p>
							<p>{ studentfeedback.StudentID }</p>
						</div>
						<div class="field">
							<p class="field-label">Feedback</p>
							<p>{ studentfeedback.Feedback }</p>
						</div>
						<div class="field">
							<p class="field-label">Rating</p>
							<p>{ fmt.Sprintf("%v", studentfeedback.Rating) }</p>
						</div>
						<div class="field">
							<p class="field-label">Created At</p>
							<p>{ fmt.Sprintf("%v", studentfeedback.CreatedAt) }</p>
						</div>
						<div class="field">
							<p class="field-label">Updated At</p>
							<p>{ fmt.Sprintf("%v", studentfeedback.UpdatedAt) }</p>
						</div>
					</div>
				</div>
			</section>
		</main>
	}
}

templ StudentFeedbackNew() {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">New StudentFeedback</h1>
						<p class="card-description">Enter the details for the new studentfeedback.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting &&" + hypermedia.DataAction(http.MethodPost, routes.StudentFeedbackCreate.URL()) }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="studentId">Student Id</label>
									<div class="field-control">
										<input class="input" type="text" id="studentId" name="studentId" data-bind="studentId"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="feedback">Feedback</label>
									<div class="field-control">
										<input class="input" type="text" id="feedback" name="feedback" data-bind="feedback"/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="rating">Rating</label>
									<div class="field-control">
										<input class="input" type="text" id="rating" name="rating" data-bind="rating"/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Create StudentFeedback</button>
									<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
				</div>
			</section>
		</main>
	}
}

templ StudentFeedbackEdit(studentfeedback models.StudentfeedbackEntity) {
	@base() {
		<main class="auth-shell">
			<section class="center">
				<div class="card">
					<div class="card-header">
						<h1 class="card-title">Edit StudentFeedback</h1>
						<p class="card-description">Update the details for this studentfeedback.</p>
					</div>
					<div class="card-content">
						<form
							class="form"
							data-indicator:submitting
							data-on:submit={ "!$submitting &&" + hypermedia.DataAction(http.MethodPut, routes.StudentFeedbackUpdate.URL(studentfeedback.ID)) }
						>
							<fieldset class="fieldset" data-attr:disabled="$submitting">
								<div class="field">
									<label class="field-label" for="studentId">Student Id</label>
									<div class="field-control">
										<input class="input" type="text" id="studentId" name="studentId" data-bind="studentId" value={ studentfeedback.StudentID }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="feedback">Feedback</label>
									<div class="field-control">
										<input class="input" type="text" id="feedback" name="feedback" data-bind="feedback" value={ studentfeedback.Feedback }/>
									</div>
								</div>
								<div class="field">
									<label class="field-label" for="rating">Rating</label>
									<div class="field-control">
										<input class="input" type="text" id="rating" name="rating" data-bind="rating" value={ fmt.Sprintf("%v", studentfeedback.Rating) }/>
									</div>
								</div>
								<div class="stack" data-gap="sm">
									<button class="btn btn-primary btn-block" type="submit">Update StudentFeedback</button>
									<a class="btn btn-outline btn-block" href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
								</div>
							</fieldset>
						</form>
					</div>
					<div class="card-footer">
						<button
							class="btn btn-destructive btn-block"
							type="button"
							data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.StudentFeedbackDestroy.URL(studentfeedback.ID)) }
						>Destroy StudentFeedback</button>
					</div>
				</div>
			</section>
		</main>
	}
}
