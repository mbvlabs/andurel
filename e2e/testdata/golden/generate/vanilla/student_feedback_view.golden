



package views

import (
	"fmt"
	"net/http"
	"testapp/internal/hypermedia"
	"testapp/internal/renderer"
	"testapp/models"
	"testapp/router/routes"
)

type StudentFeedbackIndex struct {
	Items []models.StudentfeedbackEntity
}

func (sfi StudentFeedbackIndex) PageFragment() string {
	return "studentfeedback-index-page-fragment"
}

templ (sfi StudentFeedbackIndex) Page() {
	@base() {
		@templ.Fragment(sfi.PageFragment()) {
			<main id="studentfeedback-index-container">
				<section>
					<div>
						<div>
							<h1>StudentFeedbacks</h1>
						</div>
						<a href={ routes.StudentFeedbackNew.URL() }>New StudentFeedback</a>
					</div>
					if len(sfi.Items) == 0 {
						<section>
							<div>
								<h2>No student_feedbacks found</h2>
							</div>
							<div>
								<a href={ routes.StudentFeedbackNew.URL() }>New StudentFeedback</a>
							</div>
						</section>
					} else {
						<div>
							<table>
								<thead>
									<tr>
										<th>Student Id</th>
										<th>Feedback</th>
										<th>Rating</th>
										<th>Created At</th>
										<th>Updated At</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									for _, studentfeedback := range sfi.Items {
										<tr>
											<td>{ studentfeedback.StudentID }</td>
											<td>{ studentfeedback.Feedback }</td>
											<td>{ fmt.Sprintf("%d", studentfeedback.Rating) }</td>
											<td>{ studentfeedback.CreatedAt.String() }</td>
											<td>{ studentfeedback.UpdatedAt.String() }</td>
											<td>
												<div>
													<a href={ routes.StudentFeedbackShow.URL(studentfeedback.ID) }>View</a>
													<a href={ routes.StudentFeedbackEdit.URL(studentfeedback.ID) }>Edit</a>
												</div>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
				</section>
			</main>
		}
	}
}

type StudentFeedbackShow struct {
	Item models.StudentfeedbackEntity
}

func (sfs StudentFeedbackShow) PageFragment() string {
	return "studentfeedback-show-page-fragment"
}

templ (sfs StudentFeedbackShow) Page() {
	@base() {
		@templ.Fragment(sfs.PageFragment()) {
			<main id="studentfeedback-show-container">
				<section>
					<div>
						<div>
							<h1>StudentFeedback Details</h1>
						</div>
						<div>
							<a href={ routes.StudentFeedbackEdit.URL(sfs.Item.ID) }>Edit</a>
							<a href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
						</div>
					</div>
					<div>
						<div>
							<div>
								<p>Student Id</p>
								<p>{ sfs.Item.StudentID }</p>
							</div>
							<div>
								<p>Feedback</p>
								<p>{ sfs.Item.Feedback }</p>
							</div>
							<div>
								<p>Rating</p>
								<p>{ fmt.Sprintf("%d", sfs.Item.Rating) }</p>
							</div>
							<div>
								<p>Created At</p>
								<p>{ sfs.Item.CreatedAt.String() }</p>
							</div>
							<div>
								<p>Updated At</p>
								<p>{ sfs.Item.UpdatedAt.String() }</p>
							</div>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type StudentFeedbackNew struct{}

func (sfn StudentFeedbackNew) PageFragment() string {
	return "studentfeedback-new-page-fragment"
}

templ (sfn StudentFeedbackNew) Page() {
	@base() {
		@templ.Fragment(sfn.PageFragment()) {
			<main id="studentfeedback-new-container">
				<section>
					<div>
						<div>
							<h1>New StudentFeedback</h1>
							<p>Enter the details for the new studentfeedback.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPost, routes.StudentFeedbackCreate.URL()) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="studentId">Student Id</label>
										<div>
											<input type="text" id="studentId" name="studentId" data-bind="studentId"/>
										</div>
									</div>
									<div>
										<label for="feedback">Feedback</label>
										<div>
											<input type="text" id="feedback" name="feedback" data-bind="feedback"/>
										</div>
									</div>
									<div>
										<label for="rating">Rating</label>
										<div>
											<input type="number" id="rating" name="rating" data-bind="rating"/>
										</div>
									</div>
									<div>
										<button type="submit">Create StudentFeedback</button>
										<a href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
					</div>
				</section>
			</main>
		}
	}
}

type StudentFeedbackEdit struct {
	Item models.StudentfeedbackEntity
}

func (sfe StudentFeedbackEdit) PageFragment() string {
	return "studentfeedback-edit-page-fragment"
}

templ (sfe StudentFeedbackEdit) Page() {
	@base() {
		@templ.Fragment(sfe.PageFragment()) {
			<main id="studentfeedback-edit-container">
				<section>
					<div>
						<div>
							<h1>Edit StudentFeedback</h1>
							<p>Update the details for this studentfeedback.</p>
						</div>
						<div>
							<form
								data-indicator:_submitting
								data-on:submit={ hypermedia.DataAction(http.MethodPut, routes.StudentFeedbackUpdate.URL(sfe.Item.ID)) }
							>
								<fieldset data-attr:disabled="$_submitting">
									<div>
										<label for="studentId">Student Id</label>
										<div>
											<input type="text" id="studentId" name="studentId" data-bind="studentId" value={ sfe.Item.StudentID }/>
										</div>
									</div>
									<div>
										<label for="feedback">Feedback</label>
										<div>
											<input type="text" id="feedback" name="feedback" data-bind="feedback" value={ sfe.Item.Feedback }/>
										</div>
									</div>
									<div>
										<label for="rating">Rating</label>
										<div>
											<input type="number" id="rating" name="rating" data-bind="rating" value={ fmt.Sprintf("%d", sfe.Item.Rating) }/>
										</div>
									</div>
									<div>
										<button type="submit">Update StudentFeedback</button>
										<a href={ renderer.ResolveBackURL(ctx, routes.StudentFeedbackIndex.URL()) }>Back to List</a>
									</div>
								</fieldset>
							</form>
						</div>
						<div>
							<button
								type="button"
								data-on:click={ hypermedia.DataAction(http.MethodDelete, routes.StudentFeedbackDestroy.URL(sfe.Item.ID)) }
							>Destroy StudentFeedback</button>
						</div>
					</div>
				</section>
			</main>
		}
	}
}
