package controllers

import (
	"database/sql"
	"errors"
	"fmt"
	"log/slog"
	"net/http"
	"strconv"
	"testapp/internal/storage"
	"testapp/models"
	"testapp/router"
	"testapp/router/cookies"
	"testapp/router/routes"
	"testapp/views"

	"github.com/google/uuid"
	"github.com/labstack/echo/v5"
)

type StudentFeedback struct {
	db storage.Pool
}

func NewStudentFeedback(db storage.Pool) StudentFeedback {
	return StudentFeedback{db}
}

var _ = RegisterController(NewStudentFeedback)

func (sf StudentFeedback) Index(etx *echo.Context) error {
	page := int64(1)
	if p := etx.QueryParam("page"); p != "" {
		if parsed, err := strconv.Atoi(p); err == nil && parsed > 0 {
			page = int64(parsed)
		}
	}

	perPage := int64(25)
	if pp := etx.QueryParam("per_page"); pp != "" {
		if parsed, err := strconv.Atoi(pp); err == nil && parsed > 0 &&
			parsed <= 100 {
			perPage = int64(parsed)
		}
	}

	studentFeedbackList, err := models.StudentFeedback.Paginate(
		etx.Request().Context(),
		sf.db.Conn(),
		page,
		perPage,
	)
	if err != nil {
		return render(etx, views.InternalError())
	}

	return render(etx, views.StudentFeedbackIndex{Items: studentFeedbackList.StudentFeedback}.Page())
}

func (sf StudentFeedback) Show(etx *echo.Context) error {
	studentFeedbackID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return render(etx, views.BadRequest())
	}

	studentFeedback, err := models.StudentFeedback.Find(etx.Request().Context(), sf.db.Conn(), studentFeedbackID)
	if err != nil {
		return render(etx, views.NotFound())
	}

	return render(etx, views.StudentFeedbackShow{Item: studentFeedback}.Page())
}

func (sf StudentFeedback) New(etx *echo.Context) error {
	return render(etx, views.StudentFeedbackNew{}.Page())
}

type CreateStudentFeedbackFormPayload struct {
	StudentID string `json:"studentId"`
	Feedback  string `json:"feedback"`
	Rating    int32  `json:"rating"`
}

func (sf StudentFeedback) Create(etx *echo.Context) error {
	var payload CreateStudentFeedbackFormPayload
	if err := etx.Bind(&payload); err != nil {
		slog.ErrorContext(
			etx.Request().Context(),
			"could not parse CreateStudentFeedbackFormPayload",
			"error",
			err,
		)

		return render(etx, views.NotFound())
	}

	data := models.CreateStudentFeedbackData{
		StudentID: payload.StudentID,
		Feedback:  payload.Feedback,
		Rating:    sql.NullInt32{Int32: payload.Rating, Valid: true},
	}

	studentFeedback, err := models.StudentFeedback.Create(
		etx.Request().Context(),
		sf.db.Conn(),
		data,
	)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to create studentFeedback: %v", err)); flashErr != nil {
			return flashErr
		}
		return etx.Redirect(http.StatusSeeOther, routes.StudentFeedbackNew.URL())
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "StudentFeedback created successfully"); flashErr != nil {
		return render(etx, views.InternalError())
	}

	return etx.Redirect(http.StatusSeeOther, routes.StudentFeedbackShow.URL(studentFeedback.ID))
}

func (sf StudentFeedback) Edit(etx *echo.Context) error {
	studentFeedbackID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return render(etx, views.BadRequest())
	}

	studentFeedback, err := models.StudentFeedback.Find(etx.Request().Context(), sf.db.Conn(), studentFeedbackID)
	if err != nil {
		return render(etx, views.NotFound())
	}

	return render(etx, views.StudentFeedbackEdit{Item: studentFeedback}.Page())
}

type UpdateStudentFeedbackFormPayload struct {
	StudentID string `json:"studentId"`
	Feedback  string `json:"feedback"`
	Rating    int32  `json:"rating"`
}

func (sf StudentFeedback) Update(etx *echo.Context) error {
	studentFeedbackID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return render(etx, views.BadRequest())
	}

	var payload UpdateStudentFeedbackFormPayload
	if err := etx.Bind(&payload); err != nil {
		slog.ErrorContext(
			etx.Request().Context(),
			"could not parse UpdateStudentFeedbackFormPayload",
			"error",
			err,
		)

		return render(etx, views.NotFound())
	}

	data := models.UpdateStudentFeedbackData{
		ID:        studentFeedbackID,
		StudentID: payload.StudentID,
		Feedback:  payload.Feedback,
		Rating:    sql.NullInt32{Int32: payload.Rating, Valid: true},
	}

	studentFeedback, err := models.StudentFeedback.Update(
		etx.Request().Context(),
		sf.db.Conn(),
		data,
	)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to update studentFeedback: %v", err)); flashErr != nil {
			return render(etx, views.InternalError())
		}
		return etx.Redirect(
			http.StatusSeeOther,
			routes.StudentFeedbackEdit.URL(studentFeedbackID),
		)
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "StudentFeedback updated successfully"); flashErr != nil {
		return render(etx, views.InternalError())
	}

	return etx.Redirect(http.StatusSeeOther, routes.StudentFeedbackShow.URL(studentFeedback.ID))
}

func (sf StudentFeedback) Destroy(etx *echo.Context) error {
	studentFeedbackID, err := uuid.Parse(etx.Param("id"))
	if err != nil {
		return render(etx, views.BadRequest())
	}

	err = models.StudentFeedback.Destroy(etx.Request().Context(), sf.db.Conn(), studentFeedbackID)
	if err != nil {
		if flashErr := cookies.AddFlash(etx, cookies.FlashError, fmt.Sprintf("Failed to delete studentFeedback: %v", err)); flashErr != nil {
			return render(etx, views.InternalError())
		}
		return etx.Redirect(http.StatusSeeOther, routes.StudentFeedbackIndex.URL())
	}

	if flashErr := cookies.AddFlash(etx, cookies.FlashSuccess, "StudentFeedback destroyed successfully"); flashErr != nil {
		return render(etx, views.InternalError())
	}

	return etx.Redirect(http.StatusSeeOther, routes.StudentFeedbackIndex.URL())
}

func (sf StudentFeedback) RegisterRoutes(r *router.Router) error {
	var errs []error

	_, err := r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.StudentFeedbackIndex.Path(),
		Name:    routes.StudentFeedbackIndex.Name(),
		Handler: sf.Index,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.StudentFeedbackShow.Path(),
		Name:    routes.StudentFeedbackShow.Name(),
		Handler: sf.Show,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.StudentFeedbackNew.Path(),
		Name:    routes.StudentFeedbackNew.Name(),
		Handler: sf.New,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodPost,
		Path:    routes.StudentFeedbackCreate.Path(),
		Name:    routes.StudentFeedbackCreate.Name(),
		Handler: sf.Create,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodGet,
		Path:    routes.StudentFeedbackEdit.Path(),
		Name:    routes.StudentFeedbackEdit.Name(),
		Handler: sf.Edit,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodPut,
		Path:    routes.StudentFeedbackUpdate.Path(),
		Name:    routes.StudentFeedbackUpdate.Name(),
		Handler: sf.Update,
	})
	if err != nil {
		errs = append(errs, err)
	}

	_, err = r.AddRoute(echo.Route{
		Method:  http.MethodDelete,
		Path:    routes.StudentFeedbackDestroy.Path(),
		Name:    routes.StudentFeedbackDestroy.Name(),
		Handler: sf.Destroy,
	})
	if err != nil {
		errs = append(errs, err)
	}

	return errors.Join(errs...)
}
