package factories

import (
	"context"
	"database/sql"
	"fmt"
	"time"

	"testapp/internal/storage"
	"testapp/models"

	"github.com/go-faker/faker/v4"
	"github.com/google/uuid"
)

// PersonFactory wraps models.PersonEntity for testing
type PersonFactory struct {
	models.PersonEntity
}

type PersonOption func(*PersonFactory)

// BuildPerson creates an in-memory Person with default test values.
// Auto-managed fields (ID, timestamps) are left at zero and set by CreatePerson.
func BuildPerson(opts ...PersonOption) models.PersonEntity {
	f := &PersonFactory{
		PersonEntity: models.PersonEntity{
			FirstName: faker.Word(),
			LastName:  faker.Word(),
			Email:     sql.NullString{String: faker.Word(), Valid: true},
		},
	}

	for _, opt := range opts {
		opt(f)
	}

	return f.PersonEntity
}

// CreatePerson creates and persists a Person to the database.
// It returns the entity populated with all DB-assigned values via RETURNING *.
func CreatePerson(ctx context.Context, exec storage.Executor, opts ...PersonOption) (models.PersonEntity, error) {
	built := BuildPerson(opts...)

	entity := models.PersonEntity{
		ID:        uuid.New(),
		CreatedAt: time.Now(),
		UpdatedAt: time.Now(),
		FirstName: built.FirstName,
		LastName:  built.LastName,
		Email:     built.Email,
	}

	if _, err := exec.NewInsert().Model(&entity).Returning("*").Scan(ctx); err != nil {
		return models.PersonEntity{}, err
	}

	return entity, nil
}

// CreatePersons creates multiple Person records at once
func CreatePersons(ctx context.Context, exec storage.Executor, count int, opts ...PersonOption) ([]models.PersonEntity, error) {
	persons := make([]models.PersonEntity, 0, count)

	for i := 0; i < count; i++ {
		entity, err := CreatePerson(ctx, exec, opts...)
		if err != nil {
			return nil, fmt.Errorf("failed to create person %d: %w", i+1, err)
		}
		persons = append(persons, entity)
	}

	return persons, nil
}

// Option functions

// WithPeopleDataFirstName sets the FirstName field
func WithPeopleDataFirstName(value string) PersonOption {
	return func(f *PersonFactory) {
		f.PersonEntity.FirstName = value
	}
}

// WithPeopleDataLastName sets the LastName field
func WithPeopleDataLastName(value string) PersonOption {
	return func(f *PersonFactory) {
		f.PersonEntity.LastName = value
	}
}

// WithPeopleDataEmail sets the Email field
func WithPeopleDataEmail(value sql.NullString) PersonOption {
	return func(f *PersonFactory) {
		f.PersonEntity.Email = value
	}
}
